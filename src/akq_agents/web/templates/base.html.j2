<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ ctx.title }} - {% block title %}{% endblock %}</title>
  <script src="https://unpkg.com/htmx.org@1.9.10"></script>
  <script src="https://unpkg.com/htmx.org@1.9.10/dist/ext/sse.js"></script>
  {% if ctx.echarts_use_cdn %}
  <script src="{{ ctx.echarts_cdn_url }}"></script>
  {% endif %}
  <link rel="stylesheet" href="/static/styles.css?v={{ ctx.boot_ts }}">
</head>
<body>
  <nav>
    <span class="title">{{ ctx.title }}</span>
    <a href="/ops" class="{% if page == 'ops' %}active{% endif %}" title="系统运行状态、后台启停、手动触发任务">运维 Ops<span id="nav-ops-dot" class="nav-dot" style="display:none"></span></a>
    <a href="/research" class="{% if page == 'research' %}active{% endif %}" title="每日组合、因子表现、自动发现的新因子">研究 Research</a>
    <a href="/data" class="{% if page == 'data' %}active{% endif %}" title="查询 AKShare 基础数据：行情、指数、板块、宏观、新闻">数据 Data</a>
    <a href="/logs" class="{% if page == 'logs' %}active{% endif %}" title="实时滚动查看 daemon / web / 回测引擎物理日志">日志 Logs</a>
    <a href="/chat" class="{% if page == 'chat' %}active{% endif %}" title="跟 AI 对话查询系统状态或操作">对话 Chat</a>
    <span class="spacer"></span>
    <details class="nav-disclaimer" title="本控制台仅供研究参考，不构成投资建议；不执行任何交易指令。">
      <summary>ⓘ</summary>
      <span>本控制台仅供研究参考，不构成投资建议；不执行任何交易指令。</span>
    </details>
  </nav>
  <div id="data-freshness-bar" class="freshness-bar"></div>
  <main>
    {% block content %}{% endblock %}
  </main>

  <script>
  // ============================================================
  // 全局 UX helpers — 各页共享（必须先于 block scripts 加载）
  // ============================================================

  // HTML 转义
  function escapeHtml(s) {
    if (s == null) return '';
    return String(s).replace(/[&<>"']/g, c => ({
      '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
    }[c]));
  }

  // FastAPI 错误 detail 可能是 string 或 object，统一展开
  function formatErrorDetail(d) {
    if (!d) return 'unknown error';
    const detail = d.detail;
    if (typeof detail === 'string') return detail;
    if (detail && typeof detail === 'object') return JSON.stringify(detail);
    if (typeof d === 'string') return d;
    return JSON.stringify(d);
  }

  // 在容器里渲染统一的错误态
  function renderFetchError(el, err) {
    if (!el) return;
    const msg = err && err.detail
      ? formatErrorDetail({ detail: err.detail })
      : (err && err.message ? err.message : JSON.stringify(err || {}));
    el.innerHTML = `<div class="empty-state status-error">
      <div class="empty-state-icon">⚠️</div>
      <div class="em-title">请求失败</div>
      <div class="em-hint">${escapeHtml(msg)}</div>
      ${err && err.status ? `<div class="small" style="color:var(--fg-dim);margin-top:4px">HTTP ${err.status}</div>` : ''}
    </div>`;
  }

  // 长操作通用执行器
  // 用于 30s-120s 的后台触发任务：自动禁用按钮 / 显示计时 / 支持后台轮询
  // 调用: runLongOperation({ button, url, body, statusEl, pollUrl, onSuccess, successMessage, pollIsDone })
  async function runLongOperation(opts) {
    const {
      button, url, body, statusEl,
      pollUrl, pollUrlFromResponse, pollInterval = 2000, pollTimeout = 120000,
      pollIsDone,
      onSuccess, onError,
      successMessage,
      method = 'POST',
      runningMessage = '执行中',
    } = opts || {};
    if (!url) throw new Error('runLongOperation: url is required');

    const start = Date.now();
    let ticker = null;
    const setStatus = (txt, cls) => {
      if (!statusEl) return;
      statusEl.classList.remove('status-ok', 'status-error', 'status-warn');
      if (cls) statusEl.classList.add(cls);
      statusEl.innerHTML = txt;
    };
    const startTicker = (label) => {
      stopTicker();
      const update = () => {
        const sec = Math.floor((Date.now() - start) / 1000);
        setStatus(`<span class="lo-spinner"></span> ${label}… ${sec}s`);
      };
      update();
      ticker = setInterval(update, 1000);
    };
    const stopTicker = () => { if (ticker) { clearInterval(ticker); ticker = null; } };

    if (button) {
      button.disabled = true;
      button.classList.add('is-loading');
      if (!button.dataset.origLabel) button.dataset.origLabel = button.innerHTML;
    }
    startTicker(runningMessage);

    try {
      const fetchOpts = { method };
      if (body !== undefined) {
        fetchOpts.headers = { 'Content-Type': 'application/json' };
        fetchOpts.body = typeof body === 'string' ? body : JSON.stringify(body);
      }
      const r = await fetch(url, fetchOpts);
      let data = null;
      try { data = await r.json(); } catch (e) { data = null; }
      if (!r.ok) {
        stopTicker();
        setStatus(`❌ ${formatErrorDetail(data || {})}`, 'status-error');
        if (onError) try { onError(data); } catch (e) {}
        return { ok: false, data, status: r.status };
      }
      // M19: 业务层 noop (HTTP 200 + ok:false/status:noop) — 不能当成功。
      // 典型场景: JobRunner 撞 (job_id, partition) UNIQUE 返 ALREADY_OK 防重复触发,
      // 或 control endpoint 检测到当天/当小时已跑过. 用户点完按钮要看到"⏭ 已跑过"提示,
      // 而不是 ✅ 完成 (会误导用户以为有新结果)。
      // P1-5 (review): noop 白名单 — 之前 (data.ok === false && data.reason_code) 太宽,
      // 任何业务失败带 reason_code 都会被误标 noop 显示成 ⏭ 友好提示而非 ❌ 失败。
      // 白名单只放真正"幂等跳过"语义的 code。
      const NOOP_CODES = new Set(['ALREADY_OK', 'NOT_TRADING_DAY', 'GUARD_ERROR']);
      const isNoop = data && (
        data.status === 'noop' ||
        NOOP_CODES.has(data.reason_code)
      );
      if (isNoop) {
        stopTicker();
        const code = data.reason_code || data.status || 'noop';
        const friendly = {
          ALREADY_OK: '⏭ 今天/本小时已经跑过一次，跳过（同 partition 防重）',
          NOT_TRADING_DAY: '⏭ 今天非交易日，跳过',
          GUARD_ERROR: '⏭ 前置检查不通过',
        }[code] || `⏭ ${code}`;
        setStatus(friendly, 'status-warn');
        if (onError) try { onError(data); } catch (e) {}
        return { ok: false, noop: true, data };
      }
      // 若调用方给了 pollUrlFromResponse, 从 trigger 首响应里派生真正的轮询地址.
      // 用于异步入队端点: trigger 只返回 202 + partition, 需据此拼出 job 状态轮询 URL,
      // 等 daemon 真跑完再回调, 避免\"入队即当完成\"过早刷新看到旧数据.
      let effectivePollUrl = pollUrl;
      if (!effectivePollUrl && typeof pollUrlFromResponse === 'function') {
        try { effectivePollUrl = pollUrlFromResponse(data); } catch (e) { effectivePollUrl = null; }
      }
      if (!effectivePollUrl) {
        stopTicker();
        setStatus(`✅ ${successMessage || (data && data.result) || '完成'}`, 'status-ok');
        if (onSuccess) try { onSuccess(data); } catch (e) {}
        return { ok: true, data };
      }
      startTicker(runningMessage + '（后台轮询中）');
      const isDone = pollIsDone || ((d) => d && (d.running === false || d.status === 'ok' || d.status === 'done'));
      while (true) {
        const elapsed = Date.now() - start;
        if (elapsed > pollTimeout) {
          stopTicker();
          setStatus('⏱ 超时，请稍后手动刷新查看结果', 'status-warn');
          return { ok: false, timeout: true };
        }
        await new Promise(res => setTimeout(res, pollInterval));
        try {
          const pr = await fetch(effectivePollUrl);
          const pd = await pr.json();
          if (isDone(pd)) {
            stopTicker();
            setStatus(`✅ ${successMessage || '完成'}`, 'status-ok');
            if (onSuccess) try { onSuccess(pd); } catch (e) {}
            return { ok: true, data: pd };
          }
        } catch (e) { /* 单次失败先忽略，下一轮重试 */ }
      }
    } catch (e) {
      stopTicker();
      setStatus(`❌ 网络异常：${escapeHtml(e.message || String(e))}`, 'status-error');
      if (onError) try { onError(e); } catch (_) {}
      return { ok: false, error: e };
    } finally {
      if (button) {
        button.disabled = false;
        button.classList.remove('is-loading');
      }
    }
  }

  // 给表格 <th> 加可点击排序：前端排序，三态（升 / 降 / 取消）。
  // 用法: makeSortable(tableEl) — 自动给所有 <th> 加监听
  // 单元格的"原始可比值"取自:
  //   1) <td data-sort-value="..."> 显式指定
  //   2) 单元格文本（自动识别百分比 / 千分位 / 货币符号 / 数字；其它当字符串）
  function makeSortable(tableEl) {
    if (!tableEl || tableEl.dataset.sortableInit === '1') return;
    tableEl.dataset.sortableInit = '1';
    const ths = tableEl.querySelectorAll('thead th');
    ths.forEach((th, idx) => {
      // 跳过明确禁用的列（th 上加 data-no-sort）
      if (th.dataset.noSort === '1') return;
      th.classList.add('sortable');
      th.addEventListener('click', () => sortTableBy(tableEl, idx, th));
    });
  }

  function _cellSortValue(td) {
    if (!td) return { kind: 'str', v: '' };
    if (td.dataset && td.dataset.sortValue != null) {
      const raw = td.dataset.sortValue;
      const n = parseFloat(raw);
      if (!isNaN(n) && isFinite(n)) return { kind: 'num', v: n };
      return { kind: 'str', v: raw };
    }
    let txt = (td.innerText || td.textContent || '').trim();
    if (txt === '' || txt === '—' || txt === '-') return { kind: 'num', v: -Infinity, missing: true };
    // 去掉 ¥ , % 后试数字
    const cleaned = txt.replace(/[,¥%\s]/g, '').replace(/^[+]/, '');
    const n = parseFloat(cleaned);
    if (!isNaN(n) && isFinite(n) && /^[+-]?\d/.test(cleaned)) {
      return { kind: 'num', v: n };
    }
    return { kind: 'str', v: txt.toLowerCase() };
  }

  function sortTableBy(tableEl, colIdx, th) {
    const tbody = tableEl.tBodies[0];
    if (!tbody) return;
    const rows = Array.from(tbody.rows);
    // 第一次保存原始顺序
    if (!tbody.dataset.origCaptured) {
      rows.forEach((r, i) => r.dataset.origIdx = String(i));
      tbody.dataset.origCaptured = '1';
    }
    // 当前模式：none → asc → desc → none ...
    const current = th.dataset.sortMode || 'none';
    const next = current === 'none' ? 'asc' : (current === 'asc' ? 'desc' : 'none');
    // 清同表格其它 th 状态
    tableEl.querySelectorAll('thead th').forEach(other => {
      if (other !== th) {
        other.classList.remove('sort-asc', 'sort-desc');
        other.dataset.sortMode = 'none';
      }
    });
    th.classList.remove('sort-asc', 'sort-desc');
    if (next === 'asc') th.classList.add('sort-asc');
    if (next === 'desc') th.classList.add('sort-desc');
    th.dataset.sortMode = next;

    if (next === 'none') {
      // 还原
      rows.sort((a, b) => Number(a.dataset.origIdx) - Number(b.dataset.origIdx));
    } else {
      const sign = next === 'asc' ? 1 : -1;
      rows.sort((a, b) => {
        const av = _cellSortValue(a.cells[colIdx]);
        const bv = _cellSortValue(b.cells[colIdx]);
        // missing 永远沉底
        if (av.missing && !bv.missing) return 1;
        if (bv.missing && !av.missing) return -1;
        if (av.kind === 'num' && bv.kind === 'num') return (av.v - bv.v) * sign;
        return String(av.v).localeCompare(String(bv.v)) * sign;
      });
    }
    const frag = document.createDocumentFragment();
    rows.forEach(r => frag.appendChild(r));
    tbody.appendChild(frag);
  }

  // ============================================================
  // 轻量 toast — toast(message, level='ok'|'warn'|'error', { duration })
  // ============================================================
  function toast(message, level, opts) {
    const lv = (level || 'ok').toLowerCase();
    const duration = (opts && opts.duration != null) ? opts.duration : 3000;
    const text = typeof message === 'string' ? message : JSON.stringify(message);
    const key = lv + '|' + text;
    let host = document.getElementById('toast-host');
    if (!host) {
      host = document.createElement('div');
      host.id = 'toast-host';
      host.className = 'toast-host';
      document.body.appendChild(host);
    }
    // 去重: 同内容同级别已存在 → 重置倒计时 + 抖动提示
    const existing = host.querySelector(`.toast[data-key="${CSS.escape(key)}"]:not(.is-out)`);
    if (existing) {
      if (existing._dismissTimer) clearTimeout(existing._dismissTimer);
      existing.classList.remove('toast-bump');
      // 触发动画重启
      void existing.offsetWidth;
      existing.classList.add('toast-bump');
      existing._dismissTimer = setTimeout(() => {
        existing.classList.add('is-out');
        setTimeout(() => existing.remove(), 280);
      }, duration);
      return existing;
    }
    // 数量上限 3: 超出移除最早的
    const MAX = 3;
    const alive = Array.from(host.querySelectorAll('.toast:not(.is-out)'));
    if (alive.length >= MAX) {
      for (let i = 0; i <= alive.length - MAX; i++) {
        const old = alive[i];
        if (old._dismissTimer) clearTimeout(old._dismissTimer);
        old.classList.add('is-out');
        setTimeout(() => old.remove(), 280);
      }
    }
    const el = document.createElement('div');
    el.className = `toast toast-${lv}`;
    el.dataset.key = key;
    const icon = lv === 'error' ? '❌' : (lv === 'warn' ? '⚠' : '✓');
    el.innerHTML = `<span class="toast-icon">${icon}</span><span class="toast-msg"></span>`;
    el.querySelector('.toast-msg').textContent = text;
    host.appendChild(el);
    el._dismissTimer = setTimeout(() => {
      el.classList.add('is-out');
      setTimeout(() => el.remove(), 280);
    }, duration);
    return el;
  }

  // confirmDialog(message, opts?) → Promise<bool>
  // opts: { title, confirmLabel, cancelLabel, danger }
  function confirmDialog(message, opts) {
    return new Promise(resolve => {
      const o = opts || {};
      const title = o.title || '请确认';
      const confirmLabel = o.confirmLabel || '确定';
      const cancelLabel = o.cancelLabel || '取消';
      const danger = !!o.danger;
      const back = document.createElement('div');
      back.className = 'confirm-backdrop';
      back.innerHTML = `
        <div class="confirm-window" role="dialog" aria-modal="true">
          <div class="confirm-head">${escapeHtml(title)}</div>
          <div class="confirm-body"></div>
          <div class="confirm-actions">
            <button class="confirm-cancel" type="button">${escapeHtml(cancelLabel)}</button>
            <button class="confirm-ok ${danger ? 'is-danger' : ''}" type="button">${escapeHtml(confirmLabel)}</button>
          </div>
        </div>
      `;
      back.querySelector('.confirm-body').textContent = message;
      document.body.appendChild(back);
      const cleanup = (val) => {
        back.classList.add('is-out');
        setTimeout(() => back.remove(), 180);
        document.removeEventListener('keydown', keyHandler);
        resolve(val);
      };
      const keyHandler = (e) => {
        if (e.key === 'Escape') cleanup(false);
        if (e.key === 'Enter') cleanup(true);
      };
      document.addEventListener('keydown', keyHandler);
      back.querySelector('.confirm-cancel').addEventListener('click', () => cleanup(false));
      back.querySelector('.confirm-ok').addEventListener('click', () => cleanup(true));
      back.addEventListener('click', e => { if (e.target === back) cleanup(false); });
      // 焦点放到确认按钮
      setTimeout(() => back.querySelector('.confirm-ok').focus(), 30);
    });
  }

  // ============================================================
  // 全局快捷键
  //   g+r/o/d/c/l → 跳转 研究 / 运维 / 数据 / 对话 / 日志
  //   r           → 触发当前页 'hotkey:refresh' 事件
  //   /           → 聚焦 #hotkey-search
  //   ? 或 Shift+/ → 弹出帮助 toast
  // ============================================================
  (function setupHotkeys() {
    let gKeyTimer = null;
    const PAGES = { r: '/research', o: '/ops', d: '/data', c: '/chat', l: '/logs' };
    document.addEventListener('keydown', (e) => {
      // input/textarea/select 内不触发
      const t = e.target;
      if (!t) return;
      if (['INPUT','TEXTAREA','SELECT'].includes(t.tagName)) return;
      if (t.isContentEditable) return;
      // 已在 modal/confirm 里（confirmDialog 自己处理 Enter/Esc）也不要再触发
      if (document.querySelector('.confirm-backdrop:not(.is-out)')) return;
      if (e.metaKey || e.ctrlKey || e.altKey) return;

      const k = e.key.toLowerCase();

      // 'g' → 进入二段
      if (k === 'g' && !gKeyTimer) {
        gKeyTimer = setTimeout(() => { gKeyTimer = null; }, 1500);
        toast("→ 等待第二个键: r/o/d/c/l", 'ok', { duration: 1400 });
        return;
      }
      if (gKeyTimer) {
        clearTimeout(gKeyTimer);
        gKeyTimer = null;
        if (PAGES[k]) {
          e.preventDefault();
          location.href = PAGES[k];
          return;
        }
      }

      // 'r' — 刷新当前页
      if (k === 'r' && !e.shiftKey) {
        let handled = false;
        const ack = () => { handled = true; };
        window.addEventListener('hotkey:refresh:ack', ack, { once: true });
        window.dispatchEvent(new CustomEvent('hotkey:refresh'));
        setTimeout(() => {
          window.removeEventListener('hotkey:refresh:ack', ack);
          if (!handled && typeof toast === 'function') {
            toast('本页无刷新动作', 'warn', { duration: 1500 });
          }
        }, 50);
        return;
      }

      // '/' — 聚焦页面搜索框
      if (k === '/' && !e.shiftKey) {
        const search = document.getElementById('hotkey-search')
                    || document.querySelector('[data-hotkey-search]');
        if (search) {
          e.preventDefault();
          search.focus();
          if (typeof search.select === 'function') search.select();
        } else if (typeof toast === 'function') {
          toast('本页无搜索框', 'warn', { duration: 1500 });
        }
        return;
      }

      // '?' 帮助
      if (k === '?' || (e.shiftKey && k === '/')) {
        e.preventDefault();
        toast('快捷键: g+r/o/d/c/l 跳转 · r 刷新当前页 · / 聚焦搜索 · ? 查看帮助', 'ok', { duration: 4500 });
        return;
      }
    });
  })();
  </script>

  {% block scripts %}{% endblock %}

  <script>
  // ============================================================
  // 数据新鲜度条 — 30s 轮询
  // ============================================================
  async function loadDataFreshness() {
    try {
      const r = await fetch('/api/ops/data-freshness');
      if (!r.ok) return;
      const d = await r.json();
      const bar = document.getElementById('data-freshness-bar');
      if (!bar) return;
      const fresh = d.all_fresh;
      const dotColor = fresh ? '#5eead4' : '#fbbf24';
      bar.innerHTML = `
        <span class="fresh-dot" style="background:${dotColor}"></span>
        <span><b>今日:</b> ${d.today}</span>
        <span class="sep">·</span>
        <span>行情 <code>${d.ohlcv_latest || '-'}</code></span>
        <span>组合 <code>${d.portfolio_snapshots_latest || '-'}</code></span>
        <span>净值 <code>${d.portfolio_nav_latest || '-'}</code></span>
        <span>清单 <code>${d.trade_list_latest || '-'}</code></span>
        <span class="sep">·</span>
        <span>因子 <code>${d.factor_metrics_latest || '-'}</code></span>
        <span>提案 <code>${d.factor_proposals_count}</code></span>
        <span>持仓 <code>${d.holdings_count}</code></span>
      `;
    } catch {}
  }
  window.addEventListener('load', loadDataFreshness);
  setInterval(loadDataFreshness, 30000);

  // ============================================================
  // 导航「运维 Ops」健康红点 — 30s 轮询 /api/ops/health
  // 让 daemon 挂掉 / 任务失败 / 数据异常 在任意页面都能被感知，异常追着人跑。
  // ============================================================
  async function loadOpsHealthDot() {
    const dot = document.getElementById('nav-ops-dot');
    if (!dot) return;
    try {
      const r = await fetch('/api/ops/health');
      if (!r.ok) return;
      const d = await r.json();
      const dh = d.data_health || {};
      const dm = d.daemon || {};
      const tb = d.today_batch;
      const evt = d.scheduler_events_24h_by_level || {};
      const healthRaw = (dh.health || 'UNKNOWN').toUpperCase();
      const errCount = Number(evt.error || 0);
      const tbStatus = tb ? String(tb.status || '').toLowerCase() : '';
      const tbFailed = ['error', 'failed', 'crashed', 'interrupted', 'timeout'].includes(tbStatus);

      let level = null; // 'danger' | 'warn' | null
      let reason = '';
      if (dm.is_alive === false) { level = 'danger'; reason = '后台守护进程未运行'; }
      else if (healthRaw === 'FAILED' || healthRaw === 'DEGRADED' || tbFailed) {
        level = 'danger';
        reason = tbFailed ? '今日盘后批处理失败' : ('数据健康度异常（' + healthRaw + '）');
      } else if (healthRaw === 'PENDING_TODAY' || errCount > 0) {
        level = 'warn';
        reason = errCount > 0 ? ('近 24h 有 ' + errCount + ' 个错误事件') : '今日数据待刷新';
      }

      if (!level) {
        dot.style.display = 'none';
        dot.title = '';
      } else {
        dot.style.display = 'inline-block';
        dot.className = 'nav-dot nav-dot-' + level;
        dot.title = '运维需关注：' + reason + '（点进去看详情）';
      }
    } catch {}
  }
  window.addEventListener('load', loadOpsHealthDot);
  setInterval(loadOpsHealthDot, 30000);
  </script>
</body>
</html>
