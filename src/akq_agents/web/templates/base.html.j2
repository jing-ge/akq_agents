<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ ctx.title }} - {% block title %}{% endblock %}</title>
  <script src="https://unpkg.com/htmx.org@1.9.10"></script>
  <script src="https://unpkg.com/htmx.org@1.9.10/dist/ext/sse.js"></script>
  {% if ctx.echarts_use_cdn %}
  <script src="{{ ctx.echarts_cdn_url }}"></script>
  {% endif %}
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
      margin: 0;
      background: #f7f8fa;
      color: #1f1f1f;
    }
    nav {
      background: #1f2937;
      color: #fff;
      padding: 12px 24px;
      display: flex;
      gap: 16px;
      align-items: center;
    }
    nav a {
      color: #fff;
      text-decoration: none;
      padding: 4px 8px;
      border-radius: 4px;
    }
    nav a.active { background: #374151; }
    nav .title { font-weight: bold; flex: 0 0 auto; }
    nav .spacer { flex: 1; }
    nav .disclaimer { font-size: 12px; color: #9ca3af; }
    main { max-width: 1280px; margin: 24px auto; padding: 0 24px; }
    h1 { font-size: 20px; margin: 0 0 16px 0; }
    h2 { font-size: 16px; margin: 24px 0 12px 0; }
    .card { background: #fff; border-radius: 8px; padding: 16px; margin-bottom: 16px; box-shadow: 0 1px 3px rgba(0,0,0,.06); }
    .grid { display: grid; gap: 16px; }
    .grid-2 { grid-template-columns: 1fr 1fr; }
    .grid-3 { grid-template-columns: 1fr 1fr 1fr; }
    .grid-4 { grid-template-columns: repeat(4, 1fr); }
    @media (max-width: 800px) { .grid-2, .grid-3, .grid-4 { grid-template-columns: 1fr; } }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    th, td { padding: 6px 8px; text-align: left; border-bottom: 1px solid #f3f4f6; }
    th { background: #f9fafb; font-weight: 600; }
    code { background: #f3f4f6; padding: 2px 6px; border-radius: 3px; font-size: 12px; }
    .status-ok { color: #10b981; font-weight: 600; }
    .status-warning { color: #f59e0b; font-weight: 600; }
    .status-error, .status-failed, .status-crashed { color: #ef4444; font-weight: 600; }
    .status-skipped { color: #6b7280; }
    .status-timeout { color: #f59e0b; }
    .status-interrupted { color: #f97316; }
    .status-running { color: #3b82f6; }
    .pill {
      display: inline-block; padding: 2px 8px; border-radius: 999px; font-size: 11px;
      background: #e5e7eb; color: #1f2937;
    }
    .pill.alive { background: #d1fae5; color: #065f46; }
    .pill.dead { background: #fee2e2; color: #991b1b; }
    .stat-num { font-size: 24px; font-weight: 700; }
    .stat-label { font-size: 12px; color: #6b7280; }
    .chart { width: 100%; height: 320px; }
    .small { font-size: 12px; color: #6b7280; }
    input, select, button {
      font: inherit; padding: 6px 10px; border: 1px solid #d1d5db; border-radius: 4px;
      background: #fff;
    }
    button { cursor: pointer; }
    button:hover { background: #f3f4f6; }
    button.primary { background: #1f2937; color: #fff; border-color: #1f2937; }
    button.primary:hover { background: #374151; }
    .chat-window { height: 60vh; overflow-y: auto; padding: 12px; background: #fafafa; border-radius: 8px; }
    .chat-msg { margin-bottom: 12px; padding: 8px 12px; border-radius: 8px; max-width: 80%; }
    .chat-msg.user { background: #3b82f6; color: #fff; margin-left: auto; }
    .chat-msg.assistant { background: #fff; border: 1px solid #e5e7eb; }
    .chat-msg.tool { background: #f3f4f6; font-size: 12px; font-family: monospace; }
    .chat-input { display: flex; gap: 8px; margin-top: 12px; }
    .chat-input input { flex: 1; }
  </style>
</head>
<body>
  <nav>
    <span class="title">{{ ctx.title }}</span>
    <a href="/ops" class="{% if page == 'ops' %}active{% endif %}">Ops</a>
    <a href="/research" class="{% if page == 'research' %}active{% endif %}">Research</a>
    <a href="/chat" class="{% if page == 'chat' %}active{% endif %}">Chat</a>
    <span class="spacer"></span>
    <span class="disclaimer">本控制台仅供研究参考，不构成投资建议；不执行任何交易指令。</span>
  </nav>
  <main>
    {% block content %}{% endblock %}
  </main>
  {% block scripts %}{% endblock %}
</body>
</html>
