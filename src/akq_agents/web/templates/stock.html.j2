// ---------------------------------------------------------------
// 格式化辅助
// ---------------------------------------------------------------
// 分位条填充: 给定 0-100 百分位, 更新进度条宽度和 label 数值/语义色.
//   - null: 保持 0% + label='—'
//   - <30:  low  (绿, 偏便宜)
//   - 30-70: mid (中性)
//   - >70:  high (红, 偏贵)
function fillPctBar(fillId, labelId, pct) {
  const fillEl = document.getElementById(fillId);
  const labelEl = document.getElementById(labelId);
  if (!fillEl || !labelEl) return;
  if (pct == null || isNaN(pct)) {
    fillEl.style.width = '0%';
    labelEl.textContent = '—';
    labelEl.className = 'hg-pct-bar-label';
    return;
  }
  const clamped = Math.max(0, Math.min(100, Number(pct)));
  fillEl.style.width = clamped.toFixed(0) + '%';
  labelEl.textContent = clamped.toFixed(0) + '%';
  labelEl.className = 'hg-pct-bar-label ' + (clamped < 30 ? 'low' : clamped > 70 ? 'high' : 'mid');
}

// 均线速览条: K 线加载后, 用最后一根 close 对比 MA5/10/20/60/120 位置.
//   - 本地算, 无需网络.
//   - 分钟 K / 分时 场景下 bar 是分钟, 均线含义会变 (改成'近 N 分钟均线'),
//     所以只在日/周/月/年 K 时渲染, 其它周期 hint '切到日 K 后自动计算'.
function renderMaBadges(kline) {
  const badgesEl = document.getElementById('ma-strip-badges');
  if (!badgesEl) return;
  const period = (kline && kline.period) || '';
  const isDaily = ['D', 'W', 'M', 'Y'].includes(period);
  if (!isDaily) {
    badgesEl.innerHTML = '<span class="ma-strip-hint">切到日/周/月/年 K 后自动计算</span>';
    return;
  }
  const bars = (kline && kline.bars) || [];
  if (bars.length < 5) {
    badgesEl.innerHTML = '<span class="ma-strip-hint">bars 不足, 无法算均线</span>';
    return;
  }
  const closes = bars.map(b => Number(b.c)).filter(c => !isNaN(c));
  if (closes.length < 5) {
    badgesEl.innerHTML = '<span class="ma-strip-hint">收盘价数据不足</span>';
    return;
  }
  const current = closes[closes.length - 1];
  const windows = [5, 10, 20, 60, 120];
  const html = [];
  for (const w of windows) {
    if (closes.length < w) continue;  // 数据不够跳过
    const slice = closes.slice(-w);
    const ma = slice.reduce((a, b) => a + b, 0) / w;
    const diffPct = ((current - ma) / ma) * 100;
    const dir = diffPct > 0.5 ? 'above' : diffPct < -0.5 ? 'below' : 'flat';
    const sign = diffPct >= 0 ? '+' : '';
    html.push(
      `<span class="ma-badge ${dir}" title="MA${w} = ${ma.toFixed(2)}, 现价${dir === 'above' ? '站上' : dir === 'below' ? '跌破' : '贴近'}此均线">`
      + `<span class="ma-badge-name">MA${w}</span>`
      + `<span class="ma-badge-val">${ma.toFixed(2)}</span>`
      + `<span class="ma-badge-diff">${sign}${diffPct.toFixed(1)}%</span>`
      + `</span>`
    );
  }
  if (html.length === 0) {
    badgesEl.innerHTML = '<span class="ma-strip-hint">bars 不足 5 根, 无均线</span>';
    return;
  }
  badgesEl.innerHTML = html.join('');
}

// 数据结论卡刷新: overview 或 kline 更新后调用一次, 在 K 线下方常驻显示.
// 无 overview + 无 kline 时 hide, 有任何一个就显示 (会跳过缺数据的那几行).
function refreshInsightsPanel() {
  const el = document.getElementById('quick-insights-panel');
  if (!el) return;
  if (currentOverview == null && currentKlineData == null) {
    el.style.display = 'none';
    return;
  }
  el.style.display = '';
  el.innerHTML = buildQuickInsightsCard(currentOverview, currentKlineData, currentPeers);
}

// AI 数据结论卡: 展开 AI 面板时, 在 LLM 请求出结果前先展示这一卡结构化结论,
// 用户第一秒就有可读内容. 全部本地算, 不请求任何后端.
//   - 估值位置: PE/PB 5y 分位 → 便宜/中位/偏贵
//   - 均线位置: 现价 vs MA5/20/60/120 → 多头/空头位置
//   - 近期表现: 最近 5/20/60 日累计涨跌 %
//   - 成交动能: 最近 5 日平均量 vs 20 日均量 → 放量/缩量
//   - 市值分档: 总市值 → 大盘/中盘/小盘 (按 300 亿 / 100 亿 门槛)
//   - 行业对比: 个股 vs 行业中位数 20 日累计涨跌
function buildQuickInsightsCard(overview, kline, peers) {
  const rows = [];  // 每行: {label, value, verdict, cls}

  // ==== 1. 估值位置 ====
  if (overview) {
    const pe = overview.pe_ratio;
    const pePct = overview.pe_percentile_5y;
    const pb = overview.pb_ratio;
    const pbPct = overview.pb_percentile_5y;
    const verdictOf = (pct) => pct == null ? '—' :
      pct < 20 ? '<b class="qi-cheap">显著低估</b>' :
      pct < 40 ? '<b class="qi-lowish">偏便宜</b>' :
      pct < 60 ? '<span class="qi-mid">中位</span>' :
      pct < 80 ? '<b class="qi-pricey">偏贵</b>' :
                 '<b class="qi-expensive">显著高估</b>';
    if (pe != null || pb != null) {
      const parts = [];
      if (pe != null) parts.push('PE ' + pe.toFixed(2) + (pePct != null ? ` (5y 分位 ${pePct.toFixed(0)}%)` : ''));
      if (pb != null) parts.push('PB ' + pb.toFixed(2) + (pbPct != null ? ` (5y 分位 ${pbPct.toFixed(0)}%)` : ''));
      // 综合判定用 pe/pb 分位平均
      let combined = null;
      if (pePct != null && pbPct != null) combined = (pePct + pbPct) / 2;
      else if (pePct != null) combined = pePct;
      else if (pbPct != null) combined = pbPct;
      rows.push({ label: '估值位置', value: parts.join(' · '), verdict: verdictOf(combined) });
    }
  }

  // ==== 2. 均线位置 (需要日线 kline) ====
  if (kline && ['D', 'W', 'M', 'Y'].includes(kline.period) && kline.bars && kline.bars.length >= 20) {
    const closes = kline.bars.map(b => Number(b.c)).filter(x => !isNaN(x));
    const cur = closes[closes.length - 1];
    const maAt = (w) => {
      if (closes.length < w) return null;
      const s = closes.slice(-w);
      return s.reduce((a, b) => a + b, 0) / w;
    };
    const above = [5, 10, 20, 60].map(w => {
      const ma = maAt(w);
      return ma != null && cur > ma;
    });
    const nAbove = above.filter(Boolean).length;
    let verdict;
    if (nAbove === 4) verdict = '<b class="qi-pricey">多头排列 (站上全部主要均线)</b>';
    else if (nAbove === 0) verdict = '<b class="qi-cheap">空头排列 (跌破全部主要均线)</b>';
    else if (nAbove >= 3) verdict = '<b class="qi-lowish">偏多 (' + nAbove + '/4 站上)</b>';
    else if (nAbove >= 2) verdict = '<span class="qi-mid">震荡 (' + nAbove + '/4 站上)</span>';
    else verdict = '<b class="qi-expensive">偏空 (' + nAbove + '/4 站上)</b>';
    const parts = [];
    for (const w of [5, 20, 60]) {
      const ma = maAt(w);
      if (ma != null) parts.push(`MA${w} ${ma.toFixed(2)}`);
    }
    rows.push({ label: '均线位置', value: '现价 ' + cur.toFixed(2) + ' · ' + parts.join(' · '), verdict });
  }

  // ==== 3. 近期表现 ====
  if (kline && ['D', 'W', 'M', 'Y'].includes(kline.period) && kline.bars && kline.bars.length >= 5) {
    const closes = kline.bars.map(b => Number(b.c)).filter(x => !isNaN(x));
    const cur = closes[closes.length - 1];
    const chgPct = (n) => {
      if (closes.length < n + 1) return null;
      const past = closes[closes.length - 1 - n];
      return (cur - past) / past * 100;
    };
    const p5 = chgPct(5), p20 = chgPct(20), p60 = chgPct(60);
    const parts = [];
    const cls = (v) => v == null ? '' : v > 0 ? 'qi-pricey' : v < 0 ? 'qi-cheap' : 'qi-mid';
    const fmt = (v) => v == null ? '—' : (v > 0 ? '+' : '') + v.toFixed(1) + '%';
    parts.push(`近 5 日 <b class="${cls(p5)}">${fmt(p5)}</b>`);
    parts.push(`近 20 日 <b class="${cls(p20)}">${fmt(p20)}</b>`);
    parts.push(`近 60 日 <b class="${cls(p60)}">${fmt(p60)}</b>`);
    let verdict;
    const p = p20 == null ? p5 : p20;
    if (p == null) verdict = '—';
    else if (p > 20) verdict = '<b class="qi-pricey">强势上涨</b>';
    else if (p > 5) verdict = '<b class="qi-lowish">温和上涨</b>';
    else if (p > -5) verdict = '<span class="qi-mid">震荡</span>';
    else if (p > -20) verdict = '<b class="qi-cheap">温和下跌</b>';
    else verdict = '<b class="qi-expensive">大幅下跌</b>';
    rows.push({ label: '近期表现', value: parts.join(' · '), verdict });
  }

  // ==== 4. 成交动能 ====
  if (kline && ['D'].includes(kline.period) && kline.bars && kline.bars.length >= 20) {
    const vols = kline.bars.map(b => Number(b.v)).filter(x => !isNaN(x) && x > 0);
    if (vols.length >= 20) {
      const v5 = vols.slice(-5).reduce((a, b) => a + b, 0) / 5;
      const v20 = vols.slice(-20).reduce((a, b) => a + b, 0) / 20;
      const ratio = v5 / v20;
      let verdict;
      if (ratio > 1.5) verdict = '<b class="qi-pricey">显著放量 (' + ratio.toFixed(2) + 'x)</b>';
      else if (ratio > 1.15) verdict = '<b class="qi-lowish">温和放量 (' + ratio.toFixed(2) + 'x)</b>';
      else if (ratio < 0.7) verdict = '<b class="qi-cheap">显著缩量 (' + ratio.toFixed(2) + 'x)</b>';
      else if (ratio < 0.85) verdict = '<span class="qi-mid">温和缩量 (' + ratio.toFixed(2) + 'x)</span>';
      else verdict = '<span class="qi-mid">量能平稳 (' + ratio.toFixed(2) + 'x)</span>';
      rows.push({ label: '成交动能', value: '近 5 日均量 vs 近 20 日均量', verdict });
    }
  }

  // ==== 5. 市值分档 ====
  if (overview && overview.market_cap != null) {
    const cap = overview.market_cap;
    let verdict;
    if (cap > 3e11) verdict = '<b class="qi-pricey">大盘股 (>3000 亿)</b>';
    else if (cap > 1e11) verdict = '<b class="qi-lowish">大盘股 (1000-3000 亿)</b>';
    else if (cap > 3e10) verdict = '<span class="qi-mid">中盘股 (300-1000 亿)</span>';
    else if (cap > 1e10) verdict = '<b class="qi-cheap">中小盘 (100-300 亿)</b>';
    else verdict = '<b class="qi-expensive">小盘股 (<100 亿)</b>';
    rows.push({ label: '市值分档', value: '总市值 ' + (cap / 1e8).toFixed(1) + ' 亿', verdict });
  }

  // ==== 6. 行业相对表现 (个股近 20 日 vs 同行业中位数) ====
  if (peers && !peers.error && peers.stock_ret_pct != null && peers.industry_ret_pct != null) {
    const stockR = peers.stock_ret_pct;
    const indR = peers.industry_ret_pct;
    const diff = stockR - indR;
    const rankPct = peers.rank_percentile;  // 0=涨最多, 100=垫底
    const clsR = (v) => v > 0 ? 'qi-pricey' : v < 0 ? 'qi-cheap' : 'qi-mid';
    const sign = (v) => v > 0 ? '+' : '';
    let verdict;
    if (diff > 5) verdict = '<b class="qi-pricey">显著跑赢行业 (+' + diff.toFixed(1) + '%)</b>';
    else if (diff > 1) verdict = '<b class="qi-lowish">小幅跑赢 (+' + diff.toFixed(1) + '%)</b>';
    else if (diff > -1) verdict = '<span class="qi-mid">与行业同步 (' + (diff >= 0 ? '+' : '') + diff.toFixed(1) + '%)</span>';
    else if (diff > -5) verdict = '<b class="qi-cheap">小幅跑输 (' + diff.toFixed(1) + '%)</b>';
    else verdict = '<b class="qi-expensive">显著跑输行业 (' + diff.toFixed(1) + '%)</b>';
    const rankText = rankPct != null
      ? ` · 排名 ${peers.rank_in_industry}/${peers.peer_count} (前 ${(100 - rankPct).toFixed(0)}%)`
      : '';
    rows.push({
      label: '行业对比',
      value: `个股 <b class="${clsR(stockR)}">${sign(stockR)}${stockR.toFixed(1)}%</b>`
        + ` vs ${peers.industry || '行业'}中位数 <b class="${clsR(indR)}">${sign(indR)}${indR.toFixed(1)}%</b>`
        + rankText,
      verdict,
    });
  }

  if (rows.length === 0) {
    return '<div class="qi-hint">数据加载中, 请稍候…</div>';
  }
  let html = '<div class="quick-insights-card">'
    + '<div class="qi-title">📊 数据结论 <span class="qi-subtitle">(本地即时算, LLM 综合判断稍后追加)</span></div>'
    + '<table class="qi-table"><tbody>';
  for (const r of rows) {
    html += `<tr>
      <td class="qi-label">${r.label}</td>
      <td class="qi-value">${r.value}</td>
      <td class="qi-verdict">${r.verdict}</td>
    </tr>`;
  }
  html += '</tbody></table></div>';
  return html;
}

function fmtNum(v, digits) {
  if (v === null || v === undefined) return '-';
  const n = parseFloat(v);
  if (isNaN(n)) return '-';
  const d = digits === undefined ? 2 : digits;
  if (Math.abs(n) >= 100) return n.toLocaleString('en', { maximumFractionDigits: d, minimumFractionDigits: 0 });
  return n.toFixed(d);
}
function fmtPct(v) {
  if (v === null || v === undefined) return '-';
  const n = parseFloat(v);
  if (isNaN(n)) return '-';
  return (n >= 0 ? '+' : '') + n.toFixed(2) + '%';
}
function fmtYi(v) {
  if (v === null || v === undefined) return '-';
  const n = parseFloat(v);
  if (isNaN(n)) return '-';
  if (Math.abs(n) >= 1e8) return (n / 1e8).toFixed(2) + '亿';
  if (Math.abs(n) >= 1e4) return (n / 1e4).toFixed(2) + '万';
  return n.toFixed(2);
}
function fmtWan(v) {
  if (v === null || v === undefined) return '-';
  const n = parseFloat(v);
  if (isNaN(n)) return '-';
  if (Math.abs(n) >= 1e4) return (n / 1e4).toFixed(2) + '万';
  return n.toFixed(0);
}
function classifyDir(v) {
  if (v === null || v === undefined) return 'flat';
  const n = parseFloat(v);
  if (isNaN(n) || Math.abs(n) < 1e-9) return 'flat';
  return n > 0 ? 'up' : 'down';
}
function classifyByRef(v, ref) {
  if (v === null || v === undefined || ref === null || ref === undefined) return '';
  const a = parseFloat(v), b = parseFloat(ref);
  if (isNaN(a) || isNaN(b) || Math.abs(a - b) < 1e-9) return '';
  return a > b ? 'up' : 'down';
}

// ---------------------------------------------------------------
// AI 综合分析面板 (常驻可折叠, K 线下方) 交互
// ---------------------------------------------------------------
let AI_SESSION_ID = null;
let AI_LOADING = false;

document.getElementById('ai-toggle').addEventListener('click', () => {
  const card = document.getElementById('ai-card');
  if (card.classList.contains('is-expanded')) {
    collapsePanel();
  } else {
    expandPanel();
    if (!AI_SESSION_ID) startAnalyze();
  }
});

// 追问 textarea Enter 发送 / Shift+Enter 换行
const askInput = document.getElementById('ai-textarea');
askInput.addEventListener('keydown', (e) => {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendFollowup();
  }
});
document.getElementById('ai-send').addEventListener('click', sendFollowup);

// textarea 自动增高
askInput.addEventListener('input', () => {
  askInput.style.height = 'auto';
  askInput.style.height = Math.min(askInput.scrollHeight, 120) + 'px';
});

function expandPanel() {
  const card = document.getElementById('ai-card');
  card.classList.add('is-expanded');
  document.getElementById('ai-toggle').setAttribute('aria-expanded', 'true');
  document.getElementById('ai-body').hidden = false;
}

function collapsePanel() {
  const card = document.getElementById('ai-card');
  card.classList.remove('is-expanded');
  document.getElementById('ai-toggle').setAttribute('aria-expanded', 'false');
  document.getElementById('ai-body').hidden = true;
}

async function startAnalyze() {
  if (AI_LOADING) return;
  AI_LOADING = true;
  const toggleBtn = document.getElementById('ai-toggle');
  toggleBtn.disabled = true;
  const hintEl = document.getElementById('ai-head-hint');
  const body = document.getElementById('ai-content');
  const period = currentMode.mode === 'kline' ? currentMode.period : 'D';

  // 1) AI 面板 loading. 数据结论卡已在 K 线下方常驻, AI 面板专注 LLM 综合判断.
  const loadingCard =
    '<div class="stock-ai-loading" id="ai-loading-placeholder">'
    + '<span class="lo-spinner"></span>'
    + '<span>AI 综合判断生成中, 大约需要 20-60 秒… (上方"数据结论"已给出本地即时结论)</span>'
    + '</div>';
  body.innerHTML = loadingCard;

  const startTs = Date.now();
  const tickerEl = body.querySelector('#ai-loading-placeholder span:last-child');
  const ticker = setInterval(() => {
    const s = Math.floor((Date.now() - startTs) / 1000);
    if (tickerEl) tickerEl.textContent = 'AI 综合判断生成中, 已用时 ' + s + ' 秒…';
  }, 1000);

  try {
    const r = await fetch('/api/stock/analyze/' + STOCK_SYMBOL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ period_context: period }),
    });
    clearInterval(ticker);
    if (!r.ok) {
      let err = null;
      try { err = await r.json(); } catch (_) {}
      const msg = err && err.detail
        ? (typeof err.detail === 'object' ? JSON.stringify(err.detail) : err.detail)
        : ('HTTP ' + r.status);
      renderAnalyzeError(msg);
      return;
    }
    const d = await r.json();
    AI_SESSION_ID = d.session_id;
    renderAnalyzeResult(d);
    document.getElementById('ai-input').style.display = '';
    hintEl.textContent = '已生成, 可下方追问';
  } catch (e) {
    clearInterval(ticker);
    renderAnalyzeError(e.message || String(e));
  } finally {
    AI_LOADING = false;
    toggleBtn.disabled = false;
  }
}

function renderAnalyzeResult(d) {
  // 不覆盖 quickCard, 只替换 loading placeholder 为 LLM 结果
  const body = document.getElementById('ai-content');
  const placeholder = document.getElementById('ai-loading-placeholder');
  const asstTurn = document.createElement('div');
  asstTurn.className = 'ai-turn ai-turn-assistant';
  asstTurn.innerHTML = renderMarkdown(d.content || '');
  if (placeholder) {
    placeholder.replaceWith(asstTurn);
  } else {
    body.appendChild(asstTurn);
  }
  body.scrollTop = body.scrollHeight;
}

function renderAnalyzeError(msg) {
  const body = document.getElementById('ai-content');
  body.innerHTML =
    '<div class="stock-degraded-tip">🤖 AI 分析失败：' + escapeHtml(msg) + '<br>'
    + '<span class="small" style="color:var(--fg-dim)">请稍后重试；若持续失败，检查本地 LLM 代理（默认 127.0.0.1:18931）是否可达。</span>'
    + '</div>'
    + '<button class="primary" style="margin-top:12px" onclick="AI_SESSION_ID=null;startAnalyze()">重试</button>';
  document.getElementById('ai-head-hint').textContent = '生成失败，点击面板内的重试';
}

async function sendFollowup() {
  if (AI_LOADING || !AI_SESSION_ID) return;
  const textarea = document.getElementById('ai-textarea');
  const content = textarea.value.trim();
  if (!content) return;

  AI_LOADING = true;
  document.getElementById('ai-send').disabled = true;

  // 追加用户气泡
  const body = document.getElementById('ai-content');
  const userTurn = document.createElement('div');
  userTurn.className = 'ai-turn ai-turn-user';
  userTurn.textContent = content;
  body.appendChild(userTurn);

  const asstTurn = document.createElement('div');
  asstTurn.className = 'ai-turn ai-turn-assistant';
  asstTurn.innerHTML = '<span class="lo-spinner"></span> AI 思考中…';
  body.appendChild(asstTurn);
  body.scrollTop = body.scrollHeight;

  textarea.value = '';
  textarea.style.height = 'auto';

  try {
    // 复用 /api/chat 的 SSE endpoint
    const r = await fetch('/api/chat/sessions/' + AI_SESSION_ID + '/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ content }),
    });
    if (!r.ok || !r.body) {
      asstTurn.innerHTML = '<span style="color:var(--err)">追问失败：HTTP ' + r.status + '</span>';
      return;
    }
    await consumeSSE(r.body, {
      onAssistant: (txt) => { asstTurn.innerHTML = renderMarkdown(txt); body.scrollTop = body.scrollHeight; },
      onError: (payload) => {
        asstTurn.innerHTML = '<span style="color:var(--err)">追问失败：' + escapeHtml(payload.message || JSON.stringify(payload)) + '</span>';
      },
      onToolUse: (payload) => {
        // 在 assistant 气泡上方插一行 🔧 工具调用记录
        const tool = document.createElement('div');
        tool.className = 'small';
        tool.style.color = 'var(--fg-dim)';
        tool.style.margin = '4px 0';
        tool.textContent = '🔧 ' + (payload.name || '工具调用');
        body.insertBefore(tool, asstTurn);
      },
    });
  } catch (e) {
    asstTurn.innerHTML = '<span style="color:var(--err)">网络异常：' + escapeHtml(e.message || String(e)) + '</span>';
  } finally {
    AI_LOADING = false;
    document.getElementById('ai-send').disabled = false;
  }
}

// 最简 SSE 消费：按 event/data 行切分
async function consumeSSE(readableStream, handlers) {
  const reader = readableStream.getReader();
  const decoder = new TextDecoder();
  let buf = '';
  while (true) {
    const { value, done } = await reader.read();
    if (done) break;
    buf += decoder.decode(value, { stream: true });
    let idx;
    while ((idx = buf.indexOf('\n\n')) !== -1) {
      const chunk = buf.slice(0, idx);
      buf = buf.slice(idx + 2);
      const eventLine = chunk.split('\n').find(l => l.startsWith('event: '));
      const dataLine = chunk.split('\n').find(l => l.startsWith('data: '));
      if (!eventLine || !dataLine) continue;
      const eventName = eventLine.slice(7).trim();
      const rawData = dataLine.slice(6);
      let payload = {};
      try { payload = JSON.parse(rawData); } catch (_) {}
      if (eventName === 'assistant' && handlers.onAssistant) handlers.onAssistant(payload.content || '');
      else if (eventName === 'tool_use' && handlers.onToolUse) handlers.onToolUse(payload);
      else if (eventName === 'error' && handlers.onError) handlers.onError(payload);
    }
  }
}

// 最简 markdown（复用 chat.html.j2 里的实现思路，简化版）
function renderMarkdown(text) {
  let s = String(text || '');
  // 代码块
  const blocks = [];
  s = s.replace(/```([\s\S]*?)```/g, (_m, code) => {
    blocks.push('<pre class="md-code">' + escapeHtml(code.trim()) + '</pre>');
    return `\x00BLOCK${blocks.length - 1}\x00`;
  });
  // 转义
  s = escapeHtml(s);
  // 标题 ## / ###
  s = s.replace(/^###\s+(.+)$/gm, '<h3>$1</h3>');
  s = s.replace(/^##\s+(.+)$/gm, '<h2>$1</h2>');
  // 粗体
  s = s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
  // 行内代码
  s = s.replace(/`([^`]+)`/g, '<code>$1</code>');
  // 列表
  s = s.replace(/^-\s+(.+)$/gm, '<li>$1</li>');
  s = s.replace(/(<li>.*<\/li>)(\n<li>.*<\/li>)+/gs, m => '<ul>' + m + '</ul>');
  // 分割线
  s = s.replace(/^---$/gm, '<hr>');
  // 换行
  s = s.replace(/\n{2,}/g, '</p><p>');
  s = s.replace(/\n/g, '<br>');
  s = '<p>' + s + '</p>';
  // 还原代码块
  s = s.replace(/\x00BLOCK(\d+)\x00/g, (_m, i) => blocks[parseInt(i, 10)] || '');
  return s;
}
