{% extends "base.html.j2" %}
{% block title %}Ops{% endblock %}

{% block content %}
<h1>运维仪表盘 <span class="small" style="font-weight:400">Ops</span></h1>
<p class="page-intro">
  这个页面用来 <b>查看系统运行状态、启停后台守护进程、手动触发任务</b>。
  正常使用流程：
  <b>1)</b> 先确认上方"后台守护进程"是 <span class="metric-good">运行中</span>，没运行就在终端执行 <code>./start.sh up</code>；
  <b>2)</b> 想立刻产出今天的组合 / 因子结果，就点【立即跑一次完整流程】；
  <b>3)</b> 下方卡片实时展示 <b>数据健康度</b>、<b>最近任务</b>、<b>事件流</b>。
</p>

<!-- P0: 一句话系统状态结论条（复用 /api/ops/health，与健康卡片同源） -->
<div id="ops-summary" class="ops-summary is-loading">
  <span id="os-icon" class="os-icon">⏳</span>
  <span id="os-text" class="os-text">正在读取系统状态…</span>
  <span id="os-actions" class="os-actions"></span>
</div>

<!-- 控制面板 -->
<div class="card control-card">
  <div class="control-head">
    <h2 style="margin:0;">控制台 <span class="small">手动操作</span></h2>
    <span class="daemon-badge" title="I1 重构后 daemon 由 ./start.sh up / stop 管理，不在 Web 启停。运行状态见下方健康卡片。">
      <span class="daemon-badge-dot"></span>后台由 CLI 管理
    </span>
  </div>

  <div class="ctl-group">
    <div class="ctl-group-label">日常运行</div>
    <div class="ctl-actions">
      <button class="btn-primary"
              title="立即跑一次「盘后批处理」全流程：拉数据 → 跑因子 → 生成今日组合（约 30~120 秒）"
              onclick="doAction(this,'/api/control/jobs/batch.post_close/trigger','POST')">
        <span class="btn-icon">▶</span>立即跑一次完整流程
      </button>
      <button class="btn-ghost"
              title="一次性拉取今日全 A 股快照（~15 秒，批量接口）→ 把数据补到缓存"
              onclick="refreshDataAsync(this)">
        <span class="btn-icon">↓</span>拉取今日数据 <span class="btn-hint">~15s</span>
      </button>
      <button class="btn-ghost"
              title="让 AI 即兴生成 20 个新因子配方，做回测，自动留下表现最好的（约 30~120 秒）"
              onclick="doAction(this,'/api/control/jobs/factor.discovery/trigger?n_candidates=20','POST')">
        <span class="btn-icon">✦</span>跑一轮因子发现 <span class="btn-hint">20 候选</span>
      </button>
    </div>
  </div>

  <div class="ctl-group">
    <div class="ctl-group-label">数据修复</div>
    <div class="ctl-actions">
      <button class="btn-ghost"
              title="只算 db 里缺失的日期 (通常只有今天 1 行), 几分钟跑完。日常 cron 也用这个模式"
              onclick="doAction(this,'/api/control/jobs/batch.deep_research/trigger','POST')">
        <span class="btn-icon">⟳</span>重算因子表现 <span class="btn-hint">fast · 增量</span>
      </button>
      <button class="btn-warn-outline"
              title="重算所有 90 天历史 IC 覆盖 db, ~10-15 分钟。数据修复 / 怀疑历史错算时用"
              onclick="confirmAndDeepResearchFull(this)">
        <span class="btn-icon">⚠</span>重算因子表现 <span class="btn-hint">full · 全量 · 10-15min</span>
      </button>
    </div>
  </div>

  <div class="ctl-group ctl-group-danger">
    <div class="ctl-group-label ctl-group-label-danger">危险区</div>
    <div class="ctl-actions">
      <button class="btn-danger-outline"
              title="按 factor_score 量化打分淘汰低效因子, 防止池子无限膨胀。会先 dry-run 显示名单再确认"
              onclick="evictFactors(this)">
        <span class="btn-icon">✕</span>淘汰低效因子
      </button>
    </div>
  </div>

  <div id="control-console" class="control-console is-idle" aria-live="polite">
    <div class="cc-empty">// 等待操作…</div>
  </div>
</div>

<style>
