}

/* ===== 结构化控制台输出 ======================================== */
.control-console {
  margin-top: 16px;
  border: 1px solid var(--line);
  border-left: 3px solid var(--line-strong);
  background: var(--bg-0);
  border-radius: var(--r-sm);
  padding: 12px 14px;
  font-size: 12px;
  line-height: 1.6;
  min-height: 44px;
  transition: border-left-color 200ms var(--ease-out);
}
.control-console.is-idle  { border-left-color: var(--line-strong); }
.control-console.is-busy  { border-left-color: var(--info); }
.control-console.is-ok    { border-left-color: var(--ok); }
.control-console.is-warn  { border-left-color: var(--warn); }
.control-console.is-err   { border-left-color: var(--err); }
.cc-empty { color: var(--fg-dim); font-style: italic; font-family: var(--font-mono); font-size: 11px; }
.cc-head {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 6px;
}
.cc-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 2px 10px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.02em;
  border: 1px solid transparent;
}
.cc-pill.is-busy { background: var(--info-soft); color: var(--info); border-color: rgba(96,165,250,0.35); }
.cc-pill.is-ok   { background: var(--ok-soft);   color: var(--ok);   border-color: rgba(52,211,153,0.35); }
.cc-pill.is-warn { background: var(--warn-soft); color: var(--warn); border-color: rgba(251,191,36,0.35); }
.cc-pill.is-err  { background: var(--err-soft);  color: var(--err);  border-color: rgba(248,113,113,0.35); }
.cc-pill.is-busy::before {
  content: ""; width: 6px; height: 6px; border-radius: 50%;
  background: currentColor;
  animation: pulse 1.2s ease-in-out infinite;
}
.cc-title { color: var(--fg); font-weight: 500; }
.cc-code {
