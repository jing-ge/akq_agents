.cc-details > summary:hover { color: var(--accent); }
.cc-details[open] > summary { color: var(--fg-mute); }
.cc-details pre {
  margin: 6px 0 0;
  padding: 10px 12px;
  background: var(--bg-1);
  border: 1px solid var(--line);
  border-radius: var(--r-sm);
  font-family: var(--font-mono);
  font-size: 10.5px;
  color: var(--fg-mute);
  max-height: 260px;
  overflow: auto;
  white-space: pre-wrap;
  word-break: break-all;
