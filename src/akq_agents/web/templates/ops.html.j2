function tCn(map, key, fallback) { return map[key] != null ? map[key] : (fallback != null ? fallback : key); }

// 异步拉取今日数据：触发后台线程，前端轮询状态
async function refreshDataAsync(btn) {
  const title = 'data.refresh';
  renderConsole({ kind: 'busy', title: '启动后台数据拉取' });
  if (btn) { btn.classList.add('is-loading'); btn.disabled = true; }
  const restoreBtn = () => {
    if (btn) { btn.classList.remove('is-loading'); btn.disabled = false; }
  };
  try {
    const r = await fetch('/api/control/data/refresh', { method: 'POST' });
    const startData = await r.json();
    if (!r.ok) {
      renderConsole({
        kind: 'failed', title,
        httpStatus: r.status,
        message: formatErrorDetail(startData || {}),
        raw: startData,
      });
      restoreBtn();
      return;
    }
    renderConsole({
      kind: 'busy',
      title: '后台拉取中',
      summaryHtml:
        `<span class="kv-k">目标日期:</span> <span class="kv-v">${escapeHtml(startData.target_date || '—')}</span>  ｜  ` +
        `<span class="kv-k">开始时间:</span> <span class="kv-v">${escapeHtml(startData.started_at || '—')}</span>\n` +
        `<span class="kv-k">已耗时:</span> <span class="kv-v">0</span> 秒（通常 10-30 秒完成）`,
    });

    const startTs = Date.now();
    const poll = async () => {
      try {
        const sr = await fetch('/api/control/data/refresh/status');
        const sd = await sr.json();
        const elapsed = Math.floor((Date.now() - startTs) / 1000);
        if (sd.running) {
          renderConsole({
            kind: 'busy',
            title: '后台拉取中',
            summaryHtml:
              `<span class="kv-k">目标日期:</span> <span class="kv-v">${escapeHtml(sd.target_date || '—')}</span>  ｜  ` +
              `<span class="kv-k">开始时间:</span> <span class="kv-v">${escapeHtml(sd.started_at || '—')}</span>\n` +
              `<span class="kv-k">已耗时:</span> <span class="kv-v">${elapsed}</span> 秒（通常 10-30 秒完成）`,
          });
          setTimeout(poll, 2000);
        } else {
          if (sd.error) {
            renderConsole({
              kind: 'failed', title,
              message: sd.error,
              summaryHtml: `<span class="kv-k">目标:</span> <span class="kv-v">${escapeHtml(sd.target_date || '—')}</span>`,
              raw: sd,
            });
          } else {
            const res = sd.result || {};
            renderConsole({
              kind: 'ok', title,
              payload: res,
              jobId: 'data.refresh',
              raw: sd,
            });
          }
          restoreBtn();
        }
      } catch (e) {
        renderConsole({
          kind: 'net_err', title,
          message: '轮询失败: ' + ((e && e.message) || e),
        });
        restoreBtn();
      }
    };
    setTimeout(poll, 2000);
  } catch (err) {
    renderConsole({
      kind: 'net_err', title,
      message: (err && err.message) || String(err),
    });
    restoreBtn();
  }
}

// 把 /api/ops/health 的 JSON 渲染成卡片
htmx.on('#health-cards', 'htmx:afterRequest', e => {
  if (!e.detail.xhr || e.detail.xhr.status !== 200) return;
  try {
    const data = JSON.parse(e.detail.xhr.responseText);
    e.target.innerHTML = renderHealth(data);
    try { renderOpsSummary(data); } catch (_) {}
  } catch (err) {
    e.target.innerHTML = '<p>解析失败</p>';
  }
});
// P0: 一句话系统状态结论条 — 复用 /api/ops/health 数据，零额外请求。
// 优先级：daemon 停 > 数据异常/批处理失败 > 待刷新/24h 有错误 > 全绿。
function renderOpsSummary(d) {
  const bar = document.getElementById('ops-summary');
  if (!bar) return;
  const dh = d.data_health || {};
  const dm = d.daemon || {};
  const tb = d.today_batch;
  const evt = d.scheduler_events_24h_by_level || {};
  const healthRaw = (dh.health || 'UNKNOWN').toUpperCase();
  const errCount = Number(evt.error || 0);
  const tbStatus = tb ? String(tb.status || '').toLowerCase() : '';
  const tbFailed = ['error', 'failed', 'crashed', 'interrupted', 'timeout'].includes(tbStatus);

  const setBar = (level, icon, text, actions) => {
    bar.className = 'ops-summary ' + level;
    document.getElementById('os-icon').textContent = icon;
    document.getElementById('os-text').innerHTML = text;
    const actEl = document.getElementById('os-actions');
    actEl.innerHTML = (actions || []).map(a =>
      `<button class="os-btn" onclick="${a.onclick}">${escapeHtml(a.label)}</button>`
    ).join('');
  };
  const jumpHealth = "document.querySelector('#health-cards').scrollIntoView({behavior:'smooth',block:'center'})";
  const jumpJobs = "document.querySelector('#jobs-table').scrollIntoView({behavior:'smooth',block:'center'})";

  // 1) daemon 未运行 —— 系统停摆，最优先
  if (dm.is_alive === false) {
    setBar('os-danger', '🔴',
      '<b>后台守护进程未运行</b>，定时任务已停摆。请在终端执行 <code>./start.sh up</code> 启动，或点右侧手动跑一次。',
      [{ label: '看健康详情', onclick: jumpHealth }]);
    return;
  }
  // 2) 数据异常 / 今日批处理失败
  if (healthRaw === 'FAILED' || healthRaw === 'DEGRADED' || tbFailed) {
    const reason = tbFailed ? '今日盘后批处理执行失败' : ('数据健康度为「' + tCn(HEALTH_CN, healthRaw, healthRaw) + '」');
    setBar('os-danger', '🔴',
      `<b>需要处理：</b>${reason}${errCount ? `，近 24h 有 <b>${errCount}</b> 个错误事件` : ''}。建议查看最近任务定位原因。`,
      [{ label: '看最近任务', onclick: jumpJobs }, { label: '看健康详情', onclick: jumpHealth }]);
    return;
  }
  // 3) 数据待刷新 / 有错误事件
  if (healthRaw === 'PENDING_TODAY' || errCount > 0) {
    const parts = [];
    if (healthRaw === 'PENDING_TODAY') parts.push('今日数据尚未刷新完成');
    if (errCount > 0) parts.push(`近 24h 有 <b>${errCount}</b> 个错误事件`);
    setBar('os-warn', '🟡',
      `<b>需留意：</b>${parts.join('，')}。多为正常等待，若长时间不消可手动跑一次完整流程。`,
      [{ label: '看健康详情', onclick: jumpHealth }]);
    return;
  }
  // 4) 全绿
  const tbTxt = tb ? '今日盘后批处理已完成' : '今日盘后批处理尚未运行（收盘后自动触发）';
  setBar('os-ok', '🟢',
    `<b>系统正常：</b>后台运行中，数据健康度正常，${tbTxt}，近 24h 无错误事件。`,
    []);
}

function renderHealth(d) {
  const dh = d.data_health || {};
  const dm = d.daemon || {};
  const tb = d.today_batch;
  const evt = d.scheduler_events_24h_by_level || {};

  // 数据健康度 → 中文 + 颜色
  const healthRaw = (dh.health || 'UNKNOWN').toUpperCase();
  const healthCn  = tCn(HEALTH_CN, healthRaw, healthRaw);
  const healthCls = healthRaw === 'OK' ? 'metric-good'
                  : healthRaw === 'WARNING' ? 'metric-warn'
                  : healthRaw === 'PENDING_TODAY' ? 'metric-warn'
                  : healthRaw === 'DEGRADED' ? 'metric-warn'
                  : healthRaw === 'FAILED' ? 'metric-bad' : 'metric-dim';

  // 覆盖率 → 颜色判定
  const cov = dh.ohlcv_coverage_today;
  const covPct = (cov != null) ? (cov * 100).toFixed(1) + '%' : '—';
  const covCls = cov == null ? 'metric-dim'
               : cov >= 0.95 ? 'metric-good'
               : cov >= 0.5  ? 'metric-warn' : 'metric-bad';

  // 今日盘后状态
  const tbStatus = tb ? (tb.status || '') : '';
  const tbCn = tb ? tCn(STATUS_CN, tbStatus, tbStatus) : '未运行';
  const tbDur = (tb && tb.duration_ms != null) ? '耗时 ' + (tb.duration_ms / 1000).toFixed(1) + ' 秒' : '';

  return `
    <div class="health-kpi-row">
      <div class="hk">
        <div class="hk-lbl">后台守护进程</div>
        <div class="hk-val">${dm.is_alive
          ? '<span class="pill alive">运行中</span>'
          : '<span class="pill dead">未运行</span>'}</div>
        <div class="hk-sub">${dm.state ? '上次心跳：<code>' + (dm.state.last_heartbeat || '—') + '</code>' : '后台没在跑，请在终端执行 <code>./start.sh up</code>'}</div>
      </div>
      <div class="hk">
        <div class="hk-lbl">数据健康度</div>
        <div class="hk-val"><span class="${healthCls}">${healthCn}</span> <span class="small" style="font-size:11px;">(${healthRaw})</span></div>
        <div class="hk-sub">
          股票池：<b>${dh.universe_size_today ?? '—'}</b> 只 ｜
          今日数据覆盖率：<span class="${covCls}">${covPct}</span>
          ${healthRaw === 'PENDING_TODAY' && dh.next_refresh_attempt
            ? '<br><span class="metric-hint">今天数据计划于 ' + dh.next_refresh_attempt.replace('T',' ') + ' 自动拉取</span>'
            : '<span class="metric-hint">覆盖率指今天有日线行情的股票占股票池的比例，越接近 100% 越健康</span>'}
        </div>
      </div>
      <div class="hk">
        <div class="hk-lbl">今日盘后批处理</div>
        <div class="hk-val">${tb
          ? '<span class="status-' + tbStatus + '">' + tbCn + '</span>'
          : '<span class="metric-dim">未运行</span>'}</div>
        <div class="hk-sub">${tbDur || '今天还没有跑过完整流程'}</div>
      </div>
      <div class="hk">
        <div class="hk-lbl">最近 24 小时事件</div>
        <div class="hk-val">${(evt.info || 0) + (evt.warning || 0) + (evt.error || 0)} <span class="small" style="font-size:11px;">条</span></div>
        <div class="hk-sub">
          信息 <b>${evt.info || 0}</b> ｜
          警告 <span class="metric-warn">${evt.warning || 0}</span> ｜
          错误 <span class="metric-bad">${evt.error || 0}</span>
        </div>
      </div>
    </div>
  `;
}

htmx.on('#jobs-table', 'htmx:afterRequest', e => {
  if (!e.detail.xhr || e.detail.xhr.status !== 200) return;
  try {
    const d = JSON.parse(e.detail.xhr.responseText);
    e.target.innerHTML = renderJobs(d.runs);
    if (typeof makeSortable === 'function') {
      e.target.querySelectorAll('table').forEach(t => makeSortable(t));
    }
  } catch { e.target.innerHTML = '<p>解析失败</p>'; }
});
function renderJobs(runs) {
  if (!runs || !runs.length) return '<div class="empty-state"><span class="em">▢</span><div class="em-title">暂无任务运行记录</div><div class="em-hint">后台 daemon 启动后会定时跑「盘后批处理」「因子发现」等任务，跑完会出现在这里。也可以点上方按钮立即触发一次。</div></div>';
  return `<table class="jobs-table">
    <colgroup>
      <col class="col-job"/>
      <col class="col-part"/>
      <col class="col-status"/>
      <col class="col-dur"/>
      <col class="col-time"/>
      <col class="col-act"/>
    </colgroup>
    <thead><tr>
      <th><abbr title="任务标识，例如 batch.post_close = 盘后批处理">任务 / Job</abbr></th>
      <th><abbr title="任务的分区，通常是日期（YYYY-MM-DD）">分区</abbr></th>
      <th>状态</th>
      <th>耗时</th>
      <th>开始</th>
      <th></th>
    </tr></thead><tbody>
    ${runs.map(r => {
      const cn = tCn(STATUS_CN, r.status, r.status);
      const jobCn = tCn(JOB_CN, r.job_id, '');
      // attr-safe key for partitions containing ':' etc.
      const jobAttr = encodeURIComponent(r.job_id);
      const partAttr = encodeURIComponent(r.partition);
      // started_at 是 ISO 时间戳（如 2026-06-18T16:38:09.046701），只显示 HH:MM:SS
      // 分区列已经携带日期信息，这里无需重复
      const startedShort = r.started_at ? (r.started_at.slice(11, 19) || r.started_at) : '—';
      return `<tr>
      <td class="jc-job"><code>${r.job_id}</code>${jobCn ? ' <span class="small">'+ jobCn +'</span>' : ''}</td>
      <td class="jc-part">${r.partition}</td>
      <td class="jc-status"><span class="status-${r.status}">${cn}</span>${r.reason_code ? ' <code title="' + r.reason_code + '">' + tCn(REASON_CODE_CN, r.reason_code, r.reason_code) + '</code>' : ''}</td>
      <td class="jc-dur">${r.duration_ms != null ? (r.duration_ms / 1000).toFixed(1) + ' 秒' : '—'}</td>
      <td class="jc-time small" title="${r.started_at || ''}">${startedShort}</td>
      <td class="jc-act"><button class="job-detail-btn" data-job="${jobAttr}" data-part="${partAttr}" onclick="expandJob(this)" title="展开/收起该任务的子步骤详情">📋 详情</button></td>
    </tr>`;
    }).join('')}
  </tbody></table>`;
}

// ====== M11: Job 详情展开 ======
// 缓存：'jobId|partition' -> detailJson（避免每次都打 API）
const _jobDetailCache = new Map();

async function expandJob(btn) {
  const jobId = decodeURIComponent(btn.dataset.job);
  const partition = decodeURIComponent(btn.dataset.part);
  const row = btn.closest('tr');
  const next = row.nextElementSibling;
  // 已展开 → 收起
  if (next && next.classList.contains('job-detail-row')) {
    next.remove();
    btn.classList.remove('is-open');
    btn.textContent = '📋 详情';
    return;
  }
  btn.classList.add('is-open');
  btn.textContent = '▾ 收起';
  // 插入一个空行先显示 loading
  const detailRow = document.createElement('tr');
  detailRow.className = 'job-detail-row';
  const colCount = row.children.length;
  detailRow.innerHTML = `<td colspan="${colCount}"><div class="jd-loading">⏳ 加载子步骤…</div></td>`;
  row.parentNode.insertBefore(detailRow, row.nextSibling);

  const cacheKey = jobId + '|' + partition;
  try {
    let d = _jobDetailCache.get(cacheKey);
    if (!d) {
      const url = `/api/ops/job-runs/${encodeURIComponent(jobId)}/${encodeURIComponent(partition)}/detail`;
      const r = await fetch(url);
      if (!r.ok) throw new Error('HTTP ' + r.status);
      d = await r.json();
      if (d.error) throw new Error(d.error);
      _jobDetailCache.set(cacheKey, d);
    }
    detailRow.firstElementChild.innerHTML = renderJobDetail(d);
  } catch (e) {
    detailRow.firstElementChild.innerHTML = `<div class="jd-empty">加载失败：${e.message || e}</div>`;
  }
}

function renderJobDetail(d) {
  const statusCn = tCn(STATUS_CN, d.status, d.status);
  const dur = d.duration_ms != null ? (d.duration_ms / 1000).toFixed(2) + ' 秒' : '—';
  const payloadBlock = d.payload
    ? `<div class="jd-payload-summary">payload：${escapeHtml(JSON.stringify(d.payload, null, 2))}</div>`
    : '';
  const stepsHtml = (d.steps && d.steps.length)
    ? `<div class="jd-steps">${d.steps.map(renderStep).join('')}</div>`
    : `<div class="jd-empty">该任务没有记录子步骤（job_steps 为空）。可能是旧版本任务，或任务未使用 StepRecorder。</div>`;
  return `
    <div class="jd-head">
      <span class="jd-title">${escapeHtml(d.job_id)} <span class="small">@ ${escapeHtml(d.partition)}</span></span>
      <span class="small">状态：<span class="status-${d.status}">${statusCn}</span></span>
      <span class="small">耗时：${dur}</span>
      <span class="small">子步骤：${(d.steps || []).length} 个</span>
    </div>
    ${payloadBlock}
    ${stepsHtml}
  `;
}

function renderStep(s) {
  const statusCls = 'is-' + (s.status || 'unknown');
  const statusCn = tCn(STATUS_CN, s.status, s.status);
  const dur = s.duration_ms != null ? s.duration_ms + ' ms' : '—';
  const startedShort = (s.started_at || '').slice(11, 19) || '—';
  const hasPayload = s.payload && Object.keys(s.payload).length > 0;
  const payloadId = `jdp-${s.id}`;
  const payloadJson = hasPayload ? escapeHtml(JSON.stringify(s.payload, null, 2)) : '';
  const errorBlock = s.error
    ? `<div class="jd-payload" style="border-color:var(--err); color:var(--err);">错误：${escapeHtml(s.error)}</div>`
    : '';
  return `
    <div class="jd-step ${statusCls}">
      <span class="seq">#${s.seq}</span>
      <span class="name">${escapeHtml(s.name || '')}</span>
      <span class="status-${s.status}">${statusCn}</span>
      <span class="dur">${dur}</span>
      ${hasPayload
        ? `<button class="toggle" onclick="togglePayload('${payloadId}', this)">▸ 查看输出</button>`
        : `<span class="ts">${startedShort}</span>`}
      ${hasPayload ? `<pre id="${payloadId}" class="jd-payload hidden">${payloadJson}</pre>` : ''}
      ${errorBlock}
    </div>
  `;
}

function togglePayload(id, btn) {
  const el = document.getElementById(id);
  if (!el) return;
  const opening = el.classList.contains('hidden');
  el.classList.toggle('hidden');
  btn.textContent = opening ? '▾ 收起输出' : '▸ 查看输出';
}

// 全局快捷键 'r' → 强制刷新三块 htmx 卡片
window.addEventListener('hotkey:refresh', () => {
  if (typeof htmx === 'undefined') return;
  window.dispatchEvent(new CustomEvent('hotkey:refresh:ack'));
  // htmx.ajax 直接触发一次 GET + 替换 innerHTML（不依赖 hx-trigger 上的 event 名）
  document.querySelectorAll('[hx-get]').forEach(el => {
    const url = el.getAttribute('hx-get');
    if (url) htmx.ajax('GET', url, { target: el, swap: 'innerHTML' });
  });
  toast('已触发运维面板刷新', 'ok', { duration: 1500 });
});

htmx.on('#events-list', 'htmx:afterRequest', e => {
  if (!e.detail.xhr || e.detail.xhr.status !== 200) return;
  try {
    const d = JSON.parse(e.detail.xhr.responseText);
    e.target.innerHTML = renderEvents(d.events);
    if (typeof makeSortable === 'function') {
      e.target.querySelectorAll('table').forEach(t => makeSortable(t));
    }
  } catch { e.target.innerHTML = '<p>解析失败</p>'; }
});
function renderEvents(events) {
  if (!events || !events.length) return '<div class="empty-state"><span class="em">▢</span><div class="em-title">暂无事件</div><div class="em-hint">系统正常运行时会产生 info / warning / error 事件，会自动汇总在这里。</div></div>';
  return `<table><thead><tr>
      <th>时间</th>
      <th><abbr title="info=信息 / warning=警告 / error=错误">级别</abbr></th>
      <th><abbr title="事件类型，例如 job_started / job_finished">事件</abbr></th>
      <th>来源</th>
    </tr></thead><tbody>
    ${events.map(e => {
      const lvlCn = tCn(LEVEL_CN, e.level, e.level);
      return `<tr>
      <td class="small">${e.ts}</td>
      <td><span class="status-${e.level === 'info' ? 'ok' : e.level}">${lvlCn}</span></td>
      <td><code title="${e.kind}">${tCn(EVENT_KIND_CN, e.kind, e.kind)}</code></td>
      <td class="small">${e.source || '—'}</td>
    </tr>`;
    }).join('')}
  </tbody></table>`;
}
</script>
{% endblock %}
