</style>

<script>
// ===== 结构化控制台渲染 =========================================
// 状态感知：把 { status, reason_code, payload } 统一渲染成
//   [pill] title  <code>reason_code</code>
//   summary（每 job 类型的关键字段摘要）
//   <details> 完整 JSON 折叠
// 从而避免"外层 ✅ 执行完成 + 内层 status:failed"的矛盾输出。

const _CC_LABELS = {
  ok:      { cls: 'is-ok',   text: '成功' },
  success: { cls: 'is-ok',   text: '成功' },
  done:    { cls: 'is-ok',   text: '完成' },
  failed:  { cls: 'is-err',  text: '失败' },
  error:   { cls: 'is-err',  text: '失败' },
  crashed: { cls: 'is-err',  text: '崩溃' },
  timeout: { cls: 'is-warn', text: '超时' },
  skipped: { cls: 'is-warn', text: '跳过' },
  noop:    { cls: 'is-warn', text: '跳过' },
  review:  { cls: 'is-warn', text: '待确认' },
  busy:    { cls: 'is-busy', text: '执行中' },
  net_err: { cls: 'is-err',  text: '网络异常' },
};

function _ccEl() { return document.getElementById('control-console'); }

function _summarizePayload(jobId, payload) {
  // 针对各类 job 挑关键字段摘要展示；未知 job 显示前 6 个字段
  if (!payload || typeof payload !== 'object') return '';
  const kv = (k, v) => `<span class="kv-k">${escapeHtml(k)}:</span> <span class="kv-v">${escapeHtml(String(v))}</span>`;
  const pick = (keys) => keys.filter(k => payload[k] !== undefined && payload[k] !== null)
                             .map(k => kv(k, typeof payload[k] === 'object' ? JSON.stringify(payload[k]) : payload[k]));
  let items = [];
  if (jobId && jobId.includes('post_close')) {
    items = pick(['universe_size', 'factors_evaluated', 'portfolio_size', 'duration_s']);
  } else if (jobId && jobId.includes('deep_research')) {
    items = pick(['mode', 'factors', 'rows_written', 'duration_s']);
  } else if (jobId && jobId.includes('discovery')) {
    items = pick(['n_candidates', 'accepted', 'rejected', 'duration_s']);
  } else if (jobId && jobId.includes('eviction')) {
    items = pick(['dry_run', 'victims_n', 'pool_total_before', 'pool_total_after', 'min_score']);
  }
  if (!items.length) {
    // fallback：取前 6 个非 object 字段
    items = Object.keys(payload).slice(0, 6).map(k => {
      const v = payload[k];
      if (v && typeof v === 'object') return kv(k, JSON.stringify(v).slice(0, 80));
      return kv(k, v == null ? '—' : v);
    });
  }
  // 如果 payload 里有 error 字段（失败场景），单独截取
  if (payload.error) {
    const errStr = String(payload.error).slice(0, 300);
    return items.join('  ｜  ') + (items.length ? '\n' : '') + `<span class="kv-k">error:</span> <span class="kv-v" style="color:var(--err)">${escapeHtml(errStr)}</span>`;
  }
  return items.join('  ｜  ');
}

function renderConsole(state) {
  // state: { kind: 'busy'|'ok'|'failed'|'skipped'|'timeout'|'net_err',
  //          title, jobId?, reasonCode?, payload?, raw?, httpStatus? }
  const el = _ccEl();
  if (!el) return;
  const spec = _CC_LABELS[state.kind] || _CC_LABELS.ok;
  el.className = 'control-console ' + spec.cls;

  const codeBadge = state.reasonCode
    ? `<span class="cc-code" title="${escapeHtml(state.reasonCode)}">${escapeHtml(tCn(REASON_CODE_CN, state.reasonCode, state.reasonCode))}</span>` : '';
  const httpBadge = state.httpStatus
    ? `<span class="cc-code">HTTP ${state.httpStatus}</span>` : '';

  let summary = '';
  if (state.summaryHtml) {
    summary = `<div class="cc-summary">${state.summaryHtml}</div>`;
  } else if (state.payload) {
    const s = _summarizePayload(state.jobId, state.payload);
    if (s) summary = `<div class="cc-summary">${s}</div>`;
  } else if (state.message) {
    summary = `<div class="cc-summary">${escapeHtml(state.message)}</div>`;
  }

  const raw = state.raw !== undefined && state.raw !== null
    ? `<details class="cc-details"><summary>查看完整 JSON</summary><pre>${escapeHtml(
        typeof state.raw === 'string' ? state.raw : JSON.stringify(state.raw, null, 2)
      )}</pre></details>` : '';

  el.innerHTML = `
    <div class="cc-head">
      <span class="cc-pill ${spec.cls}">${spec.text}</span>
      <span class="cc-title">${escapeHtml(state.title || '')}</span>
      ${codeBadge}
      ${httpBadge}
    </div>
    ${summary}
    ${raw}
  `;
}

function ccIdle() {
  const el = _ccEl();
  if (!el) return;
  el.className = 'control-console is-idle';
  el.innerHTML = '<div class="cc-empty">// 等待操作…</div>';
}

// 从 job trigger URL 解析出 job_id（用于摘要选字段）
function _jobIdFromUrl(url) {
  const m = /\/jobs\/([^/]+)\/trigger/.exec(url || '');
  return m ? decodeURIComponent(m[1]) : '';
}

// ===== 异步 job 轮询辅助 =========================================
// M24 之后所有 /jobs/*/trigger 只入队立即返回 {status:"accepted", payload:{poll_url}},
// daemon 5s 内 pick 起来跑 30s~15min。直接把 accepted 当成功渲染 = "入队即当完成" bug。
// 这个 helper 从 trigger 首响应拿 poll_url, 轮询 job-runs detail 到 ok/failed/timeout,
// 返回最终 detail(含真实 status + payload)。轮询期间可选回调 onTick 更新控制台。
async function pollJobRunUntilDone(triggerData, { onTick, pollInterval = 3000, pollTimeout = 900000 } = {}) {
  const pollUrl = triggerData && triggerData.payload && triggerData.payload.poll_url;
  if (!pollUrl) return null; // 非异步端点(老同步返回), 调用方按 triggerData 自行处理
  const start = Date.now();
  while (true) {
    if (Date.now() - start > pollTimeout) return { status: 'timeout', _polled: true };
    await new Promise(res => setTimeout(res, pollInterval));
    let pd = null;
    try {
      const pr = await fetch(pollUrl);
      pd = await pr.json();
    } catch (e) { continue; } // 网络抖动, 下一轮重试
    const st = pd && pd.status ? String(pd.status).toLowerCase() : '';
    if (onTick) { try { onTick(pd, Math.floor((Date.now() - start) / 1000)); } catch (e) {} }
    // pending/running 继续等; ok/failed/skipped/timeout/error 视为终态
    if (['ok', 'failed', 'skipped', 'timeout', 'error', 'crashed', 'interrupted'].includes(st)) {
      pd._polled = true;
      return pd;
    }
  }
}

// ===== 通用 job 触发 =============================================
// 关键修复：HTTP 200 但 payload.status ∈ {failed, error, crashed} 时按失败渲染，
// 不再一律显示 "✅ 执行完成"。
async function doAction(btn, url, method) {
  // 兼容旧签名 doAction(url, method)
  if (typeof btn === 'string') { method = url; url = btn; btn = null; }

  const jobId = _jobIdFromUrl(url);
  const title = jobId || (method + ' ' + url);
  renderConsole({ kind: 'busy', title: '正在执行 ' + title });

  if (btn) {
    btn.disabled = true;
    btn.classList.add('is-loading');
    if (!btn.dataset.origLabel) btn.dataset.origLabel = btn.innerHTML;
  }

  try {
    const r = await fetch(url, { method });
    let data = null;
    try { data = await r.json(); } catch (e) { data = null; }

    if (!r.ok) {
      renderConsole({
        kind: 'failed', title,
        httpStatus: r.status,
        message: formatErrorDetail(data || {}),
        raw: data,
      });
      return;
    }

    // M24: 异步端点入队立即返回 status="accepted" + payload.poll_url。
    // 不能当完成! 必须轮询 job-runs detail 等 daemon 真跑完再渲染真实结果,
    // 否则会误报 "✅ 执行完成" 而任务其实还在排队/运行。
    const rawStatus = (data && data.status) ? String(data.status).toLowerCase() : 'ok';
    if (rawStatus === 'accepted' && data.payload && data.payload.poll_url) {
      renderConsole({ kind: 'busy', title: '已入队，daemon 执行中… ' + title });
      const finalD = await pollJobRunUntilDone(data, {
        onTick: (pd, sec) => {
          // 长任务(1-15 分钟)时用户对着 spinner 干等信息量为 0. 从 job_steps 里取
          // 已完成 + 正在跑的最后一步 name, 拼成 '拉数据 → 跑因子 → [ 生成组合… ]'
          // 这样即使还没跑完, 用户也知道当前进度和已花时间, 避免焦虑.
          const steps = (pd && pd.steps) || [];
          let stepBar = '';
          if (steps.length > 0) {
            const done = steps.filter(s => s.status === 'ok' || s.status === 'success' || s.finished_at).length;
            const inProg = steps.length > done ? steps[done] : null;
            const parts = [];
            for (let i = 0; i < done; i++) {
              parts.push(`<span class="step-done" title="已完成: ${escapeHtml(steps[i].name)}${steps[i].duration_ms ? ' ('+steps[i].duration_ms+'ms)' : ''}">✓ ${escapeHtml(steps[i].name)}</span>`);
            }
            if (inProg) {
              parts.push(`<span class="step-current" title="当前步骤: ${escapeHtml(inProg.name)}">▶ ${escapeHtml(inProg.name)}…</span>`);
            }
            if (parts.length > 0) {
              stepBar = `<div class="cc-steps"><span class="cc-steps-lbl">进度:</span> ${parts.join(' <span class="cc-steps-sep">→</span> ')}</div>`;
            }
          }
          renderConsole({
            kind: 'busy',
            title: `执行中 ${title}`,
            summaryHtml:
              `<span class="kv-k">状态:</span> <span class="kv-v">${escapeHtml(pd.status || 'running')}</span>  ｜  ` +
              `<span class="kv-k">已耗时:</span> <span class="kv-v">${sec}</span> 秒` +
              (steps.length > 0 ? `  ｜  <span class="kv-k">步骤:</span> <span class="kv-v">${steps.filter(s => s.finished_at).length} / ${steps.length}</span>` : '') +
              stepBar,
          });
        },
      });
      data = finalD || { status: 'timeout' };
    }

    // 业务层状态：区分 ok / skipped / failed
    const status = (data && data.status) ? String(data.status).toLowerCase() : 'ok';
    const reasonCode = data && data.reason_code || '';
    const NOOP_CODES = new Set(['ALREADY_OK', 'NOT_TRADING_DAY', 'GUARD_ERROR']);
    const isNoop = status === 'noop' || status === 'skipped' || NOOP_CODES.has(reasonCode);
    const isFailed = ['failed', 'error', 'crashed', 'interrupted'].includes(status);
    const isTimeout = status === 'timeout';

    let kind = 'ok';
    if (isFailed) kind = 'failed';
    else if (isTimeout) kind = 'timeout';
    else if (isNoop) kind = 'skipped';

    renderConsole({
      kind, title, jobId,
      reasonCode: reasonCode || undefined,
      payload: data && data.payload,
      raw: data,
    });
  } catch (e) {
    renderConsole({
      kind: 'net_err', title,
      message: (e && e.message) || String(e),
    });
  } finally {
    if (btn) {
      btn.disabled = false;
      btn.classList.remove('is-loading');
    }
  }
}

// M19: full mode 重算所有 90 天历史 — 跑得久 + 覆盖 db, 先确认避免误点
function confirmAndDeepResearchFull(btn) {
  if (!confirm('full 模式将重算所有因子过去 90 天的 IC, 覆盖 db, 约 10-15 分钟。\n\n确认继续吗?')) return;
  doAction(btn, '/api/control/jobs/batch.deep_research/trigger?force_full=true', 'POST');
}

// M19: 因子淘汰 — 默认先 dry_run 看名单, 用户在 console output 看准了再点真删
async function evictFactors(btn) {
  const title = 'factor.eviction';
  btn.disabled = true;
  btn.classList.add('is-loading');
  const orig = btn.innerHTML;
  btn.innerHTML = '<span class="btn-icon">⏳</span>计算淘汰名单中...';
  const restore = () => {
    btn.innerHTML = orig;
    btn.classList.remove('is-loading');
    btn.disabled = false;
  };

  renderConsole({ kind: 'busy', title: 'dry-run 计算淘汰名单' });

  try {
    // 第 1 步: dry_run 看待淘汰名单
    const r = await fetch('/api/control/jobs/factor.eviction/trigger?dry_run=true', {method: 'POST'});
    const accepted = await r.json().catch(() => ({}));
    if (!r.ok) {
      renderConsole({
        kind: 'failed', title,
        httpStatus: r.status,
        message: formatErrorDetail(accepted || {}),
        raw: accepted,
      });
      return;
    }
    // M24: eviction 走 daemon 异步, dry_run 的 victims 在 job-runs detail payload 里,
    // 首响应只有 poll_url。必须轮询到 daemon 跑完(status=ok)才拿得到 victims,
    // 否则 payload.victims 永远 undefined → 误判 "没有需要淘汰的因子"(功能失效)。
    let d = accepted;
    if (String(accepted.status || '').toLowerCase() === 'accepted' && accepted.payload && accepted.payload.poll_url) {
      d = await pollJobRunUntilDone(accepted, {
        pollTimeout: 300000,
        onTick: (pd, sec) => renderConsole({ kind: 'busy', title: 'dry-run 计算淘汰名单', summaryHtml: `<span class="kv-k">已耗时:</span> <span class="kv-v">${sec}</span> 秒` }),
      }) || { status: 'timeout' };
    }
    const dStatus = String(d.status || '').toLowerCase();
    if (['failed', 'error', 'crashed', 'timeout'].includes(dStatus)) {
      renderConsole({ kind: dStatus === 'timeout' ? 'timeout' : 'failed', title, message: formatErrorDetail(d.payload || d || {}), raw: d });
      return;
    }
    const payload = d.payload || {};
    const victims = payload.victims || [];
    if (!victims.length) {
      renderConsole({
        kind: 'skipped', title,
        reasonCode: 'NO_VICTIMS',
        message: `当前池子里 ${payload.pool_total_before || 0} 个因子，没有触及淘汰阈值 (min_score=${payload.min_score || 0})`,
        raw: d,
      });
      alert('当前没有需要淘汰的因子');
      return;
    }

    // 生成 dry-run 摘要
    const preview = victims.slice(0, 30).map(v =>
      `  ${escapeHtml((v.name || '').padEnd(48))} <span class="kv-k">score=</span>${(v.score||0).toFixed(3)} <span class="kv-k">status=</span>${escapeHtml(v.status||'')} <span class="kv-k">reason=</span>${escapeHtml(v.reason||'')}`
    ).join('\n');
    const summaryHtml =
      `<span class="kv-k">pool:</span> ${payload.pool_total_before || 0} → ${(payload.pool_total_before || 0) - (payload.victims_n || 0)}  ｜  ` +
      `<span class="kv-k">min_score:</span> ${payload.min_score || 0}  ｜  ` +
      `<span class="kv-k">max_pool_size:</span> ${payload.max_pool_size || 0}\n` +
      `\n== DRY RUN 待淘汰名单 (前 ${Math.min(victims.length, 30)}/${payload.victims_n || 0}) ==\n` + preview;
    renderConsole({
      kind: 'review',
      title: 'dry-run 完成 — 请确认',
      reasonCode: 'DRY_RUN',
      summaryHtml,
      raw: d,
    });
    // 第 2 步: 用户确认后真删
    if (!confirm(`待淘汰 ${payload.victims_n} 个因子, 名单已显示在控制台。\n\n确认执行吗?(软删除, factor_metrics 历史保留可查; 因子标 evicted_at 不再参与组合)`)) {
      return;
    }

    btn.innerHTML = '<span class="btn-icon">⏳</span>执行删除...';
    renderConsole({ kind: 'busy', title: '执行删除' });

    const r2 = await fetch('/api/control/jobs/factor.eviction/trigger', {method: 'POST'});
    const accepted2 = await r2.json().catch(() => ({}));
    if (!r2.ok) {
      renderConsole({
        kind: 'failed', title: '真删除失败',
        httpStatus: r2.status,
        message: formatErrorDetail(accepted2 || {}),
        raw: accepted2,
      });
      return;
    }
    // 同 dry-run: 真删也走异步 daemon, 必须轮询到跑完再确认结果, 否则 "入队即当完成" 误报。
    let d2 = accepted2;
    if (String(accepted2.status || '').toLowerCase() === 'accepted' && accepted2.payload && accepted2.payload.poll_url) {
      d2 = await pollJobRunUntilDone(accepted2, {
        pollTimeout: 300000,
        onTick: (pd, sec) => renderConsole({ kind: 'busy', title: '执行删除', summaryHtml: `<span class="kv-k">已耗时:</span> <span class="kv-v">${sec}</span> 秒` }),
      }) || { status: 'timeout' };
    }
    const status2 = (d2 && d2.status) ? String(d2.status).toLowerCase() : 'ok';
    const isFailed2 = ['failed', 'error', 'crashed', 'timeout'].includes(status2);
    renderConsole({
      kind: isFailed2 ? (status2 === 'timeout' ? 'timeout' : 'failed') : 'ok',
      title: '因子淘汰完成',
      reasonCode: d2.reason_code || undefined,
      jobId: 'factor.eviction',
      payload: d2.payload,
      raw: d2,
    });
  } catch (e) {
    renderConsole({
      kind: 'net_err', title,
      message: (e && e.message) || String(e),
    });
  } finally {
    restore();
  }
}
</script>

