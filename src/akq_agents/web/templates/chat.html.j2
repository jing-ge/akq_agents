{% extends "base.html.j2" %}
{% block title %}Chat{% endblock %}

{% block content %}
<h1>AI 对话 <span class="small" style="font-weight:400">Chat</span></h1>
<p class="page-intro">
  这个页面用来 <b>跟系统内的 AI 智能体对话</b>。你可以直接用大白话问，例如：
  「<i>今天的组合里有哪些股票？</i>」「<i>最近一周哪些因子表现最好？</i>」「<i>帮我跑一轮因子发现</i>」「<i>数据健康度如何？</i>」。
  AI 在回答时可能调用工具查数据 / 触发任务，会以 🔧 标记。
</p>

<div class="grid grid-2" style="grid-template-columns: 1fr 3fr;">
  <!-- Sessions sidebar -->
  <div class="card">
    <h2>会话列表</h2>
    <button onclick="newSession()" class="primary">+ 新建会话</button>
    <div id="sessions-list" style="margin-top: 12px;">
      {% if sessions %}
        {% for s in sessions %}
        <div data-session-id="{{ s.session_id }}" class="session-row">
          <div onclick="loadSession('{{ s.session_id }}')" style="flex:1; cursor:pointer; overflow:hidden;">
            <code>{{ s.session_id }}</code>
            <div class="small">{{ s.last_ts }} ｜ 共 {{ s.message_count }} 条消息</div>
          </div>
          <button class="session-del" onclick="event.stopPropagation(); deleteSession('{{ s.session_id }}')" title="删除会话">×</button>
        </div>
        {% endfor %}
      {% else %}
        <div class="empty-state"><span class="em">∅</span><div class="em-title">暂无历史会话</div><div class="em-hint">点上方「新建会话」开始跟 AI 对话。</div></div>
      {% endif %}
    </div>
  </div>

  <!-- Conversation -->
  <div class="card">
    <h2 id="session-title">尚未选择会话</h2>
    <div id="chat-window" class="chat-window">
      <div class="empty-state" id="chat-empty">
        <span class="em">›_</span>
        <div class="em-title">尚未选择会话</div>
        <div class="em-hint">点左侧「+ 新建会话」开始，或选择一条历史会话。</div>
        <div style="margin-top:18px; text-align:left; max-width:520px">
          <div class="small" style="color:#94a3b8; margin-bottom:8px">💡 试试这些问题：</div>
          <div class="quick-questions">
            <button class="qq" onclick="askQuick(this)">今天的组合里有哪些股票？</button>
            <button class="qq" onclick="askQuick(this)">现在 NAV 是多少？跑赢沪深300 多少？</button>
            <button class="qq" onclick="askQuick(this)">今天我该买什么、卖什么？</button>
            <button class="qq" onclick="askQuick(this)">对比 6-16 和 6-17 的组合变化</button>
            <button class="qq" onclick="askQuick(this)">momentum_5 这个因子最近是不是在衰减？</button>
            <button class="qq" onclick="askQuick(this)">前向跟踪 30 / 60 / 90 天的真实表现</button>
            <button class="qq" onclick="askQuick(this)">最近发现的新因子有哪些？哪些被淘汰了？</button>
            <button class="qq" onclick="askQuick(this)">现在跑一轮因子发现</button>
          </div>
        </div>
      </div>
    </div>
    <div class="chat-input">
      <textarea id="chat-input" rows="1" placeholder="输入你的问题，Enter 发送 ｜ Shift+Enter 换行 ｜ ↑ 回放上一条"></textarea>
      <button id="chat-send" onclick="sendMessage()" class="primary" disabled>发送</button>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script>
let currentSession = null;

async function deleteSession(sid) {
  const ok = await confirmDialog(`确定删除会话 ${sid}？此操作不可撤销。`, {
    title: '删除会话', confirmLabel: '删除', danger: true,
  });
  if (!ok) return;
  try {
    const r = await fetch(`/api/chat/sessions/${sid}`, { method: 'DELETE' });
    if (!r.ok) { toast('删除失败 HTTP ' + r.status, 'error'); return; }
    // 从 sidebar 移除该行
    const row = document.querySelector(`#sessions-list > div[data-session-id="${sid}"]`);
    if (row) row.remove();
    // 如果当前正打开的会话被删了，清空主区
    if (currentSession === sid) {
      currentSession = null;
      document.getElementById('chat-send').disabled = true;
      document.getElementById('session-title').textContent = '尚未选择会话';
      document.getElementById('chat-window').innerHTML = '';
      const empty = document.getElementById('chat-empty');
      if (empty) empty.style.display = '';
    }
    toast('会话已删除', 'ok');
  } catch (e) { toast('删除失败: ' + e.message, 'error'); }
}

async function newSession() {
  const r = await fetch('/api/chat/sessions', { method: 'POST' });
  if (!r.ok) { toast('创建失败: ' + r.status, 'error'); return; }
  const d = await r.json();
  currentSession = d.session_id;
  document.getElementById('session-title').textContent = '会话 #' + currentSession;
  document.getElementById('chat-window').innerHTML = '';
  document.getElementById('chat-send').disabled = false;
  highlightSession(null);
  document.getElementById('chat-input').focus();
}

async function loadSession(sid) {
  currentSession = sid;
  document.getElementById('session-title').textContent = '会话 #' + sid;
  document.getElementById('chat-send').disabled = false;
  highlightSession(sid);
  const win = document.getElementById('chat-window');
  win.innerHTML = '<div class="loading-skeleton">读取历史消息…</div>';
  const r = await fetch(`/api/chat/sessions/${sid}/messages?limit=200`);
  if (!r.ok) { win.innerHTML = '<div class="empty-state"><span class="em">!</span><div class="em-title">加载失败</div></div>'; return; }
  const d = await r.json();
  win.innerHTML = '';
  d.messages.forEach(m => addMessage(m.role, m.content, m.tool_name));
  win.scrollTop = win.scrollHeight;
}

function highlightSession(sid) {
  document.querySelectorAll('#sessions-list > div[data-session-id]').forEach(el => {
    if (el.getAttribute('data-session-id') === sid) {
      el.style.borderColor = 'var(--accent)';
      el.style.background = 'var(--accent-soft)';
    } else {
      el.style.borderColor = '';
      el.style.background = '';
    }
  });
}

function addMessage(role, content, toolName) {
  if (role === 'system') return;
  const win = document.getElementById('chat-window');
  const div = document.createElement('div');
  div.className = 'chat-msg ' + role;
  if (role === 'tool') {
    div.textContent = '🔧 ' + (toolName || '工具调用');
  } else if (role === 'assistant') {
    // 简单 markdown 渲染（LLM 喜欢用 ** / | / # / - / 代码块）
    div.innerHTML = renderMarkdown(content);
  } else {
    div.textContent = content;
  }
  win.appendChild(div);
  win.scrollTop = win.scrollHeight;
  return div;
}

// 安全 escape
function escHtml(s) {
  return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

// 最简 markdown：粗体 / 行内代码 / 代码块 / 列表 / 标题 / 表格 / 换行
function renderMarkdown(text) {
  let s = text || '';
  // 1) 代码块 ```...```
  const blocks = [];
  s = s.replace(/```([\s\S]*?)```/g, (_m, code) => {
    blocks.push('<pre class="md-code">' + escHtml(code.trim()) + '</pre>');
    return `\x00BLOCK${blocks.length - 1}\x00`;
  });
  // 2) escape 其他
  s = escHtml(s);
  // 3) 行内代码 `xxx`
  s = s.replace(/`([^`\n]+)`/g, '<code>$1</code>');
  // 4) 粗体 **xxx**
  s = s.replace(/\*\*([^*\n]+)\*\*/g, '<strong>$1</strong>');
  // 5) 表格（GFM）
  s = s.replace(/(^\|.+\|$\n^\|[\s\-:|]+\|$\n(?:^\|.+\|$\n?)+)/gm, (match) => {
    const lines = match.trim().split('\n');
    const header = lines[0].split('|').slice(1, -1).map(c => c.trim());
    const rows = lines.slice(2).map(ln => ln.split('|').slice(1, -1).map(c => c.trim()));
    let html = '<table class="md-table"><thead><tr>';
    for (const h of header) html += '<th>' + h + '</th>';
    html += '</tr></thead><tbody>';
    for (const r of rows) {
      html += '<tr>' + r.map(c => '<td>' + c + '</td>').join('') + '</tr>';
    }
    html += '</tbody></table>';
    return html;
  });
  // 6) 标题（行首 ##）
  s = s.replace(/^### (.+)$/gm, '<h4 class="md-h">$1</h4>');
  s = s.replace(/^## (.+)$/gm, '<h3 class="md-h">$1</h3>');
  s = s.replace(/^# (.+)$/gm, '<h3 class="md-h">$1</h3>');
  // 7) 列表 - / *
  s = s.replace(/(?:^[-*] .+$\n?)+/gm, (block) => {
    const items = block.trim().split('\n').map(ln => ln.replace(/^[-*] /, ''));
    return '<ul class="md-ul">' + items.map(it => '<li>' + it + '</li>').join('') + '</ul>';
  });
  // 8) 换行
  s = s.replace(/\n/g, '<br>');
  // 9) 还原代码块
  s = s.replace(/\x00BLOCK(\d+)\x00/g, (_m, i) => blocks[parseInt(i)]);
  return s;
}

// 打字机渐进：把完整 content 按字符喂给已有的 div
function addAssistantTyped(content) {
  const win = document.getElementById('chat-window');
  const div = document.createElement('div');
  div.className = 'chat-msg assistant streaming';
  div.textContent = '';
  win.appendChild(div);
  win.scrollTop = win.scrollHeight;

  const text = content || '';
  // 速度：短文本快，长文本平滑（最长 1.2s 显示完）
  const total = text.length;
  const targetMs = Math.min(1200, Math.max(220, total * 12));
  const startedAt = performance.now();
  function tick(now) {
    const elapsed = now - startedAt;
    const pct = Math.min(1, elapsed / targetMs);
    // 缓动 easeOutQuad
    const eased = 1 - (1 - pct) * (1 - pct);
    const chars = Math.floor(total * eased);
    div.textContent = text.slice(0, chars);
    win.scrollTop = win.scrollHeight;
    if (pct < 1) {
      requestAnimationFrame(tick);
    } else {
      // 渐进结束 → 用 markdown 渲染最终内容
      div.innerHTML = renderMarkdown(text);
      div.classList.remove('streaming');
    }
  }
  requestAnimationFrame(tick);
}

function addToolEvent(payload) {
  const win = document.getElementById('chat-window');
  const div = document.createElement('div');
  div.className = 'chat-msg tool';
  div.innerHTML = `🔧 <code>${payload.name}</code><br><span class="small">${JSON.stringify(payload.args || {}).slice(0, 80)}</span>`;
  win.appendChild(div);
  win.scrollTop = win.scrollHeight;
}

// 一键发送预设问题：自动新建 session（如果没有）+ 填入 input + sendMessage
async function askQuick(btn) {
  const q = btn.textContent;
  if (!currentSession) {
    // 自动新建一个 session
    const r = await fetch('/api/chat/sessions', { method: 'POST', headers:{'Content-Type':'application/json'}, body:'{}' });
    const d = await r.json();
    if (d && d.session_id) {
      currentSession = d.session_id;
      const titleEl = document.getElementById('session-title');
      if (titleEl) titleEl.textContent = currentSession;
      const winEl = document.getElementById('chat-window');
      if (winEl) winEl.innerHTML = '';
      document.getElementById('chat-send').disabled = false;
    } else { return; }
  }
  document.getElementById('chat-input').value = q;
  sendMessage();
}

async function sendMessage() {
  if (!currentSession) return;
  const input = document.getElementById('chat-input');
  const content = input.value.trim();
  if (!content) return;
  // 移除空状态占位（如果还在）
  const empty = document.getElementById('chat-empty');
  if (empty) empty.remove();
  addMessage('user', content);
  input.value = '';
  input.disabled = true;
  document.getElementById('chat-send').disabled = true;

  // 使用 fetch + EventSource 不太直接；改用 POST + text/event-stream 解析
  try {
    const response = await fetch(`/api/chat/sessions/${currentSession}/messages`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'text/event-stream' },
      body: JSON.stringify({ content }),
    });
    if (!response.ok) {
      addMessage('assistant', `[错误 ${response.status}: ${await response.text()}]`);
      return;
    }
    const reader = response.body.getReader();
    const decoder = new TextDecoder();
    let buffer = '';
    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      buffer += decoder.decode(value, { stream: true });
      const events = buffer.split('\n\n');
      buffer = events.pop() || '';
      for (const ev of events) {
        if (!ev.trim()) continue;
        const lines = ev.split('\n');
        let evName = 'message';
        let evData = '';
        for (const l of lines) {
          if (l.startsWith('event:')) evName = l.slice(6).trim();
          if (l.startsWith('data:')) evData += l.slice(5).trim();
        }
        if (!evData) continue;
        try {
          const payload = JSON.parse(evData);
          if (evName === 'tool_use') addToolEvent(payload);
          if (evName === 'assistant') addAssistantTyped(payload.content);
          if (evName === 'error') addMessage('assistant', `[错误: ${payload.message || JSON.stringify(payload)}]`);
        } catch { /* ignore parse */ }
      }
    }
  } catch (e) {
    addMessage('assistant', '[网络错误] ' + e.message);
  } finally {
    input.disabled = false;
    document.getElementById('chat-send').disabled = false;
    input.focus();
  }
}

// Enter 发送 / Shift+Enter 换行 / ↑ ↓ 回放历史
const _inputEl = document.getElementById('chat-input');
let _historyStack = [];      // 用户发过的消息
let _historyCursor = -1;     // -1 = 当前未浏览历史

_inputEl.addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    const t = _inputEl.value.trim();
    if (t) {
      _historyStack.push(t);
      _historyCursor = -1;
    }
    sendMessage();
    return;
  }
  if (e.key === 'ArrowUp' && _inputEl.value.trim() === '' && _historyStack.length > 0) {
    e.preventDefault();
    if (_historyCursor === -1) _historyCursor = _historyStack.length - 1;
    else if (_historyCursor > 0) _historyCursor -= 1;
    _inputEl.value = _historyStack[_historyCursor];
  } else if (e.key === 'ArrowDown' && _historyCursor >= 0) {
    e.preventDefault();
    if (_historyCursor < _historyStack.length - 1) {
      _historyCursor += 1;
      _inputEl.value = _historyStack[_historyCursor];
    } else {
      _historyCursor = -1;
      _inputEl.value = '';
    }
  }
});

// textarea 自适应高度（最多 6 行）
_inputEl.addEventListener('input', () => {
  _inputEl.style.height = 'auto';
  _inputEl.style.height = Math.min(_inputEl.scrollHeight, 140) + 'px';
});
</script>
{% endblock %}
