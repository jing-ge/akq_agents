      tooltip: {
        trigger: 'axis',
        backgroundColor: 'rgba(17,20,27,0.95)',
        borderColor: '#2e3648',
        textStyle: { color: '#e6e9f0' },
        axisPointer: { type: 'shadow', shadowStyle: { color: 'rgba(94,234,212,0.06)' } },
      },
      grid: { left: 50, right: 20, top: 44, bottom: 64 },
