// ===== KPI 总览条 =====================================================
// 顶部 sticky 6 KPI 一排 — 点击平滑滚动至对应卡片，30s 自动刷新
function setupKpiOverview() {
  document.querySelectorAll('.kpi-overview .kpi-tile').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.target;
      if (!id) return;
      const card = document.getElementById(id);
      if (!card) return;
      // 计算 sticky bar 高度后偏移
      const stickyH = document.querySelector('.kpi-overview')?.offsetHeight || 0;
      const top = card.getBoundingClientRect().top + window.pageYOffset - stickyH - 12;
      window.scrollTo({ top, behavior: 'smooth' });
      // 高亮目标卡片一秒
      card.classList.remove('kpi-flash-target');
      void card.offsetWidth;
      card.classList.add('kpi-flash-target');
      setTimeout(() => card.classList.remove('kpi-flash-target'), 1400);
    });
  });
}

async function loadKpiOverview() {
  // 并行拉所有数据源；任何一个失败仅 fallback 显示 "—"
  const tasks = [
    fetch('/api/research/nav?limit=400').then(r => r.ok ? r.json() : null).catch(() => null),
    fetch('/api/trading/today-list').then(r => r.ok ? r.json() : null).catch(() => null),
    fetch('/api/research/factors/shadow-stats').then(r => r.ok ? r.json() : null).catch(() => null),
  ];
  const [navD, listD, shadowD] = await Promise.all(tasks);

  const setVal = (id, val, sub, cls) => {
    const v = document.getElementById(id);
    if (!v) return;
    v.textContent = val;
    if (cls !== undefined) {
      v.classList.remove('metric-good', 'metric-bad', 'metric-warn', 'metric-dim');
      if (cls) v.classList.add(cls);
    }
    if (sub !== undefined) {
      const subId = id.replace('-val', '-sub');
      const s = document.getElementById(subId);
      if (s) s.textContent = sub;
    }
  };

  // NAV: 取最后一个有效点
  if (navD && navD.nav && navD.nav.length) {
    const last = navD.nav[navD.nav.length - 1];
    const navVal = last.nav_net;
    const navStr = navVal != null ? Number(navVal).toFixed(4) : '—';
    let dailyStr = '—';
    let dailyCls = '';
    if (navD.nav.length >= 2) {
      const prev = navD.nav[navD.nav.length - 2];
      if (prev && prev.nav_net && navVal != null) {
        const ret = (navVal - prev.nav_net) / prev.nav_net;
        const sign = ret >= 0 ? '+' : '';
        dailyStr = `${sign}${(ret * 100).toFixed(2)}%`;
        dailyCls = ret >= 0 ? 'metric-good' : 'metric-bad';
      }
    }
    setVal('kpi-nav-val', navStr);
    const navSub = document.getElementById('kpi-nav-sub');
    if (navSub) {
      navSub.textContent = `${last.date} · 日 ${dailyStr}`;
      navSub.classList.remove('metric-good', 'metric-bad');
      if (dailyCls) navSub.classList.add(dailyCls);
    }
    // 累计超额
    if (last.benchmark_nav && navVal != null) {
      const excess = (navVal - last.benchmark_nav) / last.benchmark_nav;
      const sign = excess >= 0 ? '+' : '';
      setVal('kpi-excess-val', `${sign}${(excess * 100).toFixed(2)}%`, undefined,
             excess >= 0 ? 'metric-good' : 'metric-bad');
    }
  }

  // Trade list: 用 today-list 既有汇总数 + 持仓数
  if (listD) {
    setVal('kpi-buy-val', listD.n_buy != null ? listD.n_buy : '—');
    setVal('kpi-sell-val', listD.n_sell != null ? listD.n_sell : '—');
    // 持仓数 = 推荐组合的 holdings = items 总数（含 HOLD），但更准确取 portfolio
    if (listD.cohort_date) {
      try {
        const r = await fetch(`/api/research/portfolio?date=${listD.cohort_date}`);
        if (r.ok) {
          const pd = await r.json();
          const n = (pd.rows || []).length;
          setVal('kpi-portfolio-val', n);
          const sub = document.getElementById('kpi-portfolio-sub');
          if (sub) sub.textContent = listD.cohort_date;
        }
      } catch (e) { /* ignore */ }
    }
  }

  // Shadow 待 demote
  if (shadowD && shadowD.shadows) {
    const n = shadowD.shadows.filter(s => s.verdict === 'should_demote').length;
    setVal('kpi-shadow-val', n, undefined, n > 0 ? 'metric-bad' : 'metric-dim');
  }

  // 给所有 tile 一次 flash 动画暗示数据已更新
  document.querySelectorAll('.kpi-overview .kpi-tile').forEach(t => {
    t.classList.remove('is-flash');
    void t.offsetWidth;
    t.classList.add('is-flash');
  });
}

// ===== P0-1 Trade List + Holdings =============================

async function loadTradeList() {
  const sumEl = document.getElementById('trade-list-summary');
  const tblEl = document.getElementById('trade-list-table');
  sumEl.innerHTML = '<span style="color:#94a3b8">加载中...</span>';
  try {
    const r = await fetch('/api/trading/today-list');
    const d = await r.json();
    if (!d.items || !d.items.length) {
      sumEl.innerHTML = '<div class="empty-state"><div class="empty-state-icon">⏳</div><div>暂无交易清单</div><div class="empty-state-hint">下次 portfolio agent 跑完后自动生成</div></div>';
      tblEl.innerHTML = '';
      return;
    }
    const fmt = (v, d=2) => v == null ? '-' : Number(v).toLocaleString('en', {maximumFractionDigits: d});

    sumEl.innerHTML = `
      ${d.stale_warning ? `<div class="stale-banner">${d.stale_warning}</div>` : ''}
      <div class="kpi-strip">
        <div><span class="small">建议日期</span><span class="stat-num">${d.cohort_date}${d.is_today ? '' : ' <span class="small" style="color:#fbbf24">(非今日)</span>'}</span></div>
        <div><span class="small">买入</span><span class="stat-num metric-good">${d.n_buy}</span></div>
        <div><span class="small">卖出</span><span class="stat-num metric-bad">${d.n_sell}</span></div>
        <div><span class="small">不动</span><span class="stat-num">${d.n_hold}</span></div>
        <div><span class="small">总买入额</span><span class="stat-num metric-good">¥${fmt(d.total_buy_amount, 0)}</span></div>
        <div><span class="small">总卖出额</span><span class="stat-num metric-bad">¥${fmt(d.total_sell_amount, 0)}</span></div>
      </div>
    `;

    // 表格 — 按 action 分组，先 BUY 后 SELL 后 HOLD
    const actBadge = (a) => {
      if (a === 'BUY') return '<span class="status-ok" style="font-weight:600">买入</span>';
      if (a === 'SELL') return '<span class="status-error" style="font-weight:600">卖出</span>';
      return '<span style="color:#94a3b8">保持</span>';
    };
    // 只显示 BUY/SELL，HOLD 折叠
    const tradable = d.items.filter(it => it.action !== 'HOLD');
    const holdItems = d.items.filter(it => it.action === 'HOLD');
    let html = `<table class="trade-table"><thead><tr>
      <th>动作</th><th>代码</th><th>行业</th>
      <th>当前 → 目标</th><th>变动股数</th><th>金额</th>
      <th>当前价</th><th>原因</th><th>操作</th>
    </tr></thead><tbody>${tradable.map(it => `<tr>
      <td>${actBadge(it.action)}</td>
      <td><code>${it.symbol}</code></td>
      <td class="small">${it.industry || '-'}</td>
      <td>${fmt(it.current_shares, 0)} → ${fmt(it.target_shares, 0)}</td>
      <td class="${it.delta_shares>=0?'metric-good':'metric-bad'}">${it.delta_shares>=0?'+':''}${fmt(it.delta_shares, 0)}</td>
      <td class="${it.delta_amount>=0?'metric-good':'metric-bad'}">¥${fmt(Math.abs(it.delta_amount), 0)}</td>
      <td>${fmt(it.current_price, 2)}</td>
      <td class="small">${it.reason || ''}</td>
      <td>${it.executed ? '✓ 已执行' : `<button onclick="markExecuted('${it.symbol}', '${d.cohort_date}', this)" class="small">标记完成</button>`}</td>
    </tr>`).join('')}</tbody></table>`;
    if (holdItems.length > 0) {
      html += `<details style="margin-top:14px"><summary class="small">展开 ${holdItems.length} 个保持不动的持仓</summary>`;
      html += `<table class="trade-table" style="margin-top:8px"><thead><tr>
        <th>代码</th><th>行业</th><th>股数</th><th>当前价</th><th>原因</th>
      </tr></thead><tbody>${holdItems.map(it => `<tr>
        <td><code>${it.symbol}</code></td>
        <td class="small">${it.industry || '-'}</td>
        <td>${fmt(it.current_shares, 0)}</td>
        <td>${fmt(it.current_price, 2)}</td>
        <td class="small">${it.reason || ''}</td>
      </tr>`).join('')}</tbody></table></details>`;
    }
    tblEl.innerHTML = html;
  } catch (e) {
    sumEl.textContent = '加载失败: ' + e.message;
  }
}

async function markExecuted(symbol, date, btn) {
  btn.disabled = true; btn.textContent = '...';
  try {
    await fetch(`/api/trading/today-list/${symbol}/mark-executed?date=${date}`, {method:'POST'});
    btn.outerHTML = '✓ 已执行';
  } catch (e) { btn.disabled = false; btn.textContent = '标记完成'; }
}

async function markAllExecuted() {
  if (!confirm('确认把今日 trade_list 里所有 BUY/SELL 全部标记已执行？这会更新 holdings 表。')) return;
  try {
    const r = await fetch('/api/trading/today-list/mark-all-executed', {method: 'POST'});
    const d = await r.json();
    if (!r.ok) {
      alert('失败：' + formatErrorDetail(d));
      return;
    }
    alert(`✅ 已执行 ${d.executed_count} 条`);
    location.reload();
  } catch (e) {
    alert('网络错误：' + e.message);
  }
}

async function loadHoldings() {
  const tblEl = document.getElementById('holdings-table');
  try {
    const r = await fetch('/api/trading/holdings');
    const d = await r.json();
    if (!d.holdings || !d.holdings.length) {
      tblEl.innerHTML = '<div class="empty-state small"><div>当前持仓为空</div><div class="empty-state-hint">在上方表单添加你的真实持仓</div></div>';
      return;
    }
    tblEl.innerHTML = `<table><thead><tr>
      <th>代码</th><th>股数</th><th>成本价</th><th>更新时间</th><th>备注</th><th>操作</th>
    </tr></thead><tbody>${d.holdings.map(h => `<tr>
      <td><code>${h.symbol}</code></td>
      <td>${Number(h.shares).toLocaleString('en')}</td>
      <td>${h.avg_cost != null ? Number(h.avg_cost).toFixed(2) : '-'}</td>
      <td class="small">${h.updated_at}</td>
      <td class="small">${h.note || ''}</td>
      <td><button onclick="deleteHolding('${h.symbol}')" class="small">删除</button></td>
    </tr>`).join('')}</tbody></table>`;
  } catch (e) {
    tblEl.innerHTML = '加载失败';
  }
}

async function upsertHolding() {
  const symbol = document.getElementById('hold-symbol').value.trim();
  const shares = parseFloat(document.getElementById('hold-shares').value);
  const cost = parseFloat(document.getElementById('hold-cost').value);
  const msgEl = document.getElementById('hold-msg');
  if (!symbol || isNaN(shares)) {
    msgEl.textContent = '需要填代码 + 股数';
    msgEl.style.color = '#f87171';
    return;
  }
  msgEl.textContent = '保存中...';
  try {
    await fetch(`/api/trading/holdings/${symbol}`, {
      method: 'PUT',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({shares, avg_cost: isNaN(cost) ? null : cost}),
    });
    msgEl.textContent = `✓ 已保存 ${symbol}`;
    msgEl.style.color = '#5eead4';
    document.getElementById('hold-symbol').value = '';
    document.getElementById('hold-shares').value = '';
    document.getElementById('hold-cost').value = '';
    await loadHoldings();
  } catch (e) {
    msgEl.textContent = '保存失败';
    msgEl.style.color = '#f87171';
  }
}

async function deleteHolding(symbol) {
  if (!confirm(`确定删除 ${symbol}？`)) return;
  try {
    await fetch(`/api/trading/holdings/${symbol}`, {method: 'DELETE'});
    await loadHoldings();
  } catch (e) { alert('删除失败'); }
}

