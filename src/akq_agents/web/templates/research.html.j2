// KPI sparkline 渲染: 把序列转成 SVG polyline. 简单实现, 不依赖 echarts.
// 尾点 dot + 线色跟趋势方向 (末点 vs 首点上涨 → 绿, 下跌 → 红, 持平 → 灰).
function renderSparkline(elId, series) {
  const el = document.getElementById(elId);
  if (!el || !series || series.length < 2) return;
  const min = Math.min(...series);
  const max = Math.max(...series);
  const range = max - min || 1e-9;
  const W = 100, H = 24, pad = 2;
  const step = (W - pad * 2) / Math.max(1, series.length - 1);
  const pts = series.map((v, i) => {
    const x = pad + i * step;
    const y = H - pad - ((v - min) / range) * (H - pad * 2);
    return x.toFixed(1) + ',' + y.toFixed(1);
  }).join(' ');
  const first = series[0], last = series[series.length - 1];
  const trend = last - first;
  const trendColor = Math.abs(trend) < range * 0.01
    ? 'var(--fg-dim)'
    : (trend >= 0 ? 'var(--ok)' : 'var(--err)');
  const lastX = pad + (series.length - 1) * step;
  const lastY = H - pad - ((last - min) / range) * (H - pad * 2);
  el.innerHTML = `
    <polyline points="${pts}" fill="none" stroke="${trendColor}" stroke-width="1.4"
      stroke-linecap="round" stroke-linejoin="round" opacity="0.85"/>
    <circle cx="${lastX.toFixed(1)}" cy="${lastY.toFixed(1)}" r="1.6" fill="${trendColor}"/>
  `;
}

async function loadKpiOverview() {
  // 并行拉所有数据源；任何一个失败仅 fallback 显示 "—"
  const tasks = [
    fetch('/api/research/nav?limit=400').then(r => r.ok ? r.json() : null).catch(() => null),
    fetch('/api/trading/today-list').then(r => r.ok ? r.json() : null).catch(() => null),
    fetch('/api/research/factors/shadow-stats').then(r => r.ok ? r.json() : null).catch(() => null),
  ];
  const [navD, listD, shadowD] = await Promise.all(tasks);

  // 「今日待办」汇总信号 — 各分支填充, 函数末尾统一渲染结论条
  const todo = { hasList: false, isStale: false, pendingBuy: 0, pendingSell: 0, shouldDemote: 0, navMissing: false };

  const setVal = (id, val, sub, cls) => {
    const v = document.getElementById(id);
    if (!v) return;
    v.textContent = val;
    if (cls !== undefined) {
      v.classList.remove('metric-good', 'metric-bad', 'metric-warn', 'metric-dim');
      if (cls) v.classList.add(cls);
    }
    if (sub !== undefined) {
      const subId = id.replace('-val', '-sub');
      const s = document.getElementById(subId);
      if (s) s.textContent = sub;
    }
  };

  // NAV: 取最后一个有效点
  if (navD && navD.nav && navD.nav.length) {
    const last = navD.nav[navD.nav.length - 1];
    const navVal = last.nav_net;
    const navStr = navVal != null ? Number(navVal).toFixed(4) : '—';
    let dailyStr = '—';
    let dailyCls = '';
    if (navD.nav.length >= 2) {
      const prev = navD.nav[navD.nav.length - 2];
      if (prev && prev.nav_net && navVal != null) {
        const ret = (navVal - prev.nav_net) / prev.nav_net;
        const sign = ret >= 0 ? '+' : '';
        dailyStr = `${sign}${(ret * 100).toFixed(2)}%`;
        dailyCls = ret >= 0 ? 'metric-good' : 'metric-bad';
      }
    }
    setVal('kpi-nav-val', navStr);
    const navSub = document.getElementById('kpi-nav-sub');
    if (navSub) {
      navSub.textContent = `${last.date} · 日 ${dailyStr}`;
      navSub.classList.remove('metric-good', 'metric-bad');
      if (dailyCls) navSub.classList.add(dailyCls);
    }
    // 累计超额 — B7 修复: 末点 benchmark 可能 NULL, 找最后一个有 benchmark 的日同步对齐
    const lastAligned = [...navD.nav].reverse().find(p => p.benchmark_nav != null && p.nav_net != null);
    if (lastAligned) {
      const excess = lastAligned.nav_net - lastAligned.benchmark_nav;
      const sign = excess >= 0 ? '+' : '';
      setVal('kpi-excess-val', `${sign}${(excess * 100).toFixed(2)}%`, `对齐 ${lastAligned.date.slice(5)}`,
             excess >= 0 ? 'metric-good' : 'metric-bad');
    }
    // KPI sparkline — 用最近 60 个点画迷你趋势线, 帮用户一眼感受走势
    // (只画 nav 和 excess 两条, 因为 buy/sell/portfolio 数是离散的当日快照, 无历史轴)
    try {
      const tail = navD.nav.slice(-60);
      const navSeries = tail.map(p => p.nav_net).filter(v => v != null);
      renderSparkline('kpi-nav-spark', navSeries);
      const excessSeries = tail
        .filter(p => p.nav_net != null && p.benchmark_nav != null)
        .map(p => p.nav_net - p.benchmark_nav);
      renderSparkline('kpi-excess-spark', excessSeries);
    } catch (e) { /* sparkline 失败不影响主流程 */ }
  } else {
    // NAV 数据为空：灰化 + 显示原因摘要
    const reason = navD && navD.summary && navD.summary.reason
      ? String(navD.summary.reason)
      : '尚无 NAV 数据';
    setVal('kpi-nav-val', '暂无', reason, 'metric-dim');
    setVal('kpi-excess-val', '暂无', reason, 'metric-dim');
    todo.navMissing = true;
  }

  // Trade list: 显示真正待执行的 BUY/SELL（排除 executed），并标注 stale 状态
  if (listD && listD.items) {
    const pendingBuy = listD.items.filter(i => i.action === 'BUY' && !i.executed).length;
    const pendingSell = listD.items.filter(i => i.action === 'SELL' && !i.executed).length;
    const isStale = listD.is_today === false;
    todo.hasList = true;
    todo.pendingBuy = pendingBuy;
    todo.pendingSell = pendingSell;
    todo.isStale = isStale;
    const buyStaleCls = isStale ? 'metric-dim' : '';
    const sellStaleCls = isStale ? 'metric-dim' : '';
    const staleSub = isStale ? `${listD.execution_date || listD.cohort_date} 旧清单` : undefined;
    setVal('kpi-buy-val', pendingBuy, staleSub, buyStaleCls);
    setVal('kpi-sell-val', pendingSell, staleSub, sellStaleCls);
    // 持仓数 = 推荐组合的 holdings = items 总数（含 HOLD），但更准确取 portfolio
    if (listD.cohort_date) {
      try {
        const r = await fetch(`/api/research/portfolio?date=${listD.cohort_date}`);
        if (r.ok) {
          const pd = await r.json();
          const n = (pd.rows || []).length;
          setVal('kpi-portfolio-val', n);
          const sub = document.getElementById('kpi-portfolio-sub');
          if (sub) sub.textContent = listD.cohort_date;
        }
      } catch (e) { /* ignore */ }
    }
  } else {
    // 接口失败或 items 缺失
    setVal('kpi-buy-val', '—', '暂无清单', 'metric-dim');
    setVal('kpi-sell-val', '—', '暂无清单', 'metric-dim');
  }

  // Shadow 待 demote
  if (shadowD && shadowD.shadows) {
    const n = shadowD.shadows.filter(s => s.verdict === 'should_demote').length;
    setVal('kpi-shadow-val', n, undefined, n > 0 ? 'metric-bad' : 'metric-dim');
    todo.shouldDemote = n;
  }

  // 汇总渲染「今日待办」结论条
  renderTodoSummary(todo);

  // 给所有 tile 一次 flash 动画暗示数据已更新
  document.querySelectorAll('.kpi-overview .kpi-tile').forEach(t => {
    t.classList.remove('is-flash');
    void t.offsetWidth;
    t.classList.add('is-flash');
  });
}

// 「今日待办」结论条: 把 KPI 汇总信号翻译成一句"我现在该做什么"。
// 优先级(从高到低): 数据过期/缺失 > 需调仓 > 待处理 shadow > 一切正常。
// 点击直达对应卡片, 并自动切到该卡片所在 tab。
function renderTodoSummary(todo) {
  const bar = document.getElementById('today-summary');
  const iconEl = document.getElementById('ts-icon');
  const textEl = document.getElementById('ts-text');
  const actEl = document.getElementById('ts-actions');
  if (!bar || !iconEl || !textEl || !actEl) return;

  const setBar = (level, icon, text, actions) => {
    bar.classList.remove('is-loading', 'ts-ok', 'ts-action', 'ts-warn', 'ts-danger');
    bar.classList.add('ts-' + level);
    iconEl.textContent = icon;
    textEl.innerHTML = text;
    actEl.innerHTML = (actions || []).map(a =>
      `<button type="button" class="ts-btn" onclick="jumpToCard('${a.target}')">${escapeHtml(a.label)} →</button>`
    ).join('');
  };

  // 1) 数据过期 / 缺失 — 最高优先级, 结果可能不可信
  if (todo.navMissing && !todo.hasList) {
    setBar('warn', '🔧', '系统还没有产出今日结果，可能是首次运行或数据未拉取。先去运维页跑一轮盘后批处理。', []);
    return;
  }
  if (todo.isStale) {
    setBar('warn', '🕒',
      '当前交易清单不是今天的（用的是历史快照）。今日盘后流程可能还没跑，结果仅供参考。',
      [{ label: '去重算今日组合', target: 'nav-card' }]);
    return;
  }

  // 2) 需要调仓 — 有待执行 BUY/SELL
  const totalTrades = (todo.pendingBuy || 0) + (todo.pendingSell || 0);
  if (totalTrades > 0) {
    setBar('action', '⚠️',
      `今日需要调仓：<b>${todo.pendingBuy} 买 / ${todo.pendingSell} 卖</b>，共 ${totalTrades} 笔待执行。`,
      [{ label: '查看交易清单', target: 'trade-list-card' }]);
    return;
  }

  // 3) 无需调仓, 但有 shadow 因子待处理(次要提醒)
  if (todo.shouldDemote > 0) {
    setBar('ok', '✅',
      `今日无需调仓 — <b>组合稳定，可休息</b>。另有 <b>${todo.shouldDemote} 个观察因子</b> OOS 表现不佳、建议淘汰。`,
      [{ label: '查看 Shadow 池', target: 'shadow-card' }]);
    return;
  }

  // 4) 一切正常 — 零操作日, 给明确的正面反馈 + 引导用户看组合表现
  if (todo.hasList) {
    // 有清单 = 已跑过今日盘后, 但都是 HOLD (无 BUY/SELL)
    setBar('ok', '☕',
      '今日无需调仓 — <b>组合稳定，可休息</b>。要看组合近期表现或因子健康？',
      [
        { label: '净值曲线', target: 'nav-card' },
        { label: 'Paper Trading', target: 'paper-trading-card' },
      ]);
  } else {
    // 无清单 = 今天还没跑盘后 (或 daemon 挂了)
    setBar('warn', '⏳',
      '今日盘后流程还没跑，暂无交易清单。收盘后 16:30 自动触发，也可手动。',
      [{ label: '去手动触发', target: 'portfolio-card' }]);
  }
}

// 点结论条按钮: 切到目标卡片所在 tab 并平滑滚动高亮
function jumpToCard(cardId) {
  const card = document.getElementById(cardId);
  if (!card) return;
  const tabKey = card.getAttribute('data-tab');
  if (tabKey) {
    // 直接切 tab (不走 .click, 避免触发切 tab 回滚, 由下方 scrollIntoView 精确定位到卡片)
    activateResearchTab(tabKey);
  }
  setTimeout(() => {
    card.scrollIntoView({ behavior: 'smooth', block: 'center' });
    card.classList.remove('card-flash');
    void card.offsetWidth;
    card.classList.add('card-flash');
  }, 60);
}

// ===== P0-1 Trade List + Holdings =============================

let _currentTradeListCohortDate = null;
async function loadTradeList() {
  const sumEl = document.getElementById('trade-list-summary');
  const tblEl = document.getElementById('trade-list-table');
  sumEl.innerHTML = '<span style="color:#94a3b8">加载中...</span>';
  try {
    const r = await fetch('/api/trading/today-list');
    const d = await r.json();
    // 记录当前渲染清单的 cohort_date，供"全部执行"复用（可能是 fallback 回退日期，非 today）
    _currentTradeListCohortDate = d.cohort_date || null;
    if (!d.items || !d.items.length) {
      sumEl.innerHTML = '<div class="empty-state"><div class="empty-state-icon">⏳</div><div>暂无交易清单</div><div class="empty-state-hint">下次 portfolio agent 跑完后自动生成</div></div>';
      tblEl.innerHTML = '';
      return;
    }
    const fmt = (v, d=2) => v == null ? '-' : Number(v).toLocaleString('en', {maximumFractionDigits: d});

    // 待执行（!executed）统计 — 与顶部 KPI "今日 BUY/SELL" 口径一致
    const pendingBuy = d.items.filter(i => i.action === 'BUY' && !i.executed).length;
    const pendingSell = d.items.filter(i => i.action === 'SELL' && !i.executed).length;
    const pendingBuyAmount = d.items
      .filter(i => i.action === 'BUY' && !i.executed)
      .reduce((s, i) => s + Math.abs(Number(i.delta_amount) || 0), 0);
    const pendingSellAmount = d.items
      .filter(i => i.action === 'SELL' && !i.executed)
      .reduce((s, i) => s + Math.abs(Number(i.delta_amount) || 0), 0);

    sumEl.innerHTML = `
      ${d.stale_warning ? `<div class="stale-banner">${d.stale_warning}</div>` : ''}
      <div class="kpi-strip">
        <div style="grid-column: span 2" title="execution_date: 该按此清单下单的日; cohort_date: 系统算出该清单的日(收盘后)"><span class="small">建议执行日</span><span class="stat-num" style="white-space:nowrap">${d.execution_date || d.cohort_date}</span>${d.is_today ? '' : ' <span class="small" style="color:#fbbf24">(非今日)</span>'} <span class="small" style="color:var(--fg-dim)">(算于 ${d.cohort_date} 盘后)</span></div>
        <div><span class="small">待买入</span><span class="stat-num ${pendingBuy > 0 ? 'metric-good' : ''}">${pendingBuy}</span></div>
        <div><span class="small">待卖出</span><span class="stat-num ${pendingSell > 0 ? 'metric-bad' : ''}">${pendingSell}</span></div>
        <div><span class="small">不动</span><span class="stat-num">${d.n_hold}</span></div>
        <div><span class="small">待买入额</span><span class="stat-num ${pendingBuyAmount > 0 ? 'metric-good' : ''}">¥${fmt(pendingBuyAmount, 0)}</span></div>
        <div><span class="small">待卖出额</span><span class="stat-num ${pendingSellAmount > 0 ? 'metric-bad' : ''}">¥${fmt(pendingSellAmount, 0)}</span></div>
      </div>
    `;

    // 表格 — 按 action 分组，先 BUY 后 SELL 后 HOLD
    const actBadge = (a) => {
      if (a === 'BUY') return '<span class="status-ok" style="font-weight:600">买入</span>';
      if (a === 'SELL') return '<span class="status-error" style="font-weight:600">卖出</span>';
      return '<span style="color:#94a3b8">保持</span>';
    };
    // 只显示 BUY/SELL，HOLD 折叠；executed=true 的从主表收起到独立折叠区
    const tradable = d.items.filter(it => it.action !== 'HOLD');
    // 按 |delta_amount| 从大到小排 — 用户先看金额最大的几笔, 而不是随机顺序.
    // 99 条清单一屏放不下, 大额优先能让用户快速定位真正需要关注的交易.
    // 排序稳定性: 相同金额时 BUY 优先, 便于先看要花的钱.
    tradable.sort((a, b) => {
      const da = Math.abs(Number(a.delta_amount) || 0);
      const db = Math.abs(Number(b.delta_amount) || 0);
      if (db !== da) return db - da;
      if (a.action !== b.action) return a.action === 'BUY' ? -1 : 1;
      return 0;
    });
    const pendingTradable = tradable.filter(it => !it.executed);
    const executedTradable = tradable.filter(it => it.executed);
    const holdItems = d.items.filter(it => it.action === 'HOLD');

    // 大批量清单 (>15 条) 分'重点 Top 10 + 剩余折叠', 减少滚动疲劳
    const BIG_LIST_THRESHOLD = 15;
    const isBigList = pendingTradable.length > BIG_LIST_THRESHOLD;
    const topN = 10;

    const renderRow = (it, executedCol, isTop) => `<tr${isTop ? ' class="row-top"' : ''}>
      <td>${actBadge(it.action)}</td>
      <td><a href="/stock/${it.symbol}" class="stock-link" title="打开个股详情页"><code>${it.symbol}</code></a>${it.name ? `<div class="small" style="color:var(--fg-dim)">${escapeHtml(it.name)}</div>` : ''}</td>
      <td class="small">${it.industry || '-'}</td>
      <td>${fmt(it.current_shares, 0)} → ${fmt(it.target_shares, 0)}</td>
      <td class="${it.delta_shares>=0?'metric-good':'metric-bad'}">${it.delta_shares>=0?'+':''}${fmt(it.delta_shares, 0)}</td>
      <td class="${it.delta_amount>=0?'metric-good':'metric-bad'}">¥${fmt(Math.abs(it.delta_amount), 0)}</td>
      <td>${fmt(it.current_price, 2)}</td>
      <td class="small">${it.reason || ''}</td>
      <td>${executedCol ? '✓ 已执行' : `<button onclick="markExecuted('${it.symbol}', '${d.cohort_date}', this)" class="small">标记完成</button>`}</td>
    </tr>`;

    const tableHead = `<table class="trade-table"><thead><tr>
      <th>动作</th><th>代码</th><th>行业</th>
      <th>当前 → 目标</th><th>变动股数</th><th>金额</th>
      <th>当前价</th><th>原因</th><th>操作</th>
    </tr></thead>`;

    let html = '';
    if (pendingTradable.length > 0) {
      if (isBigList) {
        const top = pendingTradable.slice(0, topN);
        const rest = pendingTradable.slice(topN);
        const topAmt = top.reduce((s, it) => s + Math.abs(Number(it.delta_amount) || 0), 0);
        const restAmt = rest.reduce((s, it) => s + Math.abs(Number(it.delta_amount) || 0), 0);
        html += `<div class="trade-list-hint small">
          共 <b>${pendingTradable.length}</b> 笔待执行，已按金额从大到小排。
          先看下方 <b>Top ${topN} 大额</b>（约占 ${(topAmt / (topAmt + restAmt) * 100).toFixed(0)}%）；
          剩余 ${rest.length} 笔小额可在下方展开。
        </div>`;
        html += `${tableHead}<tbody>${top.map(it => renderRow(it, false, true)).join('')}</tbody></table>`;
        if (rest.length > 0) {
          html += `<details class="trade-more"><summary class="small">
            展开剩余 ${rest.length} 笔小额交易 (累计 ¥${fmt(restAmt, 0)})
          </summary>`;
          html += `${tableHead.replace('class="trade-table"', 'class="trade-table trade-table-rest" style="margin-top:8px"')}<tbody>${rest.map(it => renderRow(it, false, false)).join('')}</tbody></table></details>`;
        }
      } else {
        html += `${tableHead}<tbody>${pendingTradable.map(it => renderRow(it, false, false)).join('')}</tbody></table>`;
      }
    } else if (executedTradable.length > 0) {
      // 全部已执行的完成态 — 复用 empty-state 系列样式
      html += `<div class="empty-state"><div class="empty-state-icon" style="color:var(--ok, #10b981)">✅</div><div>今日 ${executedTradable.length} 条交易已全部执行</div></div>`;
    } else if (holdItems.length > 0) {
      // 无交易信号 (BUY/SELL 全被阈值过滤). 显式告诉用户 "系统正常, 只是今天没让你动手".
      // 避免用户误以为清单坏了 / 数据没生成. 提示如何调阈值让 UI 更喜好.
      html += `<div class="empty-state">
        <div class="empty-state-icon">🟢</div>
        <div style="font-weight:600;margin-bottom:4px">今日无需调仓</div>
        <div class="small" style="color:var(--fg-mute);max-width:520px;line-height:1.6">
          ${holdItems.length} 只持仓保持不动 (权重变化不超过 <code>trade_list.min_weight_change</code>
          或调仓金额 &lt; <code>trade_list.min_trade_amount</code>).
          <br>想看更多细节 → 展开下方"保持不动的持仓". 想让阈值更敏感 → 改
          <code>config/system.yaml</code> 的 <code>trade_list:</code> 段.
        </div>
      </div>`;
    }
    if (executedTradable.length > 0) {
      html += `<details style="margin-top:14px"><summary class="small">展开 ${executedTradable.length} 条已执行交易</summary>`;
      html += `${tableHead.replace('class="trade-table"', 'class="trade-table" style="margin-top:8px"')}<tbody>${executedTradable.map(it => renderRow(it, true, false)).join('')}</tbody></table></details>`;
    }
    if (holdItems.length > 0) {
      html += `<details style="margin-top:14px"><summary class="small">展开 ${holdItems.length} 个保持不动的持仓</summary>`;
      html += `<table class="trade-table" style="margin-top:8px"><thead><tr>
        <th>代码</th><th>行业</th><th>股数</th><th>当前价</th><th>原因</th>
      </tr></thead><tbody>${holdItems.map(it => `<tr>
        <td><a href="/stock/${it.symbol}" class="stock-link"><code>${it.symbol}</code></a>${it.name ? `<div class="small" style="color:var(--fg-dim)">${escapeHtml(it.name)}</div>` : ''}</td>
        <td class="small">${it.industry || '-'}</td>
        <td>${fmt(it.current_shares, 0)}</td>
        <td>${fmt(it.current_price, 2)}</td>
        <td class="small">${it.reason || ''}</td>
      </tr>`).join('')}</tbody></table></details>`;
    }
    tblEl.innerHTML = html;
    // 给两个表格都加排序（主表 + 折叠的 HOLD 表）
    tblEl.querySelectorAll('table.trade-table').forEach(t => makeSortable(t));
  } catch (e) {
    renderFetchError(sumEl, e);
    tblEl.innerHTML = '';
  }
}

async function markExecuted(symbol, date, btn) {
  btn.disabled = true; btn.textContent = '...';
  try {
    const r = await fetch(`/api/trading/today-list/${symbol}/mark-executed?date=${date}`, {method:'POST'});
    const d = await r.json().catch(() => ({}));
    if (!r.ok) throw new Error(formatErrorDetail(d) || ('HTTP ' + r.status));
    btn.outerHTML = '✓ 已执行';
    loadKpiOverview();
    loadHoldings();
  } catch (e) {
    btn.disabled = false;
    btn.textContent = '标记完成';
    toast('标记失败：' + e.message, 'error');
  }
}

async function markAllExecuted() {
  // 从已渲染的清单里统计 pending BUY/SELL 数量与金额, 让用户在确认前看到真实规模,
  // 而不是简单"确认全部执行?" 用户可能有 20 条买入 * 5000 元一起下, 有权知情.
  let pendingBuyN = 0, pendingSellN = 0;
  let pendingBuyAmt = 0, pendingSellAmt = 0;
  try {
    const r = await fetch('/api/trading/today-list');
    const d = await r.json();
    (d.items || []).forEach(it => {
      if (it.executed) return;
      const amt = Math.abs(Number(it.delta_amount) || 0);
      if (it.action === 'BUY') { pendingBuyN += 1; pendingBuyAmt += amt; }
      else if (it.action === 'SELL') { pendingSellN += 1; pendingSellAmt += amt; }
    });
  } catch {}
  const total = pendingBuyN + pendingSellN;
  if (total === 0) {
    toast('没有待执行的交易, 已跳过', 'ok');
    return;
  }
  const fmtY = (v) => Number(v).toLocaleString('en', {maximumFractionDigits: 0});
  const msg =
    `将标记 ${total} 笔交易为已执行, 并同步更新你的 holdings 持仓表:\n\n` +
    `  • 买入 ${pendingBuyN} 笔, 累计 ¥${fmtY(pendingBuyAmt)}\n` +
    `  • 卖出 ${pendingSellN} 笔, 累计 ¥${fmtY(pendingSellAmt)}\n` +
    `  • 净流出 ¥${fmtY(pendingBuyAmt - pendingSellAmt)}\n\n` +
    `注意: 该操作仅在系统内记录, 不会真的下单. 但会覆盖你的 holdings, 请确认已在券商完成对应交易再点确定.`;
  const ok = await confirmDialog(msg, {
    title: `确认执行 ${total} 笔交易`,
    confirmLabel: `确定执行 (${total} 笔)`,
    cancelLabel: '再想想',
    danger: true,
  });
  if (!ok) return;
  try {
    const url = _currentTradeListCohortDate
      ? `/api/trading/today-list/mark-all-executed?date=${_currentTradeListCohortDate}`
      : '/api/trading/today-list/mark-all-executed';
    const r = await fetch(url, {method: 'POST'});
    const d = await r.json();
    if (!r.ok) {
      toast('失败：' + formatErrorDetail(d), 'error');
      return;
    }
    toast(`已执行 ${d.executed_count} 条交易`, 'ok');
    if (d.failed_count > 0) {
      const sym = (d.failed_symbols || []).join(', ');
      toast(`部分失败 ${d.failed_count} 条${sym ? '：' + sym : ''}`, 'warn');
    }
    // 不再 reload；只刷新相关卡片即可
    loadTradeList();
    loadHoldings();
    loadKpiOverview();
  } catch (e) {
    toast('网络错误：' + e.message, 'error');
  }
}

async function loadHoldings() {
  const tblEl = document.getElementById('holdings-table');
  try {
    const r = await fetch('/api/trading/holdings');
    const d = await r.json();
    if (!d.holdings || !d.holdings.length) {
      tblEl.innerHTML = '<div class="empty-state small"><div>当前持仓为空</div><div class="empty-state-hint">在上方表单添加你的真实持仓</div></div>';
      return;
    }
    tblEl.innerHTML = `<table><thead><tr>
      <th>代码</th><th>股数</th><th>成本价</th><th>更新时间</th><th>备注</th><th>操作</th>
    </tr></thead><tbody>${d.holdings.map(h => `<tr>
      <td><a href="/stock/${h.symbol}" class="stock-link"><code>${h.symbol}</code></a>${h.name ? `<div class="small" style="color:var(--fg-dim)">${escapeHtml(h.name)}</div>` : ''}</td>
      <td>${Number(h.shares).toLocaleString('en')}</td>
      <td>${h.avg_cost != null ? Number(h.avg_cost).toFixed(2) : '-'}</td>
      <td class="small">${h.updated_at}</td>
      <td class="small">${h.note || ''}</td>
      <td><button data-name="${h.name ? escapeHtml(h.name) : ''}" onclick="deleteHolding('${h.symbol}', this.dataset.name)" class="small">删除</button></td>
    </tr>`).join('')}</tbody></table>`;
    makeSortable(tblEl.querySelector('table'));
  } catch (e) {
    renderFetchError(tblEl, e);
  }
}

async function upsertHolding() {
  const symbol = document.getElementById('hold-symbol').value.trim();
  const shares = parseFloat(document.getElementById('hold-shares').value);
  const cost = parseFloat(document.getElementById('hold-cost').value);
  const msgEl = document.getElementById('hold-msg');
  if (!symbol || isNaN(shares)) {
    msgEl.textContent = '需要填代码 + 股数';
    msgEl.style.color = '#f87171';
    return;
  }
  msgEl.textContent = '保存中...';
  try {
    const r = await fetch(`/api/trading/holdings/${symbol}`, {
      method: 'PUT',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({shares, avg_cost: isNaN(cost) ? null : cost}),
    });
    const d = await r.json().catch(() => ({}));
    if (!r.ok) throw new Error(formatErrorDetail(d) || ('HTTP ' + r.status));
    msgEl.textContent = `✓ 已保存 ${symbol}`;
    msgEl.style.color = '#5eead4';
    document.getElementById('hold-symbol').value = '';
    document.getElementById('hold-shares').value = '';
    document.getElementById('hold-cost').value = '';
    // 持仓改了 → 后端已重算 trade_list，前端三处都要刷新
    await loadHoldings();
    loadTradeList();
    loadKpiOverview();
  } catch (e) {
    msgEl.textContent = '保存失败：' + e.message;
    msgEl.style.color = '#f87171';
  }
}

async function deleteHolding(symbol, name) {
  const label = name ? `${symbol} ${name}` : symbol;
  const ok = await confirmDialog(`确定删除持仓 ${label}？`, {
    title: '删除持仓', confirmLabel: '删除', danger: true,
  });
  if (!ok) return;
  try {
    const r = await fetch(`/api/trading/holdings/${symbol}`, {method: 'DELETE'});
    if (!r.ok) {
      const d = await r.json().catch(() => ({}));
      throw new Error(formatErrorDetail(d) || ('HTTP ' + r.status));
    }
    toast(`已删除 ${name ? symbol + ' ' + name : symbol}`, 'ok');
    await loadHoldings();
    loadTradeList();
    loadKpiOverview();
  } catch (e) { toast('删除失败：' + e.message, 'error'); }
}

// ===== P0-2 Forward Track =====================================

async function loadPaperTracking() {
  const sumEl = document.getElementById('paper-summary');
  const tblEl = document.getElementById('paper-cohorts-table');
  const chartEl = document.getElementById('paper-cohorts-chart');
  if (sumEl) sumEl.innerHTML = '<span style="color:#94a3b8">加载中...</span>';

  try {
    const [sumR, listR] = await Promise.all([
      fetch('/api/research/paper-trading/summary'),
      fetch('/api/research/paper-trading/cohorts?limit=200'),
    ]);
    const summary = await sumR.json();
    const list = await listR.json();
    if (summary.n_cohorts === 0) {
      sumEl.innerHTML = '<div class="empty-state"><div class="empty-state-icon">⏳</div><div class="empty-state-title">尚无 paper trading 记录</div><div class="empty-state-hint">明天 daemon 跑完盘后第一次会冻结 cohort，30 天后即有真 OOS 数据</div></div>';
      return;
    }

    const fmt = (v, mult=100) => v == null ? '-' : (v * mult).toFixed(2) + '%';
    const at = (k) => summary[k] || {n: 0};

    sumEl.innerHTML = `
      <div class="kpi-strip" style="margin-bottom:8px">
        <div><span class="small">已冻结 cohort</span><span class="stat-num">${summary.n_cohorts}</span></div>
        <div><span class="small">30 天后均值</span><span class="stat-num ${at('at_30d').mean_return>=0?'metric-good':'metric-bad'}">${fmt(at('at_30d').mean_return)}</span><span class="small">(n=${at('at_30d').n})</span></div>
        <div><span class="small">30 天后超额</span><span class="stat-num ${at('at_30d').mean_excess>=0?'metric-good':'metric-bad'}">${fmt(at('at_30d').mean_excess)}</span></div>
        <div><span class="small">60 天后均值</span><span class="stat-num ${at('at_60d').mean_return>=0?'metric-good':'metric-bad'}">${fmt(at('at_60d').mean_return)}</span><span class="small">(n=${at('at_60d').n})</span></div>
        <div><span class="small">60 天后超额</span><span class="stat-num ${at('at_60d').mean_excess>=0?'metric-good':'metric-bad'}">${fmt(at('at_60d').mean_excess)}</span></div>
        <div><span class="small">90 天后均值</span><span class="stat-num ${at('at_90d').mean_return>=0?'metric-good':'metric-bad'}">${fmt(at('at_90d').mean_return)}</span><span class="small">(n=${at('at_90d').n})</span></div>
        <div><span class="small">90 天后超额</span><span class="stat-num ${at('at_90d').mean_excess>=0?'metric-good':'metric-bad'}">${fmt(at('at_90d').mean_excess)}</span></div>
      </div>
    `;

    // 画散点：x=建仓日，y=最新收益率，颜色按 days_elapsed 编码
    if (typeof echarts !== 'undefined' && list.cohorts && list.cohorts.length) {
      const old = echarts.getInstanceByDom(chartEl);
      if (old) old.dispose();
      const chart = echarts.init(chartEl);
      // 散点: x=建仓日, y=最新收益率, 颜色按"已 N 天"映射（新冻结→暖色, 长期→冷色）
      const data = list.cohorts.filter(c => c.latest_return_pct != null).map(c => ({
        // [建仓日, 收益%, 已N天]; visualMap 需要 dimension=2 才能正确映射颜色
        value: [c.cohort_date, (c.latest_return_pct * 100).toFixed(2), c.days_elapsed || 0],
        excess: c.latest_excess_pct != null ? (c.latest_excess_pct * 100).toFixed(2) : null,
        n: c.n_holdings,
      }));
      chart.setOption({
        backgroundColor: 'transparent',
        tooltip: {
          trigger: 'item',
          formatter: (p) => {
            const d = p.data;
            return `<b>${d.value[0]}</b> 建仓 (${d.value[2]} 天前)<br/>` +
                   `收益: <b style="color:${d.value[1]>=0?'#5eead4':'#f87171'}">${d.value[1]}%</b><br/>` +
                   (d.excess !== null ? `超额: ${d.excess}%<br/>` : '') +
                   `持仓: ${d.n} 只`;
          },
        },
        grid: { left: 60, right: 20, top: 20, bottom: 50 },
        xAxis: {
          type: 'category',
          name: '建仓日',
          axisLine: {lineStyle:{color:'#334155'}},
          axisLabel: {color:'#94a3b8', rotate: 30},
        },
        yAxis: {
          type: 'value',
          name: '截止今日收益率 (%)',
          axisLabel: {color:'#94a3b8', formatter: '{value}%'},
          splitLine: {lineStyle:{color:'#1e293b', type:'dashed'}},
        },
        visualMap: {
          show: false,
          // 必须用数字索引, 不能用字符串字段名. data.value=[建仓日, 收益%, 已N天]
          // dimension=2 → 按"已 N 天"映射颜色 (新冻结=暖色, 长期=冷色)
          dimension: 2,
          min: 0, max: 250,
          inRange: { color: ['#fbbf24', '#5eead4'] },
        },
        series: [{
          type: 'scatter',
          symbolSize: 8,
          data,
        }],
      });
    }

    // 表格列出最近 20 个 cohort
    if (list.cohorts && list.cohorts.length) {
      const recent = list.cohorts.slice(0, 20);
      tblEl.innerHTML = `<table><thead><tr>
        <th>建仓日</th><th>持仓</th><th>已 N 天</th><th>当前收益</th><th>超额 (vs 沪深300)</th>
      </tr></thead><tbody>${recent.map(c => `<tr>
        <td>${c.cohort_date}</td>
        <td>${c.n_holdings}</td>
        <td>${c.days_elapsed != null ? c.days_elapsed : '-'}</td>
        <td class="${c.latest_return_pct>=0?'metric-good':'metric-bad'}">${c.latest_return_pct != null ? (c.latest_return_pct*100).toFixed(2)+'%' : '-'}</td>
        <td class="${c.latest_excess_pct>=0?'metric-good':'metric-bad'}">${c.latest_excess_pct != null ? (c.latest_excess_pct*100).toFixed(2)+'%' : '-'}</td>
      </tr>`).join('')}</tbody></table>`;
      makeSortable(tblEl.querySelector('table'));
    }
  } catch (e) {
    renderFetchError(sumEl, e);
    // 失败时同时清掉 table / dispose chart，避免残留旧数据让用户误以为还是最新
    if (tblEl) tblEl.innerHTML = '';
    if (chartEl && typeof echarts !== 'undefined') {
      const old = echarts.getInstanceByDom(chartEl);
      if (old) old.dispose();
    }
  }
}

// ===== 自动刷新 ============================================
const AUTO_REFRESH_MS = 30000;
const AUTO_REFRESH_KEY = 'research_auto_refresh';
let autoRefreshTimer = null;

function stampRefresh() {
  const el = document.getElementById('last-refresh-ts');
  if (!el) return;
  const d = new Date();
  const pad = (n) => String(n).padStart(2, '0');
  el.textContent = `${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;
}

async function runAutoRefresh() {
  // 因子 IC/IR 不轮询（周日才更新）
  const dateSel = document.getElementById('portfolio-date');
  const tasks = [];
  if (dateSel && dateSel.value) tasks.push(loadPortfolio());
  tasks.push(loadNav());
  tasks.push(loadProposals());
  tasks.push(loadKpiOverview());
  try { await Promise.allSettled(tasks); } catch (e) { /* ignore */ }
  stampRefresh();
}

function setupAutoRefresh() {
  const cb = document.getElementById('auto-refresh');
  if (!cb) return;
  // 反向读 localStorage：默认勾选；只有显式存过 '0' 才不勾
  try {
    if (localStorage.getItem(AUTO_REFRESH_KEY) === '0') cb.checked = false;
  } catch (e) { /* ignore */ }
  applyAutoRefresh(cb.checked);
  cb.addEventListener('change', () => {
    try { localStorage.setItem(AUTO_REFRESH_KEY, cb.checked ? '1' : '0'); } catch (e) { /* ignore */ }
    applyAutoRefresh(cb.checked);
  });
  // 首次加载完成后打一个时间戳
  setTimeout(stampRefresh, 800);
}

function applyAutoRefresh(on) {
  const bar = document.querySelector('.refresh-bar');
  if (autoRefreshTimer) { clearInterval(autoRefreshTimer); autoRefreshTimer = null; }
  if (bar) bar.classList.toggle('is-on', !!on);
  if (on) {
    autoRefreshTimer = setInterval(runAutoRefresh, AUTO_REFRESH_MS);
  }
}

async function loadNav() {
  const chartEl = document.getElementById('nav-chart');
  const summaryEl = document.getElementById('nav-summary');
  const statsEl = document.getElementById('nav-stats');
  summaryEl.textContent = '加载中...';
  try {
    const r = await fetch('/api/research/nav');
    if (!r.ok) { renderFetchError(statsEl, { status: r.status, detail: await r.text() }); summaryEl.textContent = ''; return; }
    const d = await r.json();
    if (!d.nav || !d.nav.length) {
      summaryEl.textContent = '暂无净值数据';
      statsEl.innerHTML = '<p class="small">' + ((d.summary && d.summary.reason) || '需要先在历史 portfolio_snapshots 表里有 2+ 个日期，扣费净值才能算出曲线。') + '</p>';
      return;
    }
    summaryEl.textContent = `${d.nav.length} 个交易日`;
    // 汇总卡片
    const s = d.summary || {};
    const ps = s.paper_summary || {};
    const fmt = (v, suffix='%', mult=100) => v == null ? '-' : (v * mult).toFixed(2) + suffix;
    // M20: paper_start_date 分段 — 之前全是 backfill, 之后才是真 paper trading
    const paperStartDate = s.paper_start_date;
    const paperBlock = (paperStartDate && ps && ps.n_days >= 2) ? `
      <div class="small" style="margin-top:14px;padding:12px;background:rgba(94,234,212,0.05);border-left:3px solid #5eead4;border-radius:6px">
        <div style="color:#5eead4;font-weight:600;margin-bottom:8px">
          ✅ 真实 Paper Trading 段 (forward-only, ${paperStartDate} 起 · ${ps.n_days} 天)
        </div>
        <div class="kpi-strip" style="margin-bottom:0">
          <div class="kpi"><span class="lbl">累计收益</span><span class="val ${(ps.total_return_net||0)>=0?'metric-good':'metric-bad'}">${fmt(ps.total_return_net)}</span></div>
          <div class="kpi"><span class="lbl">年化收益</span><span class="val">${fmt(ps.annualized_return_net)}</span></div>
          <div class="kpi"><span class="lbl">夏普</span><span class="val">${ps.sharpe_net != null ? ps.sharpe_net.toFixed(2) : '—'}</span></div>
          <div class="kpi"><span class="lbl">最大回撤</span><span class="val metric-bad">${fmt(ps.max_drawdown)}</span></div>
          <div class="kpi"><span class="lbl">超额收益</span><span class="val ${(ps.excess_return||0)>=0?'metric-good':'metric-bad'}">${fmt(ps.excess_return)}</span></div>
        </div>
        ${ps.n_days < 60 ? `<div class="small" style="color:#fbbf24;margin-top:8px">⚠️ paper 段只有 ${ps.n_days} 天, 任何统计推断都不显著 (Sharpe 需要 60+ 天才有参考价值)</div>` : ''}
      </div>` : '';

    statsEl.innerHTML = `
      ${paperBlock}
      <div class="small" style="margin-top:14px;color:#94a3b8">
        📊 全段统计 (含 backfill, ${s.n_days || d.nav.length} 天 · 仅参考):
      </div>
      <div class="kpi-strip" style="opacity:0.75">
        <div class="kpi"><span class="lbl">累计收益（扣费）</span><span class="val ${(s.total_return_net||0)>=0?'metric-good':'metric-bad'}">${fmt(s.total_return_net)}</span></div>
        <div class="kpi"><span class="lbl">年化收益</span><span class="val">${fmt(s.annualized_return_net)}</span></div>
        <div class="kpi"><span class="lbl">夏普比率</span><span class="val">${s.sharpe_net != null ? s.sharpe_net.toFixed(2) : '—'}</span></div>
        <div class="kpi"><span class="lbl">最大回撤</span><span class="val metric-bad">${fmt(s.max_drawdown)}</span></div>
        <div class="kpi"><span class="lbl">沪深300 累计</span><span class="val">${fmt(s.benchmark_total_return)}</span></div>
        <div class="kpi" title="${s.excess_aligned_to ? '同步对齐至 '+s.excess_aligned_to+' (benchmark 最末有效日)' : ''}"><span class="lbl">超额收益${s.excess_aligned_to ? ' <span style="color:var(--fg-dim);font-weight:400">(对齐 '+s.excess_aligned_to.slice(5)+')</span>' : ''}</span><span class="val ${(s.excess_return||0)>=0?'metric-good':'metric-bad'}">${fmt(s.excess_return)}</span></div>
        <div class="kpi"><span class="lbl">累计成本</span><span class="val">${fmt(s.total_cost)}</span></div>
        <div class="kpi"><span class="lbl">平均换手</span><span class="val">${fmt(s.avg_turnover_per_rebalance)}</span></div>
      </div>
      ${s.disclaimer ? `<div class="small" style="margin-top:8px;color:#fbbf24;line-height:1.6">${s.disclaimer}</div>` : ''}
      <div class="small" style="margin-top:8px;color:var(--fg-dim);line-height:1.6">
        ⚠️ <b>回测口径披露</b>: 历史 OHLCV 仅含<b>当前在交易</b>的 ~5500 只股票 (akshare 默认接口),
        不含 2025-09 至今约 30-50 只退市股. 这部分 survivorship bias 估算贡献 +15-25% 假超额,
        真 alpha 约为显示数字的 1/3 至 1/2. 详见 README "当前限制" 段.
      </div>
    `;
    if (typeof echarts === 'undefined') return;
    const chart = echarts.init(chartEl);
    const dates = d.nav.map(p => p.date);
    const navNet = d.nav.map(p => p.nav_net);
    const benchNav = d.nav.map(p => p.benchmark_nav);
    // M20: paper_start_date 之前是 backfill 段, 用更暗的灰色显示提醒用户;
    // 之后才是真实 paper trading 段, 用主色
    const navBackfill = paperStartDate
      ? d.nav.map(p => p.date < paperStartDate ? p.nav_net : null)
      : navNet;
    const navPaper = paperStartDate
      ? d.nav.map(p => p.date >= paperStartDate ? p.nav_net : null)
      : null;
    // 计算从 peak 起的回撤（用于阴影区）：相对于历史最高净值的偏离
    let peak = -Infinity;
    const ddArea = navNet.map(v => {
      if (v == null) return null;
      peak = Math.max(peak, v);
      return peak > 0 ? (v - peak) : null;  // 负数或 0
    });
    // 标记最大回撤位置
    let mddIdx = 0, mddVal = 0;
    ddArea.forEach((v, i) => { if (v != null && v < mddVal) { mddVal = v; mddIdx = i; } });
    chart.setOption({
      backgroundColor: 'transparent',
      textStyle: { color: '#aab2c5', fontFamily: 'inherit' },
      tooltip: {
        trigger: 'axis',
        backgroundColor: 'rgba(17,20,27,0.95)',
        borderColor: '#2e3648',
        textStyle: { color: '#e6e9f0', fontSize: 12 },
        axisPointer: { lineStyle: { color: '#5eead4', opacity: 0.5 } },
      },
      legend: {
        data: paperStartDate ? ['回测段', '真实 Paper', '沪深300', '回撤区'] : ['组合（扣费）', '沪深300', '回撤区'],
        textStyle: { color: '#aab2c5' },
        right: 10, top: 0,
      },
      xAxis: {
        type: 'category', data: dates,
        axisLine: { lineStyle: { color: '#2e3648' } },
        axisLabel: { color: '#6b748a', fontSize: 10 },
        splitLine: { show: false },
      },
      yAxis: [{
        type: 'value', scale: true,
        axisLine: { show: false },
        axisLabel: { color: '#6b748a', fontSize: 10 },
        splitLine: { lineStyle: { color: '#232936', type: 'dashed' } },
      }, {
        type: 'value', position: 'right', show: false, min: -1, max: 0,
      }],
      grid: { left: 56, right: 28, top: 36, bottom: 36 },
      series: [
        paperStartDate ? {
          // M20: backfill 段 — 灰色 + dashed 提醒用户这是回填的, 不是真赚的
          name: '回测段', type: 'line', smooth: true, showSymbol: false,
          lineStyle: { color: '#6b748a', width: 1.5, type: 'dashed' },
          itemStyle: { color: '#6b748a' },
          data: navBackfill,
        } : {
          name: '组合（扣费）', type: 'line', smooth: true, showSymbol: false,
          lineStyle: { color: '#5eead4', width: 2 },
          itemStyle: { color: '#5eead4' },
          areaStyle: {
            color: {
              type: 'linear', x: 0, y: 0, x2: 0, y2: 1,
              colorStops: [
                { offset: 0, color: 'rgba(94,234,212,0.22)' },
                { offset: 1, color: 'rgba(94,234,212,0)' },
              ],
            },
          },
          data: navNet,
          markPoint: mddIdx > 0 ? {
            symbol: 'pin', symbolSize: 36,
            itemStyle: { color: 'rgba(248,113,113,0.85)' },
            label: { color: '#fff', fontSize: 10 },
            data: [{ coord: [mddIdx, navNet[mddIdx]], value: '最大回撤' }],
          } : undefined,
        },
        // M20: 真 paper trading 段 — 主色, 带 markLine 标记起点
        ...(paperStartDate ? [{
          name: '真实 Paper', type: 'line', smooth: true, showSymbol: false,
          lineStyle: { color: '#5eead4', width: 2.5 },
          itemStyle: { color: '#5eead4' },
          areaStyle: {
            color: {
              type: 'linear', x: 0, y: 0, x2: 0, y2: 1,
              colorStops: [
                { offset: 0, color: 'rgba(94,234,212,0.22)' },
                { offset: 1, color: 'rgba(94,234,212,0)' },
              ],
            },
          },
          data: navPaper,
          markLine: {
            silent: true,
            symbol: 'none',
            lineStyle: { color: '#5eead4', type: 'dashed', width: 1.5, opacity: 0.7 },
            label: {
              color: '#5eead4', fontSize: 11, fontWeight: 600,
              position: 'insideEndTop', formatter: '↓ Paper 起点',
            },
            data: [{ xAxis: paperStartDate }],
          },
        }] : []),
        {
          name: '沪深300', type: 'line', smooth: true, showSymbol: false,
          lineStyle: { color: '#60a5fa', width: 1.5, type: 'dashed' },
          itemStyle: { color: '#60a5fa' },
          data: benchNav,
        },
        {
          name: '回撤区', type: 'line', yAxisIndex: 1, smooth: true, showSymbol: false,
          lineStyle: { width: 0 },
          areaStyle: { color: 'rgba(248,113,113,0.10)', origin: 'start' },
          itemStyle: { color: 'rgba(248,113,113,0.4)' },
          data: ddArea,
          z: -1,
        },
      ],
    });
  } catch (e) { renderFetchError(statsEl, e); summaryEl.textContent = ''; }
}

async function rebuildNav(btn) {
  await runLongOperation({
    button: btn || document.getElementById('btn-rebuild-nav'),
    url: '/api/research/nav/rebuild',
    statusEl: document.getElementById('nav-summary'),
    runningMessage: '重新计算净值',
    successMessage: '已重新计算，正在重载曲线',
    // portfolio.nav_rebuild 是异步 daemon job: trigger 立即 202, 不能入队即当完成.
    // 用 result_poll_url 轮询, daemon 写完 result(status=ok)再重载曲线, 否则看到旧净值。
    pollUrlFromResponse: (d) => (d && d.payload && d.payload.result_poll_url) || null,
    pollInterval: 2500,
    pollTimeout: 180000,
    pollIsDone: (d) => d && (d.status === 'ok' || d.status === 'not_found'),
    onSuccess: () => { loadNav(); loadKpiOverview(); },
    onError: () => { loadNav(); loadKpiOverview(); },
  });
}

async function loadProposals() {
  const status = document.getElementById('proposal-status').value;
  const url = '/api/research/proposals?limit=50' + (status ? '&status=' + status : '');
  const tableEl = document.getElementById('proposals-table');
  const countsEl = document.getElementById('proposal-counts');
  tableEl.innerHTML = '<div class="loading-skeleton">读取候选因子流水…</div>';
  try {
    const r = await fetch(url);
    if (!r.ok) { tableEl.innerHTML = '<div class="empty-state"><span class="em">!</span><div class="em-title">加载失败</div></div>'; return; }
    const d = await r.json();
    const counts = d.counts || {};
    const cnMap = { accepted: '已采纳', shadow: '观察中', rejected: '已淘汰', pending: '待评估', demoted: '未通过 OOS' };
    countsEl.textContent = ' ［' + Object.entries(counts).map(([k,v]) => `${cnMap[k]||k}=${v}`).join(' ／ ') + '］';
    if (!d.rows || !d.rows.length) {
      tableEl.innerHTML = '<div class="empty-state"><span class="em">∅</span><div class="em-title">还没有候选因子</div><div class="em-hint">点击右上「立即跑一轮发现」让 AI 自动生成 20 个新因子配方，大约 30~120 秒后会出现在这里。</div></div>';
      return;
    }
    tableEl.innerHTML = `<table><thead><tr>
      <th><abbr title="自动生成的因子名（仅作 ID，不必看懂）">因子名</abbr></th>
      <th>状态</th>
      <th><abbr title="IR = Information Ratio（信息比率），衡量因子预测稳定性，越大越好（>0.3 算良好）">IR</abbr></th>
      <th><abbr title="IC = Information Coefficient（信息系数），衡量因子值与未来收益的相关性，越大越好（>0.03 算良好）">IC</abbr></th>
      <th><abbr title="t 统计量，衡量 IC 的显著性，绝对值 >2 一般算显著">t 统计量</abbr></th>
      <th><abbr title="该因子与现有因子的最大相关系数绝对值；越低代表越有新意">最大相关性</abbr></th>
      <th>评估结论</th>
      <th><abbr title="recipe：因子配方 — DSL 因子=算子(基础数据, 窗口, 方向); code 因子=LLM 自由 Python + 描述">配方</abbr></th>
      <th>评估时间</th>
    </tr></thead><tbody>${d.rows.map(r => {
      const recipe = r.recipe || {};
      const statusText = cnMap[r.status] || r.status;
      const rowClass = r.status === 'accepted' ? 'row-accepted' :
                       (r.status === 'shadow' ? 'row-pending' :
                       (r.status === 'rejected' || r.status === 'demoted' ? 'row-rejected' : ''));
      const statusColor = r.status === 'accepted' ? 'ok' :
                          (r.status === 'shadow' ? 'warning' : 'error');
      // shadow 状态的 OOS 进度条（假设 21 天为通过门槛）
      const OOS_TARGET = 21;
      let oosText = '';
      if (r.status === 'shadow' && r.oos_observations != null) {
        const pct = Math.min(100, (r.oos_observations / OOS_TARGET) * 100);
        oosText = ` <span class="oos-progress" title="OOS 验证进度：${r.oos_observations} / ${OOS_TARGET} 天">
          <span class="bar"><i style="width:${pct.toFixed(0)}%"></i></span>
          <span class="lbl">${r.oos_observations}/${OOS_TARGET}d</span>
        </span>`;
      }
      // 配方渲染: DSL 因子有 base/op/window/direction; code 因子只有 description + direction.
      // 用 recipe_kind (后端已透出) 判定; 兜底再看字段是否齐全, 避免出现 "undefined/undefined/wundefined".
      const dirCn = cnOf(DIR_CN, recipe.direction);
      let recipeCell;
      const isCode = r.recipe_kind === 'code'
        || (r.factor_name && r.factor_name.startsWith('code_'))
        || recipe.description != null
        || !(recipe.base && recipe.op && recipe.window != null);
      if (isCode) {
        const desc = (recipe.description || '').trim() || '(无描述)';
        const short = desc.length > 60 ? desc.slice(0, 60) + '…' : desc;
        recipeCell = `<td class="small" title="${escapeHtml(desc)}">
          <span class="pill" style="background:var(--brand-mute,#334);color:var(--fg-mute);margin-right:6px">code</span>${escapeHtml(short)}（${dirCn}）
        </td>`;
      } else {
        const opCn  = cnOf(OP_CN,  recipe.op);
        const baseCn = cnOf(BASE_CN, recipe.base);
        recipeCell = `<td class="small" title="原始 recipe: ${recipe.op}(${recipe.base}, w=${recipe.window}, ${recipe.direction})">
          ${opCn}（${baseCn}，窗口 ${recipe.window} 天，${dirCn}）
        </td>`;
      }
      return `<tr class="${rowClass} is-clickable" onclick="openProposalModal('${r.factor_name}')" title="点击查看推理详情（IS / 相关性 / OOS 决策路径）">
      <td><code>${r.factor_name}</code></td>
      <td><span class="status-${statusColor}">${statusText}</span>${oosText}</td>
      <td>${r.ir != null ? r.ir.toFixed(3) : '—'}</td>
      <td>${r.ic_mean != null ? r.ic_mean.toFixed(4) : '—'}</td>
      <td>${r.t_stat != null ? r.t_stat.toFixed(2) : '—'}</td>
      <td>${r.max_abs_corr != null ? r.max_abs_corr.toFixed(2) : '—'}</td>
      <td>${r.reason || '—'}</td>
      ${recipeCell}
      <td class="small">${r.evaluated_at || r.created_at}</td>
    </tr>`;}).join('')}</tbody></table>`;
    makeSortable(tableEl.querySelector('table'));
  } catch (e) { renderFetchError(tableEl, e); }
}

async function runDiscovery() {
  const tableEl = document.getElementById('proposals-table');
  tableEl.innerHTML = '<div class="loading-skeleton">AI 生成 20 个新因子配方并回测中…（30~120 秒）</div>';
  await runLongOperation({
    button: document.getElementById('btn-discovery'),
    url: '/api/control/jobs/factor.discovery/trigger?n_candidates=20',
    statusEl: document.getElementById('discovery-status'),
    runningMessage: 'AI 因子发现中',
    successMessage: '完成，列表已刷新',
    // factor.discovery 是异步 daemon job: trigger 只入队立即 202, daemon 5s 内 pick 起来跑 30~120s.
    // 从 trigger 响应派生 job 状态轮询地址, 等 daemon 真跑完(status=ok/failed)再刷新列表,
    // 否则\"入队即当完成\"会在因子还没生产出来时就刷新, 看到的是上一轮旧数据(误导).
    pollUrlFromResponse: (d) => (d && d.payload && d.payload.poll_url) || null,
    pollInterval: 3000,
    pollTimeout: 180000,
    pollIsDone: (d) => d && (d.status === 'ok' || d.status === 'failed' || d.status === 'error'),
    onSuccess: (d) => {
      const el = document.getElementById('discovery-status');
      if (d && (d.status === 'failed' || d.status === 'error')) {
        if (el) { el.classList.remove('status-ok'); el.classList.add('status-error'); el.innerHTML = '❌ 发现任务失败，请查看运维页 job-runs'; }
      } else if (el && d && d.payload) {
        // 从 job-runs detail 的 payload 读本轮 stats, 明确告诉用户"这一轮"到底产出了什么,
        // 而不是让用户在 50 条历史里猜哪几条是刚跑的.
        const p = d.payload;
        const proposed = p.proposed != null ? p.proposed : '?';
        const accepted = p.accepted != null ? p.accepted : 0;
        const dup = p.duplicates_skipped != null ? p.duplicates_skipped : 0;
        const left = p.unexplored_remaining;
        let msg;
        if (accepted > 0) {
          msg = `✅ 本轮新增 <b>${accepted} 个观察因子</b>（试了 ${proposed} 个配方）。它们进入 SHADOW 池做 OOS 验证，若约 20 天后表现稳定将自动进入组合。`;
        } else {
          msg = `✅ 本轮试了 ${proposed} 个新配方，<b>没有通过门槛的</b>（预测力/稳定性/相关性未达标，属正常）。组合不变。`;
        }
        if (dup > 0) msg += ` 另跳过 ${dup} 个已探索配方。`;
        if (left != null) msg += ` 搜索空间还剩 ${left} 个未探索。`;
        el.classList.remove('status-error'); el.classList.add('status-ok');
        el.innerHTML = msg;
      }
      loadProposals();
    },
    onError: () => loadProposals(),
  });
}

// ============================================================
// M11：因子推理详情 Modal
// ============================================================
const PROP_STATUS_CN = {
  accepted: '已采纳', shadow: '观察中', rejected: '已淘汰',
  pending: '待评估', demoted: '未通过 OOS',
};
const PROP_BADGE_CLS = {
  accepted: 'b-accepted', shadow: 'b-shadow', rejected: 'b-rejected',
  pending: 'b-pending', demoted: 'b-demoted',
};
let _traceChart = null;

async function openProposalModal(factorName) {
  const modal = document.getElementById('proposal-modal');
  const titleEl = document.getElementById('proposal-modal-title');
  const badgeEl = document.getElementById('proposal-modal-badge');
  const bodyEl = document.getElementById('proposal-modal-body');
  titleEl.textContent = factorName;
  badgeEl.className = 'badge b-unknown';
  badgeEl.querySelector('.text').textContent = '加载中…';
  bodyEl.innerHTML = '<div class="loading-skeleton">读取因子推理详情…</div>';
  modal.classList.remove('hidden');
  document.body.style.overflow = 'hidden';
  try {
    const r = await fetch(`/api/research/proposals/${encodeURIComponent(factorName)}/trace`);
    if (!r.ok) throw new Error('HTTP ' + r.status);
    const d = await r.json();
    if (d.error) throw new Error(d.error);
    renderTraceModal(d, titleEl, badgeEl, bodyEl);
  } catch (e) {
    bodyEl.innerHTML = `<div class="empty-state"><span class="em">!</span><div class="em-title">加载失败</div><div class="em-hint">${escapeHtml(e.message || e)}</div></div>`;
  }
}

function renderTraceModal(d, titleEl, badgeEl, bodyEl) {
  const statusCn = PROP_STATUS_CN[d.status] || d.status;
  const badgeCls = PROP_BADGE_CLS[d.status] || 'b-unknown';
  titleEl.textContent = d.factor_name;
  badgeEl.className = 'badge ' + badgeCls;
  badgeEl.querySelector('.text').textContent = statusCn;

  // 决策路径
  const decisions = d.decisions || [];
  const decisionsHtml = decisions.length
    ? `<div class="trace-timeline">${decisions.map(renderDecision).join('')}</div>`
    : '<div class="small" style="color:var(--fg-dim)">尚无决策路径记录</div>';

  // 核心指标
  const m = d.metrics || {};
  const num = (v, dec=3) => v == null ? '—' : Number(v).toFixed(dec);
  const cls = (v, good=0) => v == null ? 'dim' : (v >= good ? 'pos' : 'neg');
  const metricCards = [
    { lbl: 'IC（信息系数）', val: num(m.ic_mean, 4), cls: cls(m.ic_mean) },
    { lbl: 'IR（信息比率）', val: num(m.ir, 3), cls: cls(m.ir) },
    { lbl: 't 统计量', val: num(m.t_stat, 2), cls: 'dim' },
    { lbl: 'IC 波动率', val: num(m.ic_std, 4), cls: 'dim' },
    { lbl: '最大相关性', val: num(m.max_abs_corr, 3), cls: 'dim' },
    { lbl: 'OOS IR', val: num(m.oos_ir, 3), cls: cls(m.oos_ir) },
    { lbl: 'OOS 观察天数', val: m.oos_observations != null ? m.oos_observations + ' 天' : '—', cls: 'dim' },
  ].map(c => `<div class="m"><div class="lbl">${c.lbl}</div><div class="val ${c.cls}">${c.val}</div></div>`).join('');

  // 历史曲线占位
  const hasHistory = d.metrics_history && d.metrics_history.length >= 2;
  const historyHtml = hasHistory
    ? `<div id="trace-history-chart" class="trace-history"></div>`
    : '<div class="small" style="color:var(--fg-dim)">暂无历史评估数据（需要 ≥2 条 factor_metrics 记录才能画 IR 时序）</div>';

  // 配方
  const recipeJson = escapeHtml(JSON.stringify(d.recipe || {}, null, 2));

  bodyEl.innerHTML = `
    <div class="modal-section">
      <h3>配方 / Recipe</h3>
      <div class="plain">${escapeHtml(d.plain_description || '—')}</div>
      <details><summary>原始 recipe JSON</summary><pre>${recipeJson}</pre></details>
    </div>

    <div class="modal-section">
      <h3>决策路径 / Decisions</h3>
      ${decisionsHtml}
      ${d.reason ? `<div class="small" style="color:var(--fg-mute);margin-top:4px;">评估结论：<code>${escapeHtml(d.reason)}</code></div>` : ''}
    </div>

    <div class="modal-section">
      <h3>核心指标 / Metrics</h3>
      <div class="metric-grid">${metricCards}</div>
    </div>

    <div class="modal-section">
      <h3>历史评估 / Metrics History</h3>
      ${historyHtml}
    </div>
  `;

  // 销毁前一个 chart
  if (_traceChart) { try { _traceChart.dispose(); } catch (e) {} _traceChart = null; }
  if (hasHistory && typeof echarts !== 'undefined') {
    // 后端按 limit desc 返，转正序
    const rows = d.metrics_history.slice().reverse();
    _traceChart = echarts.init(document.getElementById('trace-history-chart'));
    _traceChart.setOption({
      backgroundColor: 'transparent',
      textStyle: { color: '#aab2c5', fontFamily: 'inherit' },
      tooltip: {
        trigger: 'axis',
        backgroundColor: 'rgba(17,20,27,0.95)',
        borderColor: '#2e3648',
        textStyle: { color: '#e6e9f0' },
      },
      legend: { textStyle: { color: '#aab2c5', fontSize: 11 }, right: 8, top: 0 },
      grid: { left: 44, right: 18, top: 26, bottom: 24 },
      xAxis: {
        type: 'category',
        data: rows.map(r => r.as_of_date),
        axisLine: { lineStyle: { color: '#2e3648' } },
        axisLabel: { color: '#6b748a', fontSize: 10 },
      },
      yAxis: {
        type: 'value', scale: true,
        axisLine: { show: false },
        axisLabel: { color: '#6b748a', fontSize: 10 },
        splitLine: { lineStyle: { color: '#232936', type: 'dashed' } },
      },
      series: [
        { name: 'IR', type: 'line', smooth: true, showSymbol: false,
          lineStyle: { color: '#5eead4', width: 2 }, itemStyle: { color: '#5eead4' },
          areaStyle: { color: 'rgba(94,234,212,0.10)' },
          data: rows.map(r => r.ir) },
        { name: 'IC', type: 'line', smooth: true, showSymbol: false,
          lineStyle: { color: '#60a5fa', width: 1.5, type: 'dashed' }, itemStyle: { color: '#60a5fa' },
          data: rows.map(r => r.ic_mean) },
      ],
    });
  }
}

function renderDecision(dec) {
  const pass = dec.pass === true;
  const fail = dec.pass === false;
  const cls = pass ? 'pass' : (fail ? 'fail' : 'info');
  const icon = pass ? '✅' : (fail ? '❌' : 'ℹ');
  return `
    <div class="trace-step ${cls}">
      <div class="icon ${cls}">${icon}</div>
      <div class="body">
        <div class="step-name">${escapeHtml(dec.step || '')}</div>
        <div class="step-result">${escapeHtml(dec.result || '')}</div>
      </div>
      ${dec.threshold ? `<div class="threshold">${escapeHtml(dec.threshold)}</div>` : '<div></div>'}
    </div>
  `;
}

function closeProposalModal() {
  const modal = document.getElementById('proposal-modal');
  modal.classList.add('hidden');
  document.body.style.overflow = '';
  if (_traceChart) { try { _traceChart.dispose(); } catch (e) {} _traceChart = null; }
}
function closeProposalModalOnBackdrop(evt) {
  if (evt.target && evt.target.id === 'proposal-modal') closeProposalModal();
}
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    const m = document.getElementById('proposal-modal');
    if (m && !m.classList.contains('hidden')) closeProposalModal();
  }
});
</script>
{% endblock %}
