async function loadFactor() {
  const name = document.getElementById('factor-name').value;
  if (!name) return;
  const tableEl = document.getElementById('factor-table');
  tableEl.innerHTML = '<div class="loading-skeleton">读取因子表现…</div>';
  try {
    const r = await fetch(`/api/research/factors/${name}/metrics?limit=120`);
    if (!r.ok) { renderFetchError(tableEl, { status: r.status, detail: await r.text() }); return; }
    const d = await r.json();
    if (!d.metrics || !d.metrics.length) {
      tableEl.innerHTML = '<p class="small">暂无表现数据。请先到「运维」页点【重算因子表现（IC / IR）】跑一次。</p>';
      return;
    }
    tableEl.innerHTML = `<p class="small">共 ${d.n} 条记录（按版本与日期倒序）</p>`;
    if (typeof echarts === 'undefined') return;
    const chart = echarts.init(document.getElementById('ic-chart'));
    // 按 factor_version 分组；d.metrics 后端按日期 DESC 给的，先收集再 reverse 转 ASC
    const groups = {};
    d.metrics.forEach(m => {
      const k = `v${m.factor_version}`;
      if (!groups[k]) groups[k] = { dates: [], irs: [], ics: [] };
      groups[k].dates.push(m.as_of_date);
      groups[k].irs.push(m.ir);
      groups[k].ics.push(m.ic_mean);
    });
    // 反转为 ASC 与 xAxis 顺序对齐（之前 xAxis 单独 reverse 但 series 没 reverse，导致曲线和日期错位）
    Object.values(groups).forEach(g => {
      g.dates.reverse(); g.irs.reverse(); g.ics.reverse();
    });
    // 用所有版本的日期并集做 x 轴（多版本时间段不完全重叠），用 dates 数组对齐
    const allDatesSet = new Set();
    Object.values(groups).forEach(g => g.dates.forEach(d => allDatesSet.add(d)));
    const allDates = Array.from(allDatesSet).sort();
    const series = [];
    const palette = ['#5eead4', '#60a5fa', '#fbbf24', '#a78bfa', '#34d399', '#fb923c'];
    let ci = 0;
    Object.entries(groups).forEach(([k, g]) => {
      // 按 allDates 重新对齐：缺失填 null（echarts 会断线）
      const dateToIr = new Map(g.dates.map((d, i) => [d, g.irs[i]]));
      const dateToIc = new Map(g.dates.map((d, i) => [d, g.ics[i]]));
      const irsAligned = allDates.map(d => dateToIr.has(d) ? dateToIr.get(d) : null);
      const icsAligned = allDates.map(d => dateToIc.has(d) ? dateToIc.get(d) : null);
      const c1 = palette[ci % palette.length]; ci++;
      const c2 = palette[ci % palette.length]; ci++;
      series.push({ name: `IR（信息比率）${k}`, type: 'line', smooth: true, showSymbol: false,
                    lineStyle: { color: c1, width: 2 }, itemStyle: { color: c1 }, data: irsAligned });
      series.push({ name: `IC（信息系数）${k}`, type: 'line', smooth: true, showSymbol: false,
                    lineStyle: { color: c2, width: 1.5, type: 'dashed' }, itemStyle: { color: c2 }, data: icsAligned });
    });
    chart.setOption({
      backgroundColor: 'transparent',
      textStyle: { color: '#aab2c5', fontFamily: 'inherit' },
      title: { text: `${name} 的 IC / IR 曲线`, left: 14, top: 10, textStyle: { color: '#e6e9f0', fontSize: 13, fontWeight: 600 } },
      tooltip: {
        trigger: 'axis',
        backgroundColor: 'rgba(17,20,27,0.95)',
        borderColor: '#2e3648',
        textStyle: { color: '#e6e9f0' },
      },
      legend: { textStyle: { color: '#aab2c5' }, right: 10, top: 8 },
      grid: { left: 50, right: 24, top: 44, bottom: 32 },
      xAxis: {
        type: 'category',
        data: allDates,
        axisLabel: { color: '#6b748a', fontSize: 10 },
        axisLine: { lineStyle: { color: '#2e3648' } },
      },
      yAxis: {
        type: 'value',
        axisLabel: { color: '#6b748a', fontSize: 10 },
        axisLine: { show: false },
        splitLine: { lineStyle: { color: '#232936', type: 'dashed' } },
      },
      series: series,
    });
  } catch (e) { renderFetchError(tableEl, e); }
}

// M19: 单因子组合回测 — 选一个因子, 单独跑 top 50 等权组合, 看 NAV vs 沪深300
async function backtestSingleFactor() {
  const name = document.getElementById('factor-name').value;
  if (!name) return;
  const sumEl = document.getElementById('single-factor-nav-summary');
  const chartEl = document.getElementById('single-factor-nav-chart');
  sumEl.textContent = `正在回测 ${name} (top 50 等权, 每 5 天 rebalance, 90 天历史)…已入队，后台计算中…`;
  chartEl.style.display = 'none';
  try {
    // factor.backtest_single 是异步 daemon job: 90 天因子 history + backtest 重 CPU, web 只入队立即 202.
    // 之前前端仍按老的同步返回结构解析(d.ok/d.summary/d.nav), 但异步端点返回的是
    // {status:accepted, payload:{result_poll_url}}, 导致 d.ok=undefined → 永远显示"无结果", 功能失效.
    // 现在: 入队 → 轮询 result_poll_url → 拿到 result(daemon 写完)再渲染.
    const tr = await fetch(`/api/research/factors/${encodeURIComponent(name)}/backtest-single?days=90&rebalance_step=5&top_n=50`, {method: 'POST'});
    const td = await tr.json();
    if (!tr.ok) {
      sumEl.innerHTML = `<span style="color:#fb7185">回测触发失败 (HTTP ${tr.status}): ${formatErrorDetail(td)}</span>`;
      return;
    }
    const pollUrl = td.payload && td.payload.result_poll_url;
    if (!pollUrl) {
      sumEl.innerHTML = `<span style="color:#fbbf24">回测未返回轮询地址，无法获取结果</span>`;
      return;
    }
    // 轮询 result: 最多 ~180 秒 (每 3s 一次)。status=running 继续, ok 结束(再看 result.ok), not_found 报错。
    const started = Date.now();
    const maxMs = 180000;
    let d = null;
    while (Date.now() - started < maxMs) {
      await new Promise(res => setTimeout(res, 3000));
      let pd;
      try {
        const pr = await fetch(pollUrl);
        pd = await pr.json();
      } catch (e) { continue; }  // 网络抖动, 下一轮再试
      if (pd.status === 'running') { const sec = Math.floor((Date.now()-started)/1000); sumEl.textContent = `后台回测 ${name} 中… ${sec}s`; continue; }
      if (pd.status === 'not_found') { sumEl.innerHTML = `<span style="color:#fb7185">回测任务丢失，请重试</span>`; return; }
      if (pd.status === 'ok') { d = pd.result || {}; break; }
    }
    if (d === null) { sumEl.innerHTML = `<span style="color:#fbbf24">回测超时，请稍后在因子详情重试</span>`; return; }
    if (!d.ok) {
      sumEl.innerHTML = `<span style="color:#fbbf24">回测无结果: ${d.reason || d.error || 'unknown'}</span>`;
      return;
    }
    // 1) summary 卡片
    const s = d.summary || {};
    const fmtPct = v => v == null ? '—' : (v * 100).toFixed(2) + '%';
    const fmt = (v, n=2) => v == null ? '—' : Number(v).toFixed(n);
    sumEl.innerHTML = `
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;background:rgba(94,234,212,0.05);padding:10px;border-radius:6px;border:1px solid rgba(94,234,212,0.2)">
        <div><span style="color:#94a3b8">回测天数</span><br/><b>${s.n_days || 0}</b></div>
        <div><span style="color:#94a3b8">累计收益(net)</span><br/><b style="color:${(s.total_return_net||0) >= 0 ? '#34d399' : '#fb7185'}">${fmtPct(s.total_return_net)}</b></div>
        <div><span style="color:#94a3b8">年化收益</span><br/><b style="color:${(s.annualized_return_net||0) >= 0 ? '#34d399' : '#fb7185'}">${fmtPct(s.annualized_return_net)}</b></div>
        <div><span style="color:#94a3b8">Sharpe</span><br/><b>${fmt(s.sharpe_net)}</b></div>
        <div><span style="color:#94a3b8">最大回撤</span><br/><b style="color:#fb7185">${fmtPct(s.max_drawdown)}</b></div>
        <div><span style="color:#94a3b8">vs HS300 超额</span><br/><b style="color:${(s.excess_return||0) >= 0 ? '#34d399' : '#fb7185'}">${fmtPct(s.excess_return)}</b></div>
        <div><span style="color:#94a3b8">换手率(均)</span><br/><b>${fmtPct(s.avg_turnover_per_rebalance)}</b></div>
        <div><span style="color:#94a3b8">总成本</span><br/><b style="color:#94a3b8">${fmtPct(s.total_cost)}</b></div>
      </div>
      <div style="color:#6b748a;margin-top:6px;font-size:11px">
        配置: ${d.config.n_rebalances} 次 rebalance · top ${d.config.top_n} 等权 · direction=${d.direction} · 不行业中性, 不 IR 加权 (裸信号)
        ${s.excess_aligned_to ? ` · 超额对齐到 ${s.excess_aligned_to}` : ''}
      </div>
    `;
    // 2) NAV 曲线
    if (typeof echarts === 'undefined') return;
    chartEl.style.display = '';
    chartEl.style.height = '320px';
    const chart = echarts.init(chartEl);
    const dates = d.nav.map(r => r.as_of_date);
    const navNet = d.nav.map(r => r.nav_net);
    const navGross = d.nav.map(r => r.nav_gross);
    const benchNav = d.nav.map(r => r.benchmark_nav);
    chart.setOption({
      backgroundColor: 'transparent',
      textStyle: { color: '#aab2c5', fontFamily: 'inherit' },
      title: { text: `${name} 单因子组合 NAV (扣费 net vs 毛 gross vs 沪深300)`, left: 14, top: 10,
               textStyle: { color: '#e6e9f0', fontSize: 13, fontWeight: 600 } },
      tooltip: { trigger: 'axis', backgroundColor: 'rgba(17,20,27,0.95)',
                 borderColor: '#2e3648', textStyle: { color: '#e6e9f0' } },
      legend: { textStyle: { color: '#aab2c5' }, right: 10, top: 8 },
      grid: { left: 50, right: 24, top: 50, bottom: 36 },
      xAxis: { type: 'category', data: dates,
               axisLabel: { color: '#6b748a', fontSize: 10 },
               axisLine: { lineStyle: { color: '#2e3648' } } },
      yAxis: { type: 'value', axisLabel: { color: '#6b748a', fontSize: 10 },
               axisLine: { show: false },
               splitLine: { lineStyle: { color: '#232936', type: 'dashed' } } },
      series: [
        { name: 'NAV (净)', type: 'line', smooth: true, showSymbol: false,
          lineStyle: { color: '#5eead4', width: 2.5 }, itemStyle: { color: '#5eead4' }, data: navNet },
        { name: 'NAV (毛)', type: 'line', smooth: true, showSymbol: false,
          lineStyle: { color: '#60a5fa', width: 1.2, type: 'dashed' }, itemStyle: { color: '#60a5fa' }, data: navGross },
        { name: '沪深300', type: 'line', smooth: true, showSymbol: false,
          lineStyle: { color: '#fbbf24', width: 1.5 }, itemStyle: { color: '#fbbf24' }, data: benchNav },
      ],
    });
  } catch (e) {
    sumEl.innerHTML = `<span style="color:#fb7185">回测异常: ${e.message || e}</span>`;
  }
}

// M19: 因子全集总览 — 每个因子每天的 ICIR + 是否入选权重
let _factorsOverviewCache = null;
async function loadFactorsOverview() {
  const tableEl = document.getElementById('factors-overview-table');
  const sumEl = document.getElementById('factors-overview-summary');
  tableEl.innerHTML = '<div class="loading-skeleton">读取因子全集…</div>';
  try {
    const r = await fetch('/api/research/factors');
    if (!r.ok) { renderFetchError(tableEl, { status: r.status, detail: await r.text() }); return; }
    const d = await r.json();
    _factorsOverviewCache = d;
    renderFactorsOverview();
  } catch (e) { renderFetchError(tableEl, e); }
}

function renderFactorsOverview() {
  const tableEl = document.getElementById('factors-overview-table');
  const sumEl = document.getElementById('factors-overview-summary');
  if (!_factorsOverviewCache || !_factorsOverviewCache.factors) {
    tableEl.innerHTML = '<p class="small">暂无数据</p>';
    return;
  }
  const statusFilter = document.getElementById('factors-overview-status-filter').value;
  const onlySelected = document.getElementById('factors-overview-only-selected').checked;
  let rows = _factorsOverviewCache.factors;
  if (statusFilter !== 'all') {
    if (statusFilter === 'active') {
      rows = rows.filter(r => r.status === 'builtin' || r.status === 'accepted');
    } else {
      rows = rows.filter(r => r.status === statusFilter);
    }
  }
  if (onlySelected) rows = rows.filter(r => r.selected_top50);

  // 状态颜色
  const statusBadge = (s) => {
    const colors = {
      builtin: ['#5eead4', 'builtin'],
      accepted: ['#34d399', 'accepted'],
      shadow:   ['#fbbf24', 'shadow'],
      rejected: ['#94a3b8', 'rejected'],
      demoted:  ['#fb7185', 'demoted'],
      unknown:  ['#6b748a', '?'],
    };
    const [c, label] = colors[s] || colors.unknown;
    return `<span style="color:${c};font-weight:600">${label}</span>`;
  };

  const fmtPct = v => v == null ? '<span style="color:#6b748a">—</span>' : (v * 100).toFixed(2) + '%';
  const fmtNum = (v, d=3) => v == null ? '<span style="color:#6b748a">—</span>' : Number(v).toFixed(d);
  const fmtIR = v => {
    if (v == null) return '<span style="color:#6b748a">—</span>';
    const n = Number(v);
    const color = n >= 0.15 ? '#34d399' : (n <= -0.15 ? '#fb7185' : (Math.abs(n) < 0.05 ? '#94a3b8' : '#fbbf24'));
    return `<span style="color:${color}">${n.toFixed(3)}</span>`;
  };

  // 排序: selected_top50 优先 → composite_weight DESC → ir DESC
  rows.sort((a, b) => {
    if (a.selected_top50 !== b.selected_top50) return b.selected_top50 - a.selected_top50;
    const wa = a.composite_weight ?? -1;
    const wb = b.composite_weight ?? -1;
    if (wa !== wb) return wb - wa;
    const ira = (a.last_metric?.ir) ?? -999;
    const irb = (b.last_metric?.ir) ?? -999;
    return irb - ira;
  });

  let html = '<table class="snapshot"><thead><tr>';
  html += '<th>因子名</th><th>状态</th><th>入选?</th><th>权重</th>';
  html += '<th>最新 IC</th><th>最新 IR</th><th>评估日</th>';
  html += '<th>OOS 天数</th><th>OOS IR</th>';
  html += '</tr></thead><tbody>';
  for (const r of rows) {
    const lm = r.last_metric || {};
    const selectedMark = r.selected_top50 ? '<span style="color:#34d399">✓</span>' : '<span style="color:#6b748a">—</span>';
    const weightStr = r.composite_weight != null ? fmtPct(r.composite_weight) : '<span style="color:#6b748a">—</span>';
    html += `<tr>
      <td><code>${r.name}</code></td>
      <td>${statusBadge(r.status)}</td>
      <td>${selectedMark}</td>
      <td>${weightStr}</td>
      <td>${fmtNum(lm.ic_mean, 4)}</td>
      <td>${fmtIR(lm.ir)}</td>
      <td><span class="small">${lm.as_of_date || '—'}</span></td>
      <td>${r.oos_observations ?? '<span style="color:#6b748a">—</span>'}</td>
      <td>${fmtIR(r.oos_ir)}</td>
    </tr>`;
  }
  html += '</tbody></table>';
  tableEl.innerHTML = html;

  // summary
  const counts = { builtin: 0, accepted: 0, shadow: 0, rejected: 0, demoted: 0 };
  for (const r of _factorsOverviewCache.factors) {
    if (counts[r.status] !== undefined) counts[r.status]++;
  }
  const selectedN = _factorsOverviewCache.factors.filter(r => r.selected_top50).length;
  sumEl.innerHTML = `合计 ${_factorsOverviewCache.factors.length} 个 ` +
    `(builtin ${counts.builtin} · accepted ${counts.accepted} · shadow ${counts.shadow} · ` +
    `rejected ${counts.rejected} · demoted ${counts.demoted}) · 入选 ${selectedN} 个 · ` +
    `快照日 ${_factorsOverviewCache.snapshot_date || '—'} · 显示 ${rows.length} 行`;
}

