{% extends "base.html.j2" %}
{% block title %}Research{% endblock %}

{% block content %}
<h1>研究面板 <span class="small" style="font-weight:400">Research</span></h1>

<!-- KPI 总览条 sticky 顶部 — 4 主 KPI（交易决策相关）+ 2 个折叠到 details -->
<div class="kpi-overview kpi-overview-v2" id="kpi-overview" aria-label="今日核心指标总览">
  <button class="kpi-tile kpi-primary" type="button" data-target="trade-list-card" title="今日待执行 BUY 数（未标记完成）">
    <span class="kpi-tile-lbl">今日 BUY</span>
    <span class="kpi-tile-val metric-good" id="kpi-buy-val">—</span>
    <span class="kpi-tile-sub">待执行</span>
  </button>
  <button class="kpi-tile kpi-primary" type="button" data-target="trade-list-card" title="今日待执行 SELL 数（未标记完成）">
    <span class="kpi-tile-lbl">今日 SELL</span>
    <span class="kpi-tile-val metric-bad" id="kpi-sell-val">—</span>
    <span class="kpi-tile-sub">待执行</span>
  </button>
  <button class="kpi-tile kpi-primary" type="button" data-target="nav-card" title="当日组合净值（扣费后），含日收益">
    <span class="kpi-tile-lbl">当日 NAV</span>
    <span class="kpi-tile-val" id="kpi-nav-val">—</span>
    <span class="kpi-tile-sub" id="kpi-nav-sub">—</span>
    <svg class="kpi-spark" id="kpi-nav-spark" viewBox="0 0 100 24" preserveAspectRatio="none" aria-hidden="true"></svg>
  </button>
  <button class="kpi-tile kpi-primary" type="button" data-target="nav-card" title="累计超额收益 vs 沪深300">
    <span class="kpi-tile-lbl">累计超额</span>
    <span class="kpi-tile-val" id="kpi-excess-val">—</span>
    <span class="kpi-tile-sub" id="kpi-excess-sub">vs 沪深300</span>
    <svg class="kpi-spark" id="kpi-excess-spark" viewBox="0 0 100 24" preserveAspectRatio="none" aria-hidden="true"></svg>
  </button>
  <button class="kpi-tile kpi-secondary" type="button" data-target="portfolio-card" title="今日推荐组合的持仓数">
    <span class="kpi-tile-lbl">持仓数</span>
    <span class="kpi-tile-val" id="kpi-portfolio-val">—</span>
    <span class="kpi-tile-sub" id="kpi-portfolio-sub">—</span>
  </button>
  <button class="kpi-tile kpi-secondary" type="button" data-target="shadow-card" title="OOS 表现已应淘汰、等待 demote 的 shadow 因子数">
    <span class="kpi-tile-lbl">Shadow 待 demote</span>
    <span class="kpi-tile-val" id="kpi-shadow-val">—</span>
    <span class="kpi-tile-sub">需处理</span>
  </button>
</div>

<!-- 「今日待办」智能结论条 — 把散落在 13 张卡片里的核心信号汇成一句话结论。
     数据复用 loadKpiOverview 已拉取的 today-list / shadow-stats, 不额外发请求。
     点击直达对应卡片, 解决"每天打开不知先看哪"的核心痛点。 -->
<div class="today-summary is-loading" id="today-summary" aria-live="polite">
  <span class="ts-icon" id="ts-icon">⏳</span>
  <span class="ts-text" id="ts-text">正在汇总今日结论…</span>
  <span class="ts-actions" id="ts-actions"></span>
</div>

<!-- Tab 分组（4 组）— 用户切换时切换 body[data-active-tab] -->
<nav class="research-tabs" id="research-tabs" role="tablist" aria-label="研究面板分类">
  <button class="rtab is-active" role="tab" data-tab="trade" aria-selected="true"
          title="交易决策：今日清单、持仓、组合、异动诊断">
    <span class="rtab-ico">🎯</span>
    <span class="rtab-lbl">交易</span>
    <span class="rtab-sub">Trade</span>
  </button>
  <button class="rtab" role="tab" data-tab="portfolio" aria-selected="false"
          title="组合表现：净值曲线、Paper Trading 前向跟踪">
    <span class="rtab-ico">📈</span>
    <span class="rtab-lbl">组合</span>
    <span class="rtab-sub">Portfolio</span>
  </button>
  <button class="rtab" role="tab" data-tab="factors" aria-selected="false"
          title="因子研究：单因子表现、全集总览、相关性矩阵、自动发现流水">
    <span class="rtab-ico">🧪</span>
    <span class="rtab-lbl">因子</span>
    <span class="rtab-sub">Factors</span>
  </button>
  <button class="rtab" role="tab" data-tab="llm" aria-selected="false"
          title="LLM Lab：因子提议审核、Shadow 战况">
    <span class="rtab-ico">🤖</span>
    <span class="rtab-lbl">LLM Lab</span>
    <span class="rtab-sub">Agents</span>
  </button>
</nav>

<p class="page-intro">
  这个页面用来 <b>查看每日组合、单因子表现、自动发现的新因子</b>。
  <b>组合</b>=今日 AI 推荐的股票篮子（含权重 / 评分 / 行业分布）；
  <b>因子</b>=每个因子在历史上的预测能力曲线（IC / IR）；
  <b>归因</b>=今日组合靠哪些因子赚的分；
  <b>自动发现</b>=Agent 24 小时不断生成的新因子配方。绿色 <b class="status-ok">已采纳</b> 进组合；
  黄色 <b style="color:#fbbf24">观察中</b>（shadow）正在 OOS 验证；
  红色 <b class="status-error">已淘汰</b>。
</p>

<div class="refresh-bar">
  <label class="refresh-toggle">
    <input type="checkbox" id="auto-refresh" checked>
    <span class="refresh-dot"></span>
    自动刷新 <span class="small">（30 秒）</span>
  </label>
  <span class="refresh-meta">
    上次刷新：<code id="last-refresh-ts">—</code>
  </span>
  <span class="refresh-meta refresh-hint small">
    勾选后每 30 秒重新拉取 组合 / 净值 / 自动发现；因子 IC/IR 不轮询。
  </span>
</div>

<!-- P0-1: 今日交易清单 -->
<div class="card" id="trade-list-card" data-tab="trade">
  <h2>🎯 今日交易清单 <span class="small">Trade List — 把权重翻译成具体下单</span></h2>
  <p class="small" style="color:#94a3b8; margin-top:0">
    根据你的真实持仓 vs 今日推荐组合，自动算出 <b>该买什么 / 该卖什么 / 各多少股</b>（按整手 100 取整）。
    假定本金 ¥100,000。
    <a href="#" onclick="document.getElementById('holdings-editor').scrollIntoView({behavior:'smooth'}); return false;">校准我的实际持仓 ↓</a>
  </p>
  <div class="toolbar" style="gap:6px; margin-bottom:8px;">
    <button class="warn" onclick="markAllExecuted()" title="把今日 trade_list 里所有 BUY/SELL 一键标记已执行 + 更新 holdings (HOLD 不动)">全部执行</button>
  </div>
  <div id="trade-list-summary" class="small"></div>
  <div id="trade-list-table" style="margin-top:10px; max-height:540px; overflow:auto"></div>
</div>

<!-- P0-1: 持仓编辑器 -->
<div class="card" id="holdings-editor" data-tab="trade">
  <h2>📋 我的真实持仓 <span class="small">Holdings — 手动校准</span></h2>
  <p class="small" style="color:#94a3b8; margin-top:0">
    系统不会自动改这里。你需要 <b>手动告诉系统</b>「我昨天真的买了/没买」，
    这样明天的交易清单才会基于真实持仓计算。
  </p>
  <div class="toolbar" style="gap:6px">
    <input id="hold-symbol" data-hotkey-search type="text" placeholder="代码 例 600519" style="width:130px">
    <input id="hold-shares" type="number" placeholder="股数" style="width:100px">
    <input id="hold-cost" type="number" step="0.01" placeholder="成本价" style="width:110px">
    <button onclick="upsertHolding()" class="primary">添加 / 更新</button>
    <span id="hold-msg" class="small" style="color:#94a3b8"></span>
  </div>
  <div id="holdings-table" style="margin-top:10px"></div>
</div>

<!-- Portfolio (trade tab) -->
<div class="card holdings-compact" id="portfolio-card" data-tab="trade">
  <h2>今日组合 <span class="small">Portfolio</span></h2>
  <div class="toolbar" style="margin-bottom: 12px;">
    <label>日期：
      <select id="portfolio-date">
        {% for d in snapshot_dates %}
        <option value="{{ d }}">{{ d }}</option>
        {% endfor %}
      </select>
    </label>
    <button onclick="loadPortfolio()" class="primary">查询</button>
    <button onclick="recomputeTodayPortfolio(this)" class="warn"
            title="跑完整盘后流程 (数据刷新+因子评估+组合优化+归因), 1-5 分钟。基于最新因子表现 (含 shadow / 新 backfill) 重算今日组合。⚙️ 与「运维 Ops」页的「立即跑一次完整流程」是同一操作，点哪个都一样。"
            id="btn-recompute-portfolio">🔄 跑完整盘后流程</button>
    <span class="sep"></span>
    <span id="portfolio-summary" class="small" style="margin-left:0"></span>
    <span id="recompute-status" class="small" style="margin-left:8px;color:var(--fg-mute)"></span>
  </div>
  <div id="industry-chart" class="chart chart-compact"></div>
  <div class="holdings-scroll">
    <div id="portfolio-table"></div>
  </div>
</div>

<!-- Factors (factors tab) -->
<div class="card" data-tab="factors">
  <h2>因子表现 <span class="small">Factor</span></h2>
  <div class="toolbar" style="margin-bottom: 12px;">
    <label>因子：
      <select id="factor-name">
        {%- set groups = {'builtin': [], 'accepted': [], 'shadow': [], 'rejected': [], 'demoted': []} -%}
        {%- for f in factors -%}
          {%- if f.status in groups -%}
            {%- set _ = groups[f.status].append(f) -%}
          {%- endif -%}
        {%- endfor -%}
        {%- set group_labels = [
          ('builtin', 'Builtin (内置 7 个)'),
          ('accepted', 'Accepted (已晋升)'),
          ('shadow', 'Shadow (OOS 观察中)'),
          ('rejected', 'Rejected (历史拒绝)'),
          ('demoted', 'Demoted (已降级)'),
        ] -%}
        {% for key, label in group_labels %}
          {% if groups[key] %}
          <optgroup label="{{ label }} · {{ groups[key]|length }} 个">
            {% for f in groups[key] %}
            <option value="{{ f.name }}">{{ f.name }}{% if f.direction %} ({{ f.direction }}){% endif %}</option>
            {% endfor %}
          </optgroup>
          {% endif %}
        {% endfor %}
      </select>
    </label>
    <button onclick="loadFactor()" class="primary">查询</button>
    <button onclick="backtestSingleFactor()" class="warn"
            title="单独用这个因子跑组合 (top 50 等权, 每 5 天 rebalance), 看历史 NAV vs 沪深300">回测该因子</button>
  </div>
  <div id="factor-table" class="small"></div>
  <div id="ic-chart" class="chart"></div>
  <div id="single-factor-nav-summary" class="small" style="margin-top:8px"></div>
  <div id="single-factor-nav-chart" class="chart" style="display:none"></div>
</div>

<!-- M19: 因子全集总览（builtin/accepted/shadow/rejected/demoted 都列出，每个因子今日 ICIR + 是否入选权重） -->
<div class="card" id="factors-overview-card" data-tab="factors">
  <h2>📊 因子全集总览
    <span class="small">每个因子每天的 ICIR · 是否入选当前组合 · OOS 战况</span>
  </h2>
  <div class="toolbar" style="margin-bottom: 12px;">
    <label>状态筛选：
      <select id="factors-overview-status-filter">
        <option value="all">全部</option>
        <option value="active">活跃 (builtin + accepted)</option>
        <option value="shadow">Shadow (OOS 观察中)</option>
        <option value="rejected">已 rejected</option>
        <option value="demoted">已 demoted</option>
      </select>
    </label>
    <label>仅入选组合：<input type="checkbox" id="factors-overview-only-selected" checked /></label>
    <button onclick="loadFactorsOverview()" class="primary">刷新</button>
    <span id="factors-overview-summary" class="small" style="margin-left:0"></span>
  </div>
  <div id="factors-overview-table" class="small"></div>
</div>

<!-- M7-A: 组合净值曲线（扣费后 vs 沪深300） -->
<div class="card" id="nav-card" data-tab="portfolio">
  <h2>组合净值回测 <span class="small">扣除手续费 / 滑点后的累计净值曲线 vs 沪深300</span></h2>
  <div class="toolbar">
    <button onclick="loadNav()" class="primary">刷新</button>
    <button id="btn-rebuild-nav" onclick="rebuildNav(this)" class="warn">重新计算</button>
    <span id="nav-summary" class="small"></span>
  </div>
  <div id="nav-chart" class="chart" style="height:300px"></div>
  <div id="nav-stats" class="small"></div>
</div>

<!-- P0-2: Paper Trading 前向跟踪 -->
<div class="card" id="paper-trading-card" data-tab="portfolio">
  <h2>📦 前向跟踪 (Paper Trading)
    <span class="small">把每天系统推荐的组合"假装真买了"，看 N 天后真实表现</span>
  </h2>
  <p class="small" style="color:#94a3b8; margin-top:0">
    <b>这是把 in-sample 回测变成 out-of-sample 证据的唯一方式。</b>
    每天 daemon 跑完会把当日 top 50 + close 永久冻结到 paper_trades 表（不再修改）。
    每过一天就用最新 close 重新估值，30/60/90 天后回头看"事后涨没涨"。
  </p>
  <div id="paper-summary" class="small" style="margin-top:10px"></div>
  <div id="paper-cohorts-chart" class="chart" style="height:280px"></div>
  <div id="paper-cohorts-table" class="small" style="margin-top:12px"></div>
</div>

<div class="card" data-tab="trade">
  <h2>因子归因 <span class="small">今日组合的收益预期由哪些因子贡献</span></h2>
  <div id="attribution-chart" class="chart"></div>
</div>

<!-- B2 (M15): 今日异动诊断 -->
<div class="card" data-tab="trade">
  <h2>今日异动诊断
    <span class="small">个股贡献 bps + 因子贡献分解</span>
  </h2>
  <div class="toolbar">
    <label>日期：<input type="date" id="attr-date" /></label>
    <button class="primary" onclick="loadDailyAttribution()">分析</button>
    <span id="attr-status" class="small" style="margin-left:8px;color:var(--fg-mute)"></span>
  </div>
  <div id="daily-attr-output"></div>
</div>

<script>
async function loadDailyAttribution() {
  const di = document.getElementById('attr-date');
  const date = di.value || new Date().toISOString().slice(0, 10);
  const status = document.getElementById('attr-status');
  const out = document.getElementById('daily-attr-output');
  status.textContent = '分析中...';
  out.innerHTML = '';
  try {
    const r = await fetch(`/api/research/daily-attribution?date=${date}`);
    if (!r.ok) {
      const d = await r.json().catch(() => ({}));
      const detail = typeof d.detail === 'string' ? d.detail : '';
      // 404 "该日期无组合快照" 不是系统错误, 是用户场景 (例如选了今天但 post_close 还没跑)。
      // 渲染温和提示而不是红色 ⚠️, 引导用户选有数据的日期。
      if (r.status === 404 && detail.includes('无组合快照')) {
        out.innerHTML = `<div class="empty-state" style="padding:24px;text-align:center;color:var(--fg-mute)">
          <div style="font-size:14px;margin-bottom:6px">📅 ${date} 还没有组合快照</div>
          <div class="small">post_close 每天盘后 16:30 跑出来; 今天还没盘后或者非交易日, 都没今日数据。
            选最近一个工作日 (今日组合卡片左上 "日期" 下拉里那些) 看历史归因。</div>
        </div>`;
      } else {
        renderFetchError(out, { detail: d.detail, status: r.status });
      }
      status.textContent = '';
      return;
    }
    const d = await r.json();
    out.innerHTML = renderDailyAttr(d);
    out.querySelectorAll('table').forEach(t => makeSortable(t));
    status.textContent = `${d.n_with_return || 0}/${d.n_holdings} 只票有完整收益数据`;
  } catch (e) {
    renderFetchError(out, e);
    status.textContent = '';
  }
}

function renderDailyAttr(d) {
  let html = '<div class="grid grid-2" style="margin-top:8px">';

  html += '<div><h3 class="small">📈 Top 5 贡献（涨）</h3><table class="data-table"><thead><tr><th>票</th><th>权重</th><th>涨跌</th><th>贡献 bps</th></tr></thead><tbody>';
  if ((d.top_contributors || []).length === 0) {
    html += '<tr><td colspan="4" class="small" style="color:var(--fg-mute)">暂无</td></tr>';
  } else {
    for (const r of d.top_contributors) {
      html += `<tr>
        <td><a href="/stock/${r.symbol}" class="stock-link"><code>${r.symbol}</code></a> ${escapeHtml(r.name || '')}</td>
        <td>${(r.prev_weight * 100).toFixed(2)}%</td>
        <td class="status-ok">${(r.ret_pct * 100).toFixed(2)}%</td>
        <td class="status-ok"><b>+${r.contrib_bps.toFixed(1)}</b></td>
      </tr>`;
    }
  }
  html += '</tbody></table></div>';

  html += '<div><h3 class="small">📉 Top 5 拖累（跌）</h3><table class="data-table"><thead><tr><th>票</th><th>权重</th><th>涨跌</th><th>贡献 bps</th></tr></thead><tbody>';
  if ((d.top_draggers || []).length === 0) {
    html += '<tr><td colspan="4" class="small" style="color:var(--fg-mute)">暂无</td></tr>';
  } else {
    for (const r of d.top_draggers) {
      html += `<tr>
        <td><a href="/stock/${r.symbol}" class="stock-link"><code>${r.symbol}</code></a> ${escapeHtml(r.name || '')}</td>
        <td>${(r.prev_weight * 100).toFixed(2)}%</td>
        <td class="status-error">${(r.ret_pct * 100).toFixed(2)}%</td>
        <td class="status-error"><b>${r.contrib_bps.toFixed(1)}</b></td>
      </tr>`;
    }
  }
  html += '</tbody></table></div>';
  html += '</div>';

  html += '<h3 class="small" style="margin-top:16px;">🎯 因子贡献（汇总）</h3><table class="data-table"><thead><tr><th>因子</th><th>累计贡献</th></tr></thead><tbody>';
  if ((d.factor_contribution || []).length === 0) {
    html += '<tr><td colspan="2" class="small" style="color:var(--fg-mute)">暂无</td></tr>';
  } else {
    for (const f of d.factor_contribution) {
      const cls = f.contribution >= 0 ? 'status-ok' : 'status-error';
      const sign = f.contribution >= 0 ? '+' : '';
      html += `<tr><td>${escapeHtml(f.name)}</td><td class="${cls}">${sign}${f.contribution.toFixed(3)}</td></tr>`;
    }
  }
  html += '</tbody></table>';

  return html;
}

// HTTP 错误响应展示助手：detail 可能是字符串（FastAPI 默认）或 object（结构化）。
// 老用法 formatErrorDetail(d) 在 detail 是 object 时会显示 "[object Object]"。
if (typeof formatErrorDetail === 'undefined') {
  function formatErrorDetail(d) {
    if (!d) return 'unknown error';
    const detail = d.detail;
    if (typeof detail === 'string') return detail;
    if (detail && typeof detail === 'object') return JSON.stringify(detail);
    return JSON.stringify(d);
  }
}

window.addEventListener('load', () => {
  // 默认日期 = 最近一个有组合快照的日期 (snapshot_dates 上下文已经 DESC 排序),
  // 不是 today — 今天还没盘后跑 post_close 时, portfolio_snapshots 没今日行,
  // endpoint 必 404 给用户看 "请求失败" 像系统坏了。fallback to today 保底。
  const latestSnapshot = {{ snapshot_dates[0] | tojson if snapshot_dates else 'null' }};
  const fallbackToday = new Date().toISOString().slice(0, 10);
  const defaultDate = latestSnapshot || fallbackToday;
  const di = document.getElementById('attr-date');
  if (di && !di.value) di.value = defaultDate;
  // 延迟 1.5s 自动加载一次今日异动诊断（仿 correlation 的延迟加载）
  setTimeout(() => { try { loadDailyAttribution(); } catch (e) {} }, 1500);
});
</script>

<!-- M2 自动因子发现流水 -->
<div class="card" data-tab="factors">
  <h2>自动发现因子流水
    <span class="small" id="proposal-counts"></span>
  </h2>
  <p class="small" style="margin:-6px 0 10px;color:var(--fg-mute)">
    AI 自动生成因子配方 → 回测 → 自动判断是否纳入组合。绿色=<b class="status-ok">已采纳</b>，红色=<b class="status-error">已淘汰</b>。
  </p>
  <div class="toolbar" style="margin-bottom:12px;">
    <label>状态：
      <select id="proposal-status">
        <option value="">全部</option>
        <option value="accepted">已采纳</option>
        <option value="shadow">观察中</option>
        <option value="rejected">已淘汰</option>
        <option value="demoted">未通过 OOS</option>
      </select>
    </label>
    <button class="primary" onclick="loadProposals()">刷新列表</button>
    <button class="warn" id="btn-discovery" onclick="runDiscovery()"
            title="让 AI 临时生成 20 个新因子配方并回测（约 30~120 秒）。⚙️ 与「运维 Ops」页的「跑一轮因子发现」是同一操作，点哪个都一样。">立即跑一轮发现（20 个候选）</button>
    <span id="discovery-status" class="small" style="margin-left:8px;color:var(--fg-mute)"></span>
  </div>
  <div id="proposals-table" class="small"></div>
</div>

<!-- M16-2: 因子相关性热力图 -->
<div class="card" data-tab="factors">
  <h2>因子相关性矩阵
    <span class="small">cross-section corr 当日截面 — 防止 LLM 推一堆 momentum 变体</span>
  </h2>
  <p class="small" style="margin:-6px 0 10px;color:var(--fg-mute)">
    高度相关（|corr| ≥ 0.7）的因子提供的边际信息小；
    DSL discovery 内置 max_abs_corr=0.7 阈值会自动拒绝这类候选。
  </p>
  <div class="toolbar">
    <button class="primary" onclick="loadFactorCorrelation()">刷新</button>
    <label class="small" style="margin-left:12px;color:var(--fg-mute)">
      <input type="checkbox" id="corr-show-numbers" style="vertical-align:middle">
      在格子里显示数字（因子多时不建议勾）
    </label>
    <span id="corr-status" class="small" style="margin-left:8px;color:var(--fg-mute)"></span>
  </div>
  <div id="factor-corr-chart" style="height: 480px;"></div>
  <!-- M19 review: Top-K 高相关因子对 — 比看 49x49 矩阵直观 -->
  <div style="margin-top:14px">
    <div class="small" style="color:var(--fg-mute); margin-bottom:6px">
      <b>📌 高相关因子对</b>（|corr| ≥ 0.5, 按绝对值降序）— 重复信息源, 可考虑淘汰其中一个
    </div>
    <div id="corr-pairs-table" class="small"></div>
  </div>
</div>

<!-- A2 (M15): Shadow 战况看板 -->
<div class="card" id="shadow-card" data-tab="llm">
  <h2>SHADOW 因子池
    <span class="small">已参与组合选股（按 IS IR 加权），OOS 验证 promote / demote 判决中</span>
  </h2>
  <p class="small" style="margin:-6px 0 10px;color:var(--fg-mute)">
    阈值: OOS ≥ 20 天 + |IR| ≥ 0.15 → <b class="status-ok">promote</b>；
    OOS ≥ 60 天 + |IR| < 0.10 → <b class="status-error">demote</b>；
    20-60 天宽限期内不达标也继续观察。
  </p>
  <div class="toolbar">
    <button onclick="loadShadowStats()">刷新列表</button>
    <span id="shadow-stats-status" class="small" style="margin-left:8px;color:var(--fg-mute)"></span>
  </div>
  <div id="shadow-stats-table" class="small"></div>
</div>

<script>
let _factorCorrChart = null;

async function loadFactorCorrelation() {
  const status = document.getElementById('corr-status');
  const chartEl = document.getElementById('factor-corr-chart');
  status.textContent = '计算中…（首次约 3-5 秒）';
  try {
    const r = await fetch('/api/research/factors/correlation');
    if (!r.ok) {
      const d = await r.json();
      status.innerHTML = '<span class="status-error">❌ ' + formatErrorDetail(d) + '</span>';
      return;
    }
    const d = await r.json();
    if (!d.factors || d.factors.length === 0) {
      status.textContent = '当前 registry 没有 active 因子';
      return;
    }
    renderFactorCorrelation(chartEl, d);
    status.textContent = `${d.as_of_date} · ${d.factors.length} 因子 · ${d.n_observations} 只票完整观测`;
  } catch (e) {
    status.innerHTML = '<span class="status-error">❌ 网络错误：' + e.message + '</span>';
  }
}

function renderFactorCorrelation(el, d) {
  const n = d.factors.length;

  // M19 review: 高度自适应 — 每个因子至少 14px, 上下 padding 160px 给轴标签
  // (旧 480px 固定, 49 因子 = 单格 6px 完全看不清)
  const cellPx = 14;
  const padding = 180;  // top 60 + bottom 100 (轴标签) + visualMap
  const desiredH = Math.max(360, Math.min(n * cellPx + padding, 1200));
  el.style.height = desiredH + 'px';

  // M19 review: 因子 >20 自动隐藏数字 (除非用户勾了开关)
  const showNumbers = document.getElementById('corr-show-numbers');
  const labelShow = showNumbers && showNumbers.checked ? true : (n <= 20);

  const cells = [];
  for (let i = 0; i < n; i++) {
    for (let j = 0; j < n; j++) {
      const v = d.matrix[i][j];
      cells.push([j, i, (v == null) ? 0 : Number(v.toFixed(3))]);
    }
  }

  if (_factorCorrChart) _factorCorrChart.dispose();
  _factorCorrChart = echarts.init(el);
  _factorCorrChart.setOption({
    tooltip: {
      formatter: (p) => {
        const fx = d.factors[p.value[0]];
        const fy = d.factors[p.value[1]];
        return `${fx}<br>vs<br>${fy}<br><b>corr = ${p.value[2]}</b>`;
      },
    },
    grid: {top: 60, left: 220, right: 50, bottom: 110},
    xAxis: {
      type: 'category', data: d.factors, splitArea: {show: true},
      axisLabel: {rotate: 45, fontSize: 9, color: '#cbd5e1'},
    },
    yAxis: {
      type: 'category', data: d.factors, splitArea: {show: true},
      axisLabel: {fontSize: 9, color: '#cbd5e1'},
    },
    visualMap: {
      min: -1, max: 1, calculable: true, orient: 'horizontal',
      left: 'center', bottom: 10,
      inRange: {color: ['#60a5fa', '#161a23', '#f87171']},
      textStyle: {color: '#cbd5e1'},
    },
    series: [{
      type: 'heatmap', data: cells,
      label: {show: labelShow, fontSize: 9, color: '#e6e9f0'},
      emphasis: {itemStyle: {shadowBlur: 10, shadowColor: 'rgba(0,0,0,0.3)'}},
    }],
  });

  // M19 review: 渲染 Top-K 高相关对表 (实用洞察)
  renderCorrPairs(d);
}

function renderCorrPairs(d) {
  const n = d.factors.length;
  const pairs = [];
  // 只看上三角 (避免重复), 排除对角线 (corr=1)
  for (let i = 0; i < n; i++) {
    for (let j = i + 1; j < n; j++) {
      const v = d.matrix[i][j];
      if (v == null) continue;
      if (Math.abs(v) >= 0.5) {
        pairs.push({a: d.factors[i], b: d.factors[j], corr: Number(v.toFixed(3))});
      }
    }
  }
  pairs.sort((x, y) => Math.abs(y.corr) - Math.abs(x.corr));

  const out = document.getElementById('corr-pairs-table');
  if (!out) return;
  if (!pairs.length) {
    out.innerHTML = '<div class="empty-state" style="padding:10px 0;color:var(--fg-mute);font-size:12px">' +
      '✓ 没有高相关对 (|corr| < 0.5), 因子池信息源较独立。</div>';
    return;
  }
  const top = pairs.slice(0, 30);
  const colorCorr = (v) => {
    const abs = Math.abs(v);
    if (abs >= 0.7) return 'color:#fb7185;font-weight:600';  // 超阈值 红
    if (abs >= 0.5) return 'color:#fbbf24';                  // 边缘 黄
    return 'color:#94a3b8';
  };
  let html = '<table class="data-table"><thead><tr>'
    + '<th>因子 A</th><th>因子 B</th><th>corr</th><th>建议</th>'
    + '</tr></thead><tbody>';
  for (const p of top) {
    const suggest = Math.abs(p.corr) >= 0.7
      ? '⚠️ 信息重复, 保留 IR 高的一个'
      : '边缘相关, 可观察';
    html += `<tr>
      <td><code>${escapeHtml(p.a)}</code></td>
      <td><code>${escapeHtml(p.b)}</code></td>
      <td style="${colorCorr(p.corr)}">${p.corr > 0 ? '+' : ''}${p.corr}</td>
      <td class="small">${suggest}</td>
    </tr>`;
  }
  html += '</tbody></table>';
  if (pairs.length > 30) {
    html += `<div class="small" style="color:var(--fg-mute);margin-top:6px">仅显示前 30 对, 实际共 ${pairs.length} 对</div>`;
  }
  out.innerHTML = html;
}

async function loadShadowStats() {
  const tbl = document.getElementById('shadow-stats-table');
  const status = document.getElementById('shadow-stats-status');
  status.textContent = '加载中...';
  try {
    const r = await fetch('/api/research/factors/shadow-stats');
    const d = await r.json();
    tbl.innerHTML = renderShadowStats(d.shadows || []);
    makeSortable(tbl.querySelector('table'));
    status.textContent = `${d.n || 0} 个 shadow 因子`;
  } catch (e) {
    renderFetchError(tbl, e);
    status.textContent = '';
  }
}

function renderShadowStats(rows) {
  if (!rows.length) {
    return '<div class="small" style="color:var(--fg-mute);padding:8px 0;">暂无 shadow 因子。等 LLM brainstorm 或 auto discovery 产出新候选并被人工接受。</div>';
  }
  // 按 verdict 排序: should_demote 优先（最需要处理）→ promote_eligible → edge → no_data → evaluating
  const order = {'should_demote': 0, 'promote_eligible': 1, 'edge': 2, 'no_data': 3, 'evaluating': 4};
  rows.sort((a, b) => (order[a.verdict] ?? 5) - (order[b.verdict] ?? 5));

  let html = '<table class="data-table"><thead><tr>'
    + '<th>因子名</th><th>来源</th><th>方向</th>'
    + '<th title="因子历史 IS 期 (In-Sample) 的信息比率。CompositeScorer 会用这个值加权，绝对值越高在组合里权重越大。">IS IR</th>'
    + '<th>观察 (天)</th><th>OOS 观察次数</th><th>OOS IR</th><th>判定</th>'
    + '</tr></thead><tbody>';
  for (const s of rows) {
    const days = s.days_observed != null ? s.days_observed : '—';
    const obs = s.oos_observations != null ? s.oos_observations : '—';
    const source = s.is_llm ? '<span class="metric-dim">LLM</span>' : '<span class="metric-dim">auto</span>';

    // IS IR 列 (M20): 展示 CompositeScorer 用来加权的 IS 期 IR
    let isIrCell = '—';
    if (s.ir != null) {
      const absIr = Math.abs(s.ir);
      const cls = absIr >= 0.15 ? 'metric-good' : (absIr < 0.10 ? 'metric-bad' : '');
      isIrCell = cls ? `<span class="${cls}">${s.ir.toFixed(3)}</span>` : s.ir.toFixed(3);
    }

    // OOS IR 列 (M20): 区分「观察期未满」vs「data sparse 异常」
    let oosIrCell;
    if (s.oos_ir != null) {
      oosIrCell = s.oos_ir.toFixed(3);
    } else if ((s.oos_observations ?? 0) < 20) {
      oosIrCell = `<span class="metric-dim">&lt;20d (${s.oos_observations ?? 0}/20)</span>`;
    } else {
      oosIrCell = '<span class="metric-warn">— (data sparse)</span>';
    }

    // 判定列 (M20): 中性化表述, 不再暗示 shadow 因子"没在工作"
    let verdictCell;
    switch (s.verdict) {
      case 'evaluating':
        verdictCell = `<span class="metric-dim">验证期 ${s.oos_observations ?? 0}/20d</span>`;
        break;
      case 'no_data':
        verdictCell = '<span class="metric-warn">⚠️ 数据稀疏</span>';
        break;
      case 'promote_eligible':
        verdictCell = '<span class="status-ok">✓ 满足晋升</span>';
        break;
      case 'should_demote':
        verdictCell = '<span class="status-error">✗ 拟淘汰</span>';
        break;
      case 'edge':
        verdictCell = `<span class="metric-dim">观察中 (${s.days_observed ?? 0}d)</span>`;
        break;
      default:
        verdictCell = s.verdict;
    }

    html += `<tr>
      <td><code>${s.factor_name}</code></td>
      <td>${source}</td>
      <td>${s.direction}</td>
      <td>${isIrCell}</td>
      <td>${days}</td>
      <td>${obs}</td>
      <td>${oosIrCell}</td>
      <td>${verdictCell}</td>
    </tr>`;
  }
  return html + '</tbody></table>';
}

window.addEventListener('load', () => {
  // loadFactorCorrelation 现由 factors tab 的懒加载器触发, 不再在 window.load 里主动 setTimeout.
  // 只保留数字开关切换时的重绘回调 (无需重拉数据, echarts setOption 即可).
  const cb = document.getElementById('corr-show-numbers');
  if (cb) cb.addEventListener('change', () => loadFactorCorrelation());
});

// loadShadowStats / loadLLMSuggestions 也搬到 llm tab 懒加载器, 不再 window.load 主动触发.
</script>

<!-- M14: LLM 因子构建建议（人工审核） -->
<div class="card" data-tab="llm">
  <h2>LLM 因子构建建议
    <span class="small">大模型提议 → 人工审核 → 通过则进入 OOS 观察</span>
  </h2>
  <p class="small" style="margin:-6px 0 10px;color:var(--fg-mute)">
    每天 20:00 daemon 自动跑一次；也可以点按钮手动触发。
    审核 <b class="status-ok">接受</b> → status='shadow'（下一轮 discovery 会做 OOS 评估），
    <b class="status-error">拒绝</b> → status='rejected'。
  </p>
  <div class="toolbar" style="margin-bottom:12px;">
    <button class="primary" onclick="runBrainstorm()" id="btn-brainstorm"
            title="让大模型基于现状提出 10 个新因子方向（约 5-15 秒）">让 LLM 提 10 个方向</button>
    <button onclick="loadLLMSuggestions()">刷新列表</button>
    <span id="brainstorm-status" class="small" style="margin-left:8px;color:var(--fg-mute)"></span>
  </div>
  <div id="llm-suggestions-table" class="small"></div>
</div>

<script>
async function runBrainstorm() {
  await runLongOperation({
    button: document.getElementById('btn-brainstorm'),
    url: '/api/research/factors/brainstorm/run',
    body: { n: 10 },
    statusEl: document.getElementById('brainstorm-status'),
    runningMessage: '调用 LLM 中',
    successMessage: '完成，正在刷新列表',
    // factor.brainstorm 是异步 daemon job(60-125s): trigger 立即 202, 不能入队即当完成.
    // 用 result_poll_url 轮询, daemon 写完 result(status=ok)再刷新列表, 否则看到旧建议.
    pollUrlFromResponse: (d) => (d && d.payload && d.payload.result_poll_url) || null,
    pollInterval: 3000,
    pollTimeout: 150000,
    pollIsDone: (d) => d && (d.status === 'ok' || d.status === 'not_found'),
    onSuccess: () => loadLLMSuggestions(),
    onError: () => loadLLMSuggestions(),
  });
}

async function loadLLMSuggestions() {
  const tbl = document.getElementById('llm-suggestions-table');
  try {
    const r = await fetch('/api/research/factors/llm-suggestions?limit=50');
    const d = await r.json();
    tbl.innerHTML = renderLLMSuggestions(d.suggestions || []);
    makeSortable(tbl.querySelector('table'));
  } catch (e) {
    renderFetchError(tbl, e);
  }
}

function renderLLMSuggestions(rows) {
  if (!rows.length) {
    return '<div class="small" style="color:var(--fg-mute);padding:8px 0;">暂无待审核的 LLM 提议。点上方按钮触发一次。</div>';
  }
  let html = '<table class="data-table"><thead><tr>'
    + '<th>因子名</th><th>recipe</th><th>方向</th><th>LLM 理由</th><th>创建时间</th><th>操作</th>'
    + '</tr></thead><tbody>';
  for (const r of rows) {
    // recipe 兼容两种格式:
    // 1) DSL 因子 (旧): {base, op, window, direction} → "close/zscore/w20"
    // 2) code 因子 (自由代码): {description, direction} → "code" 徽章
    // 3) 缺字段 → "—"
    let recipe;
    if (r.recipe && r.recipe.base && r.recipe.op && r.recipe.window != null) {
      recipe = `${r.recipe.base}/${r.recipe.op}/w${r.recipe.window}`;
    } else if (r.recipe && (r.recipe.description || r.factor_name.startsWith('code_'))) {
      recipe = '<span class="pill" style="background:var(--brand-mute,#334);color:var(--fg-mute)">code</span>';
    } else {
      recipe = '—';
    }
    const reason = (r.reason || '').replace(/^LLM suggested:\s*/, '');
    const created = (r.created_at || '').slice(0, 16).replace('T', ' ');
    html += `<tr>
      <td><code>${r.factor_name}</code></td>
      <td>${recipe}</td>
      <td>${r.direction}</td>
      <td title="${escapeHtml(reason)}">${escapeHtml(reason.slice(0, 80))}${reason.length > 80 ? '…' : ''}</td>
      <td>${created}</td>
      <td>
        <button class="primary" onclick="reviewLLM(this, '${r.factor_name}', 'accept')">接受</button>
        <button class="warn" onclick="reviewLLM(this, '${r.factor_name}', 'reject')">拒绝</button>
      </td>
    </tr>`;
  }
  return html + '</tbody></table>';
}

async function reviewLLM(btn, name, action) {
  // P1-2 (review): 显式 btn 参数 — 之前用 event.target 拿按钮, 键盘 / a11y / 程序触发
  // 时 event 不可用 → btn=null → "处理中…" 不出现, 用户连点触发多次 backfill。
  // accept 的 90 天 IS-IC backfill 已下沉 daemon (factor.llm_accept job), web 立即入队 + 轮询,
  // 不再在 web 进程同步跑重 CPU (避免饿死 event loop)。reject 是纯 SQL, 继续走同步端点。
  let restoreLabel = null;
  if (btn) {
    restoreLabel = btn.innerHTML;
    btn.disabled = true;
    btn.classList.add('is-loading');
    btn.innerHTML = action === 'accept' ? '处理中…(后台约30秒)' : '处理中…';
  }
  try {
    if (action === 'accept') {
      await reviewLLMAcceptAsync(name);
    } else {
      const r = await fetch(`/api/research/factors/llm-suggestions/${encodeURIComponent(name)}/${action}`, {method:'POST'});
      const d = await r.json();
      if (!r.ok) { toast('失败：' + formatErrorDetail(d), 'error'); return; }
      toast(`${name} → 已拒绝`, 'ok');
      loadLLMSuggestions();
    }
  } catch (e) { toast('网络错误：' + e.message, 'error'); }
  finally {
    if (btn) {
      btn.disabled = false;
      btn.classList.remove('is-loading');
      if (restoreLabel != null) btn.innerHTML = restoreLabel;
    }
  }
}

// accept 下沉 daemon: 触发 factor.llm_accept job → 立即 202 → 轮询 result 端点直到 ok/failed。
async function reviewLLMAcceptAsync(name) {
  const tr = await fetch('/api/control/jobs/factor.llm_accept/trigger', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({factor_name: name}),
  });
  const td = await tr.json();
  if (!tr.ok) { toast('接受失败：' + formatErrorDetail(td), 'error'); return; }
  const pollUrl = td.payload && td.payload.result_poll_url;
  toast(`${name} 已入队，后台评估中…`, 'ok', { duration: 2500 });
  if (!pollUrl) { loadLLMSuggestions(); return; }

  // 轮询 result: 最多 ~90 秒 (每 3s 一次), running 继续, ok/failed 结束。
  const started = Date.now();
  const maxMs = 90000;
  while (Date.now() - started < maxMs) {
    await new Promise(res => setTimeout(res, 3000));
    let pd;
    try {
      const pr = await fetch(pollUrl);
      pd = await pr.json();
    } catch (e) { continue; }  // 网络抖动, 下一轮再试
    if (pd.status === 'running') continue;
    if (pd.status === 'not_found') { toast(`${name} 任务丢失，请重试`, 'error'); loadLLMSuggestions(); return; }
    if (pd.status === 'ok') {
      const res = pd.result || {};
      const isIc = res.is_ic || {};
      const tail = (isIc.ok)
        ? `（IS IR=${(isIc.ir ?? 0).toFixed(3)}, ${isIc.n_metrics_written || 0} 行历史）`
        : '';
      if (res.ok) toast(`${name} → 已接受${tail}`, 'ok');
      else toast(`${name} 接受失败：${res.error || 'unknown'}`, 'error');
      loadLLMSuggestions();
      return;
    }
  }
  // 超时: 后台可能仍在跑, 刷新列表让用户看最新状态
  toast(`${name} 评估耗时较长，请稍后刷新查看`, 'warn');
  loadLLMSuggestions();
}

// loadLLMSuggestions 已搬到 llm tab 懒加载器 (loadTabIfNeeded('llm')). 不再 window.load 主动触发.
</script>

<!-- M11: 因子推理详情 Modal -->
<div id="proposal-modal" class="modal-backdrop hidden" onclick="closeProposalModalOnBackdrop(event)">
  <div class="modal-window" role="dialog" aria-modal="true" aria-labelledby="proposal-modal-title">
    <div class="modal-head">
      <span class="title" id="proposal-modal-title">…</span>
      <span class="badge b-unknown" id="proposal-modal-badge"><span class="text">…</span></span>
      <button class="close-btn" onclick="closeProposalModal()" title="关闭（ESC）">×</button>
    </div>
    <div class="modal-body" id="proposal-modal-body">
      <div class="loading-skeleton">读取因子推理详情…</div>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<style>
.trade-table { width: 100%; font-size: 12.5px; border-collapse: collapse; }
.trade-table th { text-align: left; color: #94a3b8; font-weight: 500; padding: 8px 10px; font-size: 11px; text-transform: uppercase; letter-spacing: 0.04em; border-bottom: 1px solid rgba(94,234,212,0.15); white-space: nowrap; }
.trade-table td { padding: 7px 10px; border-bottom: 1px solid rgba(94,234,212,0.05); }
.trade-table tr:hover { background: rgba(94,234,212,0.04); }
.trade-table button.small { font-size: 11px; padding: 3px 8px; }
#holdings-editor .toolbar input { background: rgba(15,23,42,0.6); border: 1px solid #334155; color: #e2e8f0; padding: 5px 8px; border-radius: 4px; font-family: var(--font-mono); font-size: 13px; }
#holdings-editor .toolbar input:focus { outline: none; border-color: #5eead4; }
</style>
<script>
// ============================================================
// /research — Tab 分组切换
//   4 个 Tab: trade / portfolio / factors / llm
//   切换走 body[data-active-tab]，CSS 控制 [data-tab] 显隐
//   URL hash 同步 (#trade #portfolio #factors #llm)
// ============================================================
const RESEARCH_TABS = ['trade', 'portfolio', 'factors', 'llm'];

// 各 tab 的懒加载器 — 第一次切到该 tab 时才发对应 API 请求.
// 之前 window.load 里一次性触发所有 tab 的 loader (11 个 API), 用户如果只看 trade tab,
// 其余请求都是白花的 (对新用户/无数据用户尤其明显). 现在只默认加载 trade 需要的.
// 无害保留: KPI 总览 + freshness + trade 卡片 + 因子相关性 (放 factors 但用户经常想快看).
const _tabLoaded = { trade: false, portfolio: false, factors: false, llm: false };
function loadTabIfNeeded(tabKey) {
  if (_tabLoaded[tabKey]) return;
  _tabLoaded[tabKey] = true;
  try {
    if (tabKey === 'trade') {
      // trade tab (默认): 今日交易清单 + 持仓 + 今日组合快照 + 因子归因
      // ⚠️ portfolio-card / attribution-chart 两张卡 data-tab="trade" 属于 trade 视图,
      //    对应 loadPortfolio (内部会级联 loadAttribution) 必须在这里触发,
      //    而不是等用户切到 portfolio tab. 之前放在 portfolio tab lazy loader 里
      //    导致 trade tab 默认视图下这两张卡永远是空的 (b9f61ec 引入的回归).
      if (typeof loadTradeList === 'function') loadTradeList();
      if (typeof loadHoldings === 'function') loadHoldings();
      const dateSel = document.getElementById('portfolio-date');
      if (dateSel && dateSel.value && typeof loadPortfolio === 'function') loadPortfolio();
    } else if (tabKey === 'portfolio') {
      // portfolio tab: 净值曲线 + Paper Trading
      if (typeof loadNav === 'function') loadNav();
      if (typeof loadPaperTracking === 'function') loadPaperTracking();
    } else if (tabKey === 'factors') {
      // factors tab: 因子全集总览 + 单因子 + 自动发现流水 + 相关性
      if (typeof loadFactorsOverview === 'function') loadFactorsOverview();
      const factorSel = document.getElementById('factor-name');
      if (factorSel && factorSel.value && typeof loadFactor === 'function') loadFactor();
      if (typeof loadProposals === 'function') loadProposals();
      if (typeof loadFactorCorrelation === 'function') loadFactorCorrelation();
    } else if (tabKey === 'llm') {
      // llm tab: LLM 因子构建建议 + Shadow 战况
      if (typeof loadLLMSuggestions === 'function') loadLLMSuggestions();
      if (typeof loadShadowStats === 'function') loadShadowStats();
    }
  } catch (e) { console.warn('lazy load ' + tabKey + ' failed:', e); }
}

function activateResearchTab(tabKey, opts) {
  if (!RESEARCH_TABS.includes(tabKey)) tabKey = 'trade';
  document.body.setAttribute('data-active-tab', tabKey);
  document.querySelectorAll('#research-tabs .rtab').forEach(btn => {
    const on = btn.dataset.tab === tabKey;
    btn.classList.toggle('is-active', on);
    btn.setAttribute('aria-selected', on ? 'true' : 'false');
  });
  // 首次切到该 tab → 触发懒加载
  // ⚠️ setupResearchTabs() 在 script 定义时立即执行 (不等 DOMContentLoaded),
  //    此时后面几个 script 块里的 loadTradeList/loadHoldings/loadPortfolio 等
  //    异步加载函数还未 declare, 直接调用会因 `typeof === 'function'` 检查失败
  //    全部跳过 → 首屏各卡片永远空白 (b9f61ec 引入的 tab 懒加载回归).
  //    解法: 把懒加载推到当前 tick 之后, 那时所有 script 已全部解析完成.
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => loadTabIfNeeded(tabKey), { once: true });
  } else {
    setTimeout(() => loadTabIfNeeded(tabKey), 0);
  }
  // URL hash 同步 (不触发 scroll)
  if (!opts || opts.updateHash !== false) {
    if (location.hash !== '#' + tabKey) {
      history.replaceState(null, '', '#' + tabKey);
    }
  }
  // 用户点击切 tab 后回滚: 若已滚过 tab 栏, 把 tab 栏顶到 nav 下方,
  // 避免停在上一个 tab 底部的空白处 (初始化/后退前进不回滚, 保留浏览位置)
  if (opts && opts.scrollToTop) {
    const tabsEl = document.getElementById('research-tabs');
    if (tabsEl) {
      const navH = parseInt(getComputedStyle(document.documentElement)
        .getPropertyValue('--nav-h')) || 56;
      const top = tabsEl.getBoundingClientRect().top + window.scrollY - navH;
      if (window.scrollY > top) window.scrollTo({ top, behavior: 'smooth' });
    }
  }
  // 切 tab 后让 ECharts 实例 resize（切回隐藏 → 显示时容器宽度刚刚才有）
  setTimeout(() => {
    if (typeof echarts === 'undefined') return;
    document.querySelectorAll(`[data-tab="${tabKey}"] .chart, [data-tab="${tabKey}"] [id$="-chart"]`).forEach(el => {
      const inst = echarts.getInstanceByDom(el);
      if (inst) try { inst.resize(); } catch(e) {}
    });
  }, 220);
}

function setupResearchTabs() {
  document.querySelectorAll('#research-tabs .rtab').forEach(btn => {
    btn.addEventListener('click', () => activateResearchTab(btn.dataset.tab, { scrollToTop: true }));
  });
  // 初次从 URL hash 读
  const initial = (location.hash || '').slice(1);
  activateResearchTab(RESEARCH_TABS.includes(initial) ? initial : 'trade', { updateHash: false });
  // 浏览器后退/前进时切换
  window.addEventListener('hashchange', () => {
    const k = (location.hash || '').slice(1);
    activateResearchTab(k, { updateHash: false });
  });
}
// 立即执行（不等 load），避免首屏闪烁全部卡片
setupResearchTabs();
</script>

<script>
// ====== 中文术语映射 ==========
const DIR_CN  = { long: '做多', short: '做空' };
const OP_CN   = {
  rolling_mean: '滚动均值', rolling_std: '滚动标准差', rolling_sum: '滚动求和',
  rolling_max: '滚动最大值', rolling_min: '滚动最小值',
  zscore: 'Z 标准化', rank: '横截面排序', diff: '差分', pct_change: '涨跌幅',
  momentum: '动量', reversal: '反转', ts_rank: '时序排序',
};
const BASE_CN = {
  close: '收盘价', open: '开盘价', high: '最高价', low: '最低价',
  volume: '成交量', amount: '成交额', turnover: '换手率',
  vwap: '成交均价', ret: '收益率',
};
function cnOf(map, k) { return map[k] || k; }

// M19: 重算今日组合 — 调 batch.post_close 跑完整盘后流程
// (注: 包含数据刷新 + 因子评估 + 组合优化 + 归因, 1-5 分钟; 不是只重算组合那一步)
async function recomputeTodayPortfolio(btn) {
  await runLongOperation({
    button: btn || document.getElementById('btn-recompute-portfolio'),
    url: '/api/control/jobs/batch.post_close/trigger',
    statusEl: document.getElementById('recompute-status'),
    runningMessage: '跑完整盘后流程 (1-5 分钟)',
    successMessage: '完成, 已用最新因子表现重算今日组合',
    // batch.post_close 是异步 daemon job(1-5 分钟): trigger 立即 202, 不能入队即当完成.
    // 用 job-runs detail 轮询, 等 daemon 真跑完(status=ok/failed)再刷新依赖组合快照的卡片,
    // 否则会在盘后流程还没算完时刷新, 看到的是旧快照。
    pollUrlFromResponse: (d) => (d && d.payload && d.payload.poll_url) || null,
    pollInterval: 3000,
    pollTimeout: 360000,
    pollIsDone: (d) => d && (d.status === 'ok' || d.status === 'failed' || d.status === 'error'),
    onSuccess: (d) => {
      if (d && (d.status === 'failed' || d.status === 'error')) {
        const el = document.getElementById('recompute-status');
        if (el) { el.classList.remove('status-ok'); el.classList.add('status-error'); el.innerHTML = '❌ 盘后流程失败，请查看运维页 job-runs'; }
      }
      // 刷新所有依赖 portfolio_snapshots 的卡片
      try { loadPortfolio(); } catch (e) {}
      try { loadKpiOverview(); } catch (e) {}
      try { loadTradeList(); } catch (e) {}
      try { loadDailyAttribution(); } catch (e) {}
    },
    onError: () => {
      try { loadPortfolio(); } catch (e) {}
      try { loadKpiOverview(); } catch (e) {}
    },
  });
}

async function loadPortfolio() {
  const date = document.getElementById('portfolio-date').value;
  if (!date) { document.getElementById('portfolio-table').innerHTML = '<p class="small">该日期暂无组合快照</p>'; return; }
  const summary = document.getElementById('portfolio-summary');
  const tableEl = document.getElementById('portfolio-table');
  summary.textContent = '加载中…';
  tableEl.innerHTML = '<div class="loading-skeleton">读取组合快照…</div>';
  try {
    const r = await fetch(`/api/research/portfolio?date=${date}`);
    if (r.status === 404) { summary.textContent = '该日期暂无组合快照'; return; }
    if (!r.ok) { renderFetchError(tableEl, { status: r.status, detail: await r.text() }); summary.textContent = ''; return; }
    const d = await r.json();
    // 用户切到非"最新"日期时，标注一下，避免和顶部「今日 KPI」口径混淆
    const dateSel = document.getElementById('portfolio-date');
    const latestDate = dateSel.options.length > 0 ? dateSel.options[0].value : null;
    const isHistorical = latestDate && date !== latestDate;
    const historicalTag = isHistorical
      ? ` <span style="color:#fbbf24;font-weight:600">⚠️ 历史快照 (${date})，与顶部今日 KPI 不是同一天</span>`
      : '';
    summary.innerHTML = escapeHtml(d.summary) + historicalTag;
    tableEl.innerHTML = renderPortfolioTable(d.rows);
    makeSortable(tableEl.querySelector('table'));
    renderIndustryChart(d.industry_breakdown);
    // 同时加载归因
    loadAttribution(date);
  } catch (e) { renderFetchError(tableEl, e); summary.textContent = ''; }
}
function renderPortfolioTable(rows) {
  if (!rows || !rows.length) return '<p class="small">该日期组合为空</p>';
  const renderChips = (tops) => {
    if (!tops || !tops.length) return '<span class="small" style="color:var(--fg-mute)">—</span>';
    return tops.slice(0, 2).map(f => {
      const v = f.contribution;
      const cls = v >= 0 ? 'fchip fchip-pos' : 'fchip fchip-neg';
      const sign = v >= 0 ? '+' : '−';
      const shortName = f.name.length > 18 ? f.name.slice(0, 16) + '…' : f.name;
      return `<span class="${cls}" title="${f.name} = ${v.toFixed(3)}">
        <span class="fchip-name">${shortName}</span>
        <span class="fchip-val">${sign}${Math.abs(v).toFixed(2)}</span>
      </span>`;
    }).join('');
  };
  return `<table class="holdings-table"><thead><tr>
      <th><abbr title="股票代码，例如 600000.SH">代码</abbr></th>
      <th>名称</th>
      <th class="num"><abbr title="该股票在组合中所占的资金比例">权重</abbr></th>
      <th class="num"><abbr title="多因子合成评分，越高代表 AI 越看好">评分</abbr></th>
      <th><abbr title="对该股票评分贡献最大的 Top 2 因子；悬停看完整因子名">主要因子</abbr></th>
    </tr></thead><tbody>
    ${rows.map(r => `<tr>
      <td><a href="/stock/${r.symbol}" class="stock-link"><code>${r.symbol}</code></a></td>
      <td>${r.name || '—'}</td>
      <td class="num">${(r.weight * 100).toFixed(2)}%</td>
      <td class="num">${r.composite_score != null ? r.composite_score.toFixed(3) : '—'}</td>
      <td class="fchip-cell">${renderChips(r.top_factors)}</td>
    </tr>`).join('')}
  </tbody></table>`;
}
